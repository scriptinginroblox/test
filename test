-- ============================================
-- ОБНОВЛЕНИЕ GUI
-- ============================================
local function updateTradeUI()
    if not mockState.active or not mockState.trade then return end
    
    local gui = getTradeGUI()
    if not gui then return end
    
    -- Обновляем статус
    local statusLabel = gui:FindFirstChild("StatusLabel")
    if statusLabel and statusLabel:IsA("TextLabel") then
        local statusText = ""
        if mockState.trade.current_stage == "negotiation" then
            statusText = "🟡 Waiting for your action..."
        elseif mockState.trade.current_stage == "confirmation" then
            statusText = "🟢 Both accepted! Confirm the trade."
        elseif mockState.trade.current_stage == "completed" then
            statusText = "✅ Trade completed!"
        end
        statusLabel.Text = statusText
    end
    
    -- Обновляем кнопки
    local actions = findElement(gui, {"Trade", "Actions"})
    if actions then
        for _, btnName in ipairs({"Accept", "Confirm", "Decline"}) do
            local btn = actions:FindFirstChild(btnName)
            if btn then
                if mockState.trade.current_stage == "negotiation" then
                    btn.Visible = btnName == "Accept" or btnName == "Decline"
                elseif mockState.trade.current_stage == "confirmation" then
                    btn.Visible = btnName == "Confirm" or btnName == "Decline"
                elseif mockState.trade.current_stage == "completed" then
                    btn.Visible = false
                end
            end
        end
    end
    
    -- Обновляем YourOffer
    local yourOffer = findElement(gui, {"Trade", "YourOffer", "Container"})
    if yourOffer then
        for _, child in ipairs(yourOffer:GetChildren()) do
            if child:IsA("Frame") and child.Name:match("NewItem") then
                child:Destroy()
            end
        end
        
        for _, item in ipairs(mockState.trade.sender_offer.items) do
            local newItem = yourOffer:FindFirstChild("NewItem1")
            if newItem then
                local clone = newItem:Clone()
                clone.Name = "NewItem_" .. HttpService:GenerateGUID(false)
                clone.Parent = yourOffer
                
                local icon = clone:FindFirstChild("Container") and clone.Container:FindFirstChild("Icon")
                if icon and icon:IsA("ImageLabel") then
                    icon.Image = "rbxassetid://" .. (item.icon or "2005276185")
                end
                
                local amount = clone:FindFirstChild("Container") and clone.Container:FindFirstChild("Amount")
                if amount and amount:IsA("TextLabel") then
                    amount.Text = tostring(item.amount or 1)
                end
                
                local itemName = clone:FindFirstChild("ItemName")
                if itemName then
                    local label = itemName:FindFirstChild("Label")
                    if label and label:IsA("TextLabel") then
                        label.Text = item.name or "Unknown"
                    end
                end
            end
        end
    end
    
    -- Обновляем TheirOffer
    local theirOffer = findElement(gui, {"Trade", "TheirOffer", "Container"})
    if theirOffer then
        for _, child in ipairs(theirOffer:GetChildren()) do
            if child:IsA("Frame") and child.Name:match("NewItem") then
                child:Destroy()
            end
        end
        
        for _, item in ipairs(mockState.trade.recipient_offer.items) do
            local newItem = theirOffer:FindFirstChild("NewItem1")
            if newItem then
                local clone = newItem:Clone()
                clone.Name = "NewItem_" .. HttpService:GenerateGUID(false)
                clone.Parent = theirOffer
                
                local icon = clone:FindFirstChild("Container") and clone.Container:FindFirstChild("Icon")
                if icon and icon:IsA("ImageLabel") then
                    icon.Image = "rbxassetid://" .. (item.icon or "2005276185")
                end
                
                local amount = clone:FindFirstChild("Container") and clone.Container:FindFirstChild("Amount")
                if amount and amount:IsA("TextLabel") then
                    amount.Text = tostring(item.amount or 1)
                end
                
                local itemName = clone:FindFirstChild("ItemName")
                if itemName then
                    local label = itemName:FindFirstChild("Label")
                    if label and label:IsA("TextLabel") then
                        label.Text = item.name or "Unknown"
                    end
                end
            end
        end
    end
end

-- ============================================
-- ПЕРЕХВАТ REMOTE'ОВ
-- ============================================

local originals = {}

for name, remote in pairs(Remotes) do
    if remote then
        if remote:IsA("RemoteFunction") then
            originals[name] = remote.InvokeServer
        elseif remote:IsA("RemoteEvent") then
            originals[name] = remote.FireServer
        end
    end
end

-- GetTradeStatus
if Remotes.GetTradeStatus then
    Remotes.GetTradeStatus.InvokeServer = function(self)
        if mockState.active and mockState.trade then
            if mockState.trade.current_stage == "negotiation" then
                return "StartTrade"
            elseif mockState.trade.current_stage == "confirmation" then
                return "StartTrade"
            elseif mockState.trade.current_stage == "completed" then
                return "None"
            end
            return "StartTrade"
        end
        return originals.GetTradeStatus and originals.GetTradeStatus(self)
    end
end

-- SendRequest
if Remotes.SendRequest then
    Remotes.SendRequest.FireServer = function(self, player)
        if mockState.active and mockState.trade then
            if player and player.UserId == CONFIG.PARTNER_USER_ID then
                return
            end
        end
        return originals.SendRequest and originals.SendRequest(self, player)
    end
end

-- AcceptRequest
if Remotes.AcceptRequest then
    Remotes.AcceptRequest.FireServer = function(self)
        if mockState.active and mockState.trade then
            return
        end
        return originals.AcceptRequest and originals.AcceptRequest(self)
    end
end

-- AcceptTrade
if Remotes.AcceptTrade then
    Remotes.AcceptTrade.FireServer = function(self, arg1, arg2)
        if mockState.active and mockState.trade then
            if mockState.trade.current_stage == "negotiation" then
                mockState.trade.sender_offer.negotiated = true
                mockState.trade.offer_version = mockState.trade.offer_version + 1
                
                if mockState.trade.recipient_offer.negotiated then
                    mockState.trade.current_stage = "confirmation"
                    mockState.trade.offer_version = mockState.trade.offer_version + 1
                    updateTradeUI()
                    task.spawn(partnerAutoAction)
                end
                updateTradeUI()
                return
            end
        end
        return originals.AcceptTrade and originals.AcceptTrade(self, arg1, arg2)
    end
end

-- CompleteTrade
if Remotes.CompleteTrade then
    Remotes.CompleteTrade.FireServer = function(self, arg1)
        if mockState.active and mockState.trade then
            if mockState.trade.current_stage == "confirmation" then
                mockState.trade.sender_offer.confirmed = true
                mockState.trade.offer_version = mockState.trade.offer_version + 1
                
                if mockState.trade.recipient_offer.confirmed then
                    mockState.trade.current_stage = "completed"
                    mockState.trade.offer_version = mockState.trade.offer_version + 1
                    updateTradeUI()
                end
                updateTradeUI()
                return
            end
        end
        return originals.CompleteTrade and originals.CompleteTrade(self, arg1)
    end
end

-- DeclineTrade
