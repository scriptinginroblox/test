-- ─── SPAWN FUNCTION ─────────────────────────────────────────────
local function SpawnWeapon()
    local weaponName = WeaponInput.Text
    if weaponName == "" then
        -- Shake input
        Tween(WeaponInput, {Position = UDim2.new(0, 5, 0, 0)}, 0.05)
        task.wait(0.05)
        Tween(WeaponInput, {Position = UDim2.new(0, -5, 0, 0)}, 0.05)
        task.wait(0.05)
        Tween(WeaponInput, {Position = UDim2.new(0, 0, 0, 0)}, 0.05)
        return
    end

    local amount = value

    -- Show overlay
    local Overlay = Instance.new("Frame")
    Overlay.Size = UDim2.new(1, 0, 1, 0)
    Overlay.BackgroundColor3 = Color3.new(0, 0, 0)
    Overlay.BackgroundTransparency = 0.6
    Overlay.ZIndex = 100
    Overlay.Parent = MainFrame

    local OverlayText = Instance.new("TextLabel")
    OverlayText.Size = UDim2.new(1, 0, 0, 24)
    OverlayText.Position = UDim2.new(0, 0, 0.35, 0)
    OverlayText.BackgroundTransparency = 1
    OverlayText.Font = Enum.Font.GothamBold
    OverlayText.Text = "🔍 Spawning..."
    OverlayText.TextColor3 = Theme.Text
    OverlayText.TextSize = 16
    OverlayText.ZIndex = 101
    OverlayText.Parent = Overlay

    local OverlayBar = Instance.new("Frame")
    OverlayBar.Size = UDim2.new(0.5, 0, 0, 4)
    OverlayBar.Position = UDim2.new(0.25, 0, 0.5, 0)
    OverlayBar.BackgroundColor3 = Theme.Element
    OverlayBar.ZIndex = 101
    OverlayBar.Parent = Overlay
    Instance.new("UICorner", OverlayBar).CornerRadius = UDim.new(0, 2)

    local OverlayFill = Instance.new("Frame")
    OverlayFill.Size = UDim2.new(0, 0, 1, 0)
    OverlayFill.BackgroundColor3 = Theme.Text
    OverlayFill.Parent = OverlayBar
    Instance.new("UICorner", OverlayFill).CornerRadius = UDim.new(0, 2)

    local OverlayPct = Instance.new("TextLabel")
    OverlayPct.Size = UDim2.new(1, 0, 0, 20)
    OverlayPct.Position = UDim2.new(0, 0, 0.5, 18)
    OverlayPct.BackgroundTransparency = 1
    OverlayPct.Font = Enum.Font.Gotham
    OverlayPct.Text = "0%"
    OverlayPct.TextColor3 = Theme.TextDim
    OverlayPct.TextSize = 13
    OverlayPct.ZIndex = 101
    OverlayPct.Parent = Overlay

    local steps = {
        "Injecting...",
        "Bypassing...",
        "Searching...",
        "Analyzing...",
        "Creating..."
    }

    for i = 1, #steps do
        local progress = i / #steps
        OverlayFill.Size = UDim2.new(progress, 0, 1, 0)
        OverlayPct.Text = math.floor(progress * 100) .. "%"
        OverlayText.Text = "🔍 " .. steps[i]
        task.wait(0.2 + math.random() * 0.3)
    end

    -- Spawn
    local success = 0
    for i = 1, amount do
        local tool = Instance.new("Tool")
        tool.Name = weaponName

        local handle = Instance.new("Part")
        handle.Size = Vector3.new(1, 1, 1)
        handle.Anchored = false
        handle.CanCollide = false
        handle.Transparency = 0.3
        handle.BrickColor = BrickColor.Random()
        handle.Parent = tool

        local mesh = Instance.new("SpecialMesh")
        mesh.MeshType = Enum.MeshType.Brick
        mesh.Scale = Vector3.new(0.4, 0.15, 0.15)
        mesh.Parent = handle

        tool.Parent = Backpack
        success = success + 1
        task.wait(0.02)
    end

    OverlayText.Text = "✅ Done! " .. success .. "x " .. weaponName
    OverlayPct.Text = "100%"
    OverlayFill.Size = UDim2.new(1, 0, 1, 0)

    task.wait(0.6)
    Overlay:Destroy()
end

