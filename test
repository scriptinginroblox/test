    -- Color Picker (упрощенная версия)
    function Library:ColorPicker(Params)
        Params = Params or {}

        local Element = {
            Name = Params.Name or "Color",
            Flag = Params.Flag or "Color_" .. tostring(#Library.Elements + 1),
            Default = Params.Default or Color3.fromRGB(255, 180, 50),
            Callback = Params.Callback or function() end,
            Value = Params.Default or Color3.fromRGB(255, 180, 50),
            IsOpen = false,
        }

        local Container = Library:Create("Frame", {
            Size = UDim2.new(1, 0, 0, 32),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
        })

        local Label = Library:Create("TextLabel", {
            Parent = Container.Instance,
            Text = Element.Name,
            FontFace = Library.Font,
            TextSize = 14,
            TextColor3 = Theme.Text,
            Position = UDim2.new(0, 0, 0.5, 0),
            AnchorPoint = Vector2.new(0, 0.5),
            BackgroundTransparency = 1,
        })

        local ColorBtn = Library:Create("TextButton", {
            Parent = Container.Instance,
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, 0, 0.5, 0),
            Size = UDim2.new(0, 28, 0, 28),
            BackgroundColor3 = Element.Value,
            BorderSizePixel = 0,
        })

        Library:Create("UICorner", {
            Parent = ColorBtn.Instance,
            CornerRadius = UDim.new(0, 6),
        })

        Library:Create("UIStroke", {
            Parent = ColorBtn.Instance,
            Color = Theme.Outline,
            Thickness = 1,
        })

        local Palette = Library:Create("Frame", {
            Parent = Library.ScreenGui.Instance,
            Size = UDim2.new(0, 220, 0, 200),
            BackgroundColor3 = Theme.Background2,
            BorderSizePixel = 0,
            Visible = false,
            ZIndex = 100,
        })

        Library:Create("UICorner", {
            Parent = Palette.Instance,
            CornerRadius = UDim.new(0, 8),
        })

        Library:Create("UIStroke", {
            Parent = Palette.Instance,
            Color = Theme.Outline,
            Thickness = 1,
        })

        local Hue, Sat, Val = Element.Value:ToHSV()

        local function UpdateColor()
            local Color = Color3.fromHSV(Hue, Sat, Val)
            Element.Value = Color
            ColorBtn.BackgroundColor3 = Color
            Library.Flags[Element.Flag] = Color
            Library.SafeCall(Element.Callback, Color)
        end

        function Element:Toggle()
            Element.IsOpen = not Element.IsOpen
            if Element.IsOpen then
                local Pos = ColorBtn.Instance.AbsolutePosition
                Palette.Instance.Position = UDim2.new(0, Pos.X - 20, 0, Pos.Y + ColorBtn.Instance.AbsoluteSize.Y + 4)
                Palette.Instance.Visible = true
            else
                Palette.Instance.Visible = false
            end
        end

        ColorBtn.Instance.MouseButton1Click:Connect(function()
            Element:Toggle()
        end)

        local HueBar = Library:Create("Frame", {
            Parent = Palette.Instance,
            Position = UDim2.new(0, 10, 0, 10),
            Size = UDim2.new(1, -20, 0, 12),
            BackgroundColor3 = Color3.new(1, 1, 1),
            BorderSizePixel = 0,
        })

        Library:Create("UICorner", {
            Parent = HueBar.Instance,
            CornerRadius = UDim.new(1, 0),
        })

        Library:Create("UIGradient", {
            Parent = HueBar.Instance,
            Rotation = 90,
            Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
                ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
                ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
                ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
                ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
                ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0)),
            }),
        })

        local function SetHue(X)
            Hue = math.clamp(X / HueBar.Instance.AbsoluteSize.X, 0, 1)
            UpdateColor()
        end

        HueBar.Instance.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                SetHue(Input.Position.X - HueBar.Instance.AbsolutePosition.X)
            end
        end)

        Library:Connect(UserInputService.InputChanged, function(Input)
            if Element.IsOpen and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                if Input.UserInputType == Enum.UserInputType.Touch or UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                    SetHue(Input.Position.X - HueBar.Instance.AbsolutePosition.X)
                end
            end
        end)

        Library:Connect(UserInputService.InputBegan, function(Input)
            if Element.IsOpen and (Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch) then
                if not Library:IsMouseOver(Palette.Instance) and not Library:IsMouseOver(ColorBtn.Instance) then
                    Element:Toggle()
                end
            end
        end)

        Element.Instance = Container.Instance
        Library.Elements[Element.Flag] = Element
        Library.ConfigFlags[Element.Flag] = function(Value)
            Element.Value = Value
            ColorBtn.BackgroundColor3 = Value
            Library.Flags[Element.Flag] = Value
            Library.SafeCall(Element.Callback, Value)
        end

        return Element
    end

    -- Keybind
    function Library:Keybind(Params)
        Params = Params or {}

        local Element = {
            Name = Params.Name or "Keybind",
            Flag = Params.Flag or "Keybind_" .. tostring(#Library.Elements + 1),
            Default = Params.Default or Enum.KeyCode.X,
            Mode = Params.Mode or "Toggle",
            Callback = Params.Callback or function() end,
            Value = nil,
            Active = false,
            Picking = false,
        }

        local Container = Library:Create("Frame", {
            Size = UDim2.new(1, 0, 0, 32),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
        })

        local Label = Library:Create("TextLabel", {
            Parent = Container.Instance,
            Text = Element.Name,
            FontFace = Library.Font,
            TextSize = 14,
            TextColor3 = Theme.Text,
            Position = UDim2.new(0, 0, 0.5, 0),
            AnchorPoint = Vector2.new(0, 0.5),
            BackgroundTransparency = 1,
        })

        local KeyBtn = Library:Create("TextButton", {
            Parent = Container.Instance,
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, 0, 0.5, 0),
            Size = UDim2.new(0, 80, 0, 28),
            BackgroundColor3 = Theme.Element,
            BorderSizePixel = 0,
            Text = tostring(Element.Default):gsub("Enum.KeyCode.", ""),
            TextColor3 = Theme.Text,
            FontFace = Library.Font,
            TextSize = 13,
        })

        Library:Create("UICorner", {
            Parent = KeyBtn.Instance,
            CornerRadius = UDim.new(0, 6),
        })

        function Element:Set(Key)
            Element.Value = Key
            Element.Active = false

            if Key then
                local Name = tostring(Key):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "")
                KeyBtn.Text = Name
            else
                KeyBtn.Text = "None"
            end

            Library.Flags[Element.Flag] = {
                Key = Element.Value,
                Mode = Element.Mode,
                Active = Element.Active,
            }
        end

        function Element:Toggle()
            if Element.Picking then return end
            
            Element.Picking = true
            KeyBtn.Text = "..."
            
            local Connection
            Connection = UserInputService.InputBegan:Connect(function(Input)
                if Input.KeyCode == Enum.KeyCode.Escape then
                    Element.Picking = false
                    Connection:Disconnect()
                    Element:Set(Element.Default)
                    return
                end
                
                if Input.UserInputType == Enum.UserInputType.Keyboard then
                    Element:Set(Input.KeyCode)
                elseif Input.UserInputType == Enum.UserInputType.MouseButton1 or 
                       Input.UserInputType == Enum.UserInputType.MouseButton2 then
                    Element:Set(Input.UserInputType)
                else
                    return
                end
                
                Element.Picking = false
                Connection:Disconnect()
                Library.SafeCall(Element.Callback, Element.Value)
            end)
        end

        KeyBtn.Instance.MouseButton1Click:Connect(function()
            Element:Toggle()
        end)

        Element:Set(Element.Default)

        Library:Connect(UserInputService.InputBegan, function(Input)
            if not Element.Value or Element.Picking then return end
            
            if Input.KeyCode == Element.Value or Input.UserInputType == Element.Value then
                if Element.Mode == "Toggle" then
                    Element.Active = not Element.Active
                elseif Element.Mode == "Hold" then
                    Element.Active = true
                else
                    Element.Active = true
                end
                
                Library.SafeCall(Element.Callback, Element.Active)
                Library.Flags[Element.Flag].Active = Element.Active
            end
        end)

        Library:Connect(UserInputService.InputEnded, function(Input)
            if not Element.Value or Element.Picking then return end
            
            if Input.KeyCode == Element.Value or Input.UserInputType == Element.Value then
                if Element.Mode == "Hold" then
                    Element.Active = false
                    Library.SafeCall(Element.Callback, Element.Active)
                    Library.Flags[Element.Flag].Active = Element.Active
                end
            end
        end)

        Element.Instance = Container.Instance
        Library.Elements[Element.Flag] = Element
        Library.ConfigFlags[Element.Flag] = function(Value)
            Element:Set(Value)
        end

        return Element
    end

    -- ═══════════════════════════════════════════════════════════════
    -- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
    -- ═══════════════════════════════════════════════════════════════
    
    function Library:IsMouseOver(Instance)
        if not Instance then return false end
        local MousePos = Vector2.new(Mouse.X, Mouse.Y)
        local Pos = Instance.AbsolutePosition
        local Size = Instance.AbsoluteSize
        return MousePos.X >= Pos.X and MousePos.X <= Pos.X + Size.X and
               MousePos.Y >= Pos.Y and MousePos.Y <= Pos.Y + Size.Y
    end
    
    function Library:Notify(Params)
        Params = Params or {}
        
        local Container = Library:Create("Frame", {
            Parent = Library.ScreenGui.Instance,
            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.new(1, -16, 0, 16),
            Size = UDim2.new(0, 300, 0, 0),
            BackgroundColor3 = Theme.Background2,
            BorderSizePixel = 0,
            AutomaticSize = Enum.AutomaticSize.Y,
            ClipsDescendants = true,
        })
        
        Library:Create("UICorner", {
            Parent = Container.Instance,
            CornerRadius = UDim.new(0, 8),
        })
        
        Library:Create("UIStroke", {
            Parent = Container.Instance,
            Color = Theme.Outline,
            Thickness = 1,
        })
        
        Library:Create("UIPadding", {
            Parent = Container.Instance,
            PaddingTop = UDim.new(0, 12),
            PaddingBottom = UDim.new(0, 12),
            PaddingLeft = UDim.new(0, 14),
            PaddingRight = UDim.new(0, 14),
        })
        
        local Title = Library:Create("TextLabel", {
            Parent = Container.Instance,
            Text = Params.Title or "Notification",
            FontFace = Library.FontBold,
            TextSize = 15,
            TextColor3 = Theme.Text,
            BackgroundTransparency = 1,
        })
        
        local Desc = Library:Create("TextLabel", {
            Parent = Container.Instance,
            Text = Params.Description or "",
            FontFace = Library.Font,
            TextSize = 13,
            TextColor3 = Theme.TextDim,
            BackgroundTransparency = 1,
            TextWrapped = true,
        })
        
        local Progress = Library:Create("Frame", {
            Parent = Container.Instance,
            Size = UDim2.new(1, 0, 0, 2),
            Position = UDim2.new(0, 0, 1, -2),
            BackgroundColor3 = Theme.Accent1,
            BorderSizePixel = 0,
        })
        Library:AddPulse(Progress, 0.15)
        
        local Duration = Params.Duration or 3
        
        local Tween = TweenService:Create(Progress.Instance, TweenInfo.new(Duration, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0, 0, 0, 2),
        })
        Tween:Play()
        
        task.delay(Duration, function()
            Container.Instance:Destroy()
        end)
        
        return Container
    end
    
    -- ═══════════════════════════════════════════════════════════════
    -- УПРАВЛЕНИЕ ОКНОМ
    -- ═══════════════════════════════════════════════════════════════
    
    function Library:Toggle(State)
        if State ~= nil then
            Library.IsOpen = State
        else
            Library.IsOpen = not Library.IsOpen
        end
        
        if Library.ScreenGui then
            Library.ScreenGui.Instance.Enabled = Library.IsOpen
        end
    end
    
    -- ═══════════════════════════════════════════════════════════════
    -- АВТОЗАГРУЗКА
    -- ═══════════════════════════════════════════════════════════════
    
    function Library:AutoLoad()
        local Configs = Library:GetConfigsList()
        for _, Name in pairs(Configs) do
            Library:LoadConfigFile(Name)
            break
        end
    end
    
    -- ═══════════════════════════════════════════════════════════════
    -- ВОЗВРАТ
    -- ═══════════════════════════════════════════════════════════════
    
    getgenv().PulseUI = Library
    return Library
end
