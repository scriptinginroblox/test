            configDropdown:Refresh(Library:GetConfigList())
        end
    })
    
    configSection:Button({
        Name = "Set Auto Load",
        Callback = function()
            if configName and configName ~= "" then
                Library:SetAutoLoad(configName)
                Library:Notify({ Title = "Config", Description = "Auto-load set: " .. configName, Type = "success" })
            end
        end
    })
    
    configSection:Button({
        Name = "Clear Auto Load",
        Callback = function()
            Library:ClearAutoLoad()
            Library:Notify({ Title = "Config", Description = "Auto-load cleared", Type = "info" })
        end
    })
    
    local themeSection = page:Section({ Name = "Themes" })
    
    local themeDropdown = themeSection:Dropdown({
        Name = "Theme Preset",
