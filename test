                    check.Position = UDim2.new(1, -18, 0.5, -6)
                    check.ImageTransparency = 1
                    
                    itemFrame.MouseEnter:Connect(function()
                        tween(itemFrame, {BackgroundTransparency = 0.85})
                        tween(itemLabel, {TextColor3 = Theme.Text})
                    end)
                    itemFrame.MouseLeave:Connect(function()
                        tween(itemFrame, {BackgroundTransparency = 1})
                        tween(itemLabel, {TextColor3 = Theme.TextDim})
                    end)
                    itemFrame.MouseButton1Click:Connect(function()
                        selectItem(item, true)
                    end)
                end
                
                DropdownBtn.MouseButton1Click:Connect(function()
                    if isOpen then
                        closeList()
                    else
                        openList()
                    end
                end)
                
                UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        if isOpen then
                            local pos = input.Position
                            local abs = DropdownBtn.AbsolutePosition
                            local size = DropdownBtn.AbsoluteSize
                            if pos.X < abs.X or pos.X > abs.X + size.X or pos.Y < abs.Y or pos.Y > abs.Y + size.Y then
                                closeList()
                            end
                        end
                    end
                end)
                
                if multi then
                    if type(default) == "table" then
                        for _, v in ipairs(default) do
                            selectedMulti[v] = true
