-- Парсинг FR, NFR и MFR цен для твоих питомцев

local _LocalPlayer = game:GetService('Players').LocalPlayer
local _HttpService = game:GetService('HttpService')

local function createLogGUI()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "PetValues"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = _LocalPlayer:WaitForChild("PlayerGui")
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 420, 0, 480)
    frame.Position = UDim2.new(0.5, -210, 0.5, -240)
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = 0.2
    frame.BorderSizePixel = 0
    frame.Parent = screenGui
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = frame
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, -10, 1, -10)
    textLabel.Position = UDim2.new(0, 5, 0, 5)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = "⏳ Загрузка цен..."
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    textLabel.TextSize = 12
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextWrapped = true
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.TextYAlignment = Enum.TextYAlignment.Top
    textLabel.Parent = frame
    
    return {
        frame = frame,
        textLabel = textLabel,
        log = function(self, msg, color)
            color = color or Color3.fromRGB(255, 255, 255)
            local lines = {}
            for line in (self.textLabel.Text .. "\n" .. msg):gmatch("[^\n]+") do
                table.insert(lines, line)
            end
            if #lines > 36 then
                for i = 1, #lines - 36 do table.remove(lines, 1) end
            end
            self.textLabel.Text = table.concat(lines, "\n")
            self.textLabel.TextColor3 = color
        end
    }
end

local logGUI = createLogGUI()
logGUI:log("📊 Загрузка цен с winadopt.me...", Color3.fromRGB(255, 255, 0))

task.spawn(function()
    local success, html = pcall(function()
        return game:HttpGet("https://winadopt.me/value-list.php")
    end)
    
    if not success or not html or html == "" then
        logGUI:log("❌ НЕ УДАЛОСЬ ЗАГРУЗИТЬ!", Color3.fromRGB(255, 0, 0))
        return
    end
    
    logGUI:log("✅ Сайт загружен, парсинг...", Color3.fromRGB(0, 255, 0))
    
    -- Храним цены: FR (колонка 3), NFR (колонка 4), MFR (колонка 5)
    local PetValues = {}
    
    for row in html:gmatch("<tr>(.-)</tr>") do
        local cols = {}
        for col in row:gmatch("<td[^>]*>(.-)</td>") do
            local c = col:gsub("<.->",""):gsub("%s+"," "):gsub("^%s*(.-)%s*$","%1")
            table.insert(cols, c)
        end
        if #cols >= 5 then
            local name = cols[1]
            local frValue = tonumber(cols[3]) or 0   -- FR Value
            local nfrValue = tonumber(cols[4]) or 0  -- NFR Value
            local mfrValue = tonumber(cols[5]) or 0  -- MFR Value
            if name and name ~= "" then
                PetValues[name:lower()] = {
                    fr = frValue,
                    nfr = nfrValue,
                    mfr = mfrValue
                }
            end
        end
    end
    
    logGUI:log("✅ Найдено питомцев: " .. #PetValues, Color3.fromRGB(0, 255, 0))
    logGUI:log("━━━━━━━━━━━━━━━━━━━━━━━━", Color3.fromRGB(255, 255, 255))
    
    -- ТВОЙ СПИСОК ПИТОМЦЕВ
    local petNames = {
        {"african_wild_dog", "African Wild Dog"},
        {"albino_monkey", "Albino Monkey"},
        {"arctic_reindeer", "Arctic Reindeer"},
        {"balloon_unicorn", "Balloon Unicorn"},
        {"bat_dragon", "Bat Dragon"},
        {"blazing_lion", "Blazing Lion"},
        {"candyfloss_chick", "Candyfloss Chick"},
        {"crow", "Crow"},
        {"frost_dragon", "Frost Dragon"},
        {"giraffe", "Giraffe"},
        {"goat", "Goat"},
        {"hare", "Hare"},
        {"hedgehog", "Hedgehog"},
        {"owl", "Owl"},
        {"parrot", "Parrot"},
        {"peppermint_penguin", "Peppermint Penguin"},
        {"shadow_dragon", "Shadow Dragon"},
        {"sheeeeep", "Sheeeeep"},
        {"strawberry_shortcake_bat_dragon", "Strawberry Shortcake Bat Dragon"},
    }
    
    local found = 0
    local totalFR = 0
    local totalNFR = 0
    local totalMFR = 0
    
    for _, pet in ipairs(petNames) do
        local id = pet[1]
        local name = pet[2]
        local data = PetValues[id:lower()]
        
        if data and (data.fr > 0 or data.nfr > 0 or data.mfr > 0) then
            found = found + 1
            totalFR = totalFR + data.fr
            totalNFR = totalNFR + data.nfr
            totalMFR = totalMFR + data.mfr
            
            local line = name .. " | "
            if data.fr > 0 then
                line = line .. "FR:" .. data.fr .. " "
            else
                line = line .. "FR:— "
            end
            if data.nfr > 0 then
                line = line .. "NFR:" .. data.nfr .. " "
            else
                line = line .. "NFR:— "
            end
            if data.mfr > 0 then
                line = line .. "MFR:" .. data.mfr
            else
                line = line .. "MFR:—"
            end
            logGUI:log("✅ " .. line, Color3.fromRGB(0, 255, 0))
        else
            logGUI:log("❌ " .. name .. ": НЕ НАЙДЕН", Color3.fromRGB(255, 0, 0))
        end
        task.wait(0.03)
    end
    
    logGUI:log("━━━━━━━━━━━━━━━━━━━━━━━━", Color3.fromRGB(255, 255, 255))
    logGUI:log("📊 Найдено: " .. found .. "/" .. #petNames, Color3.fromRGB(255, 255, 0))
    logGUI:log("💰 Сумма FR: " .. string.format("%.2f", totalFR), Color3.fromRGB(100, 200, 255))
    logGUI:log("💰 Сумма NFR: " .. string.format("%.2f", totalNFR), Color3.fromRGB(255, 200, 100))
    logGUI:log("💰 Сумма MFR: " .. string.format("%.2f", totalMFR), Color3.fromRGB(255, 100, 255))
    
    pcall(function()
        game.StarterGui:SetCore('SendNotification', {
            Title = '✅ Готово!',
            Text = 'Найдено ' .. found .. ' питомцев.',
            Duration = 5,
        })
    end)
end)
