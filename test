        if playerCharacter and playerCharacter:FindFirstChild('HumanoidRootPart') then
            character:SetPrimaryPartCFrame(playerCharacter.HumanoidRootPart.CFrame * CFrame.new(math.random(-8, 8), 0, math.random(-8, 8)))
        end
        local humanoid = character:WaitForChild('Humanoid')
        humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
        humanoid.HealthDisplayType = Enum.HumanoidHealthDisplayType.AlwaysOff
        humanoid.HealthDisplayDistance = 0
        character.Parent = folder_fake

        pcall(function() UIManager.apps.PlayerNameApp:add_npc_id(character, partner_name) end)

        local Part = character:FindFirstChild('HumanoidRootPart')
        if Part then
            local InteractionsEngine = load('InteractionsEngine')
            local emptyFunc = function() end
            pcall(function()
                InteractionsEngine:register({
                    text = partner_name, part = Part,
                    on_selected = {
                        { text = 'Profile', on_selected = function() pcall(PlayerProfileApp.open_player_profile_for_user_id, partner_id) end },
                        { text = 'Trade', on_selected = function()
                            pcall(function()
                                task.spawn(function()
                                    pcall(function()
                                        if HintApp then HintApp:hint({ text = 'Trade request sent to ' .. partner_name, length = 3, overridable = true }) end
                                    end)
                                end)
                                task.wait(CONFIG.FAKE_PLAYER_ACCEPT_TRADE_REQUEST)
                                updatePartnerFromUsername(partner_name)
                                startMockTradeDirectly()
                            end)
                        end },
                        { text = 'Give Item...', on_selected = emptyFunc },
                        { text = 'Mute', on_selected = emptyFunc },
                    },
                })
            end)
        end

        table.insert(FakePlayers, folder_fake)
        folder_fake:SetAttribute('IsFakePlayer', true)
        folder_fake:SetAttribute('PartnerName', partner_name)
        folder_fake:SetAttribute('PartnerId', partner_id)
        
        return true
    end
    
    local FakePlayers = {}
    
    -- ============================================
    -- СПАВНЕР ПИТОМЦЕВ В ИНВЕНТАРЬ
    -- ============================================
    local function spawnPets()
        notify('🔄 Спавн', 'Петов в инвентарь...', 2)
        
        local petSpawnerSuccess, petSpawnerErr = pcall(function()
            local _KindDB = require(ReplicatedStorage.Fsys).load('KindDB')
            
            local function addPetToInventory(kind, properties)
                local unique = HttpService:GenerateGUID(false)
                local petData = nil
                
                updateData('inventory', function(inv)
                    local newInv = table.clone(inv)
                    if not newInv.pets then newInv.pets = {} end
                    
                    petData = {
                        unique = unique,
                        category = 'pets',
                        id = kind,
                        kind = _KindDB[kind].kind,
                        newness_order = 0,
                        properties = properties,
                    }
                    newInv.pets[unique] = petData
                    return newInv
                end)
                
                return petData
            end
            
            local function GetPetIdByName(petName)
                for id, data in pairs(InventoryDB.pets) do
                    if data.name and data.name:lower() == petName:lower() then return id end
                    if id:lower() == petName:lower() then return id end
                end
                return nil
            end
            
            local availablePets = {}
            for name, data in pairs(PetValues) do
                local id = GetPetIdByName(name)
                if id then
                    table.insert(availablePets, {
                        id = id,
                        name = name,
                        fr = data.fr,
                        nfr = data.nfr,
                        mfr = data.mfr
                    })
                end
            end
            
            if #availablePets == 0 then
                notify('❌ Ошибка', 'Нет петов для спавна!', 3)
                return
            end
            
            local ageNames = {
                [1] = "Reborn", [2] = "Sparkle", [3] = "Twinkle", [4] = "Flare",
                [5] = "Luminous", [6] = "Sunshine", [7] = "Full Grown", [8] = "Post Teen",
                [9] = "Teen", [10] = "Pre Teen", [11] = "Junior", [12] = "Newborn",
            }
            
            for i = #availablePets, 2, -1 do
                local j = math.random(1, i)
                availablePets[i], availablePets[j] = availablePets[j], availablePets[i]
            end
            
            local petCount = math.random(10, 15)
            local targetMin = 4500
            local targetMax = 6000
            local currentValue = 0
            local spawnedPets = {}
            local attempts = 0
            local maxAttempts = 300
            
            while #spawnedPets < petCount and attempts < maxAttempts do
                attempts = attempts + 1
                local randomIndex = math.random(1, #availablePets)
                local pet = availablePets[randomIndex]
                
                local age = math.random(1, 12)
                local ageName = ageNames[age] or "Unknown"
                
                local variantType
                local price
                
                if pet.mfr < 100 then
                    variantType = "MFR"
                    price = pet.mfr
                else
                    local variants = {
                        {name = "FR", price = pet.fr},
                        {name = "NFR", price = pet.nfr},
                        {name = "MFR", price = pet.mfr},
                    }
                    local chosen = variants[math.random(1, 3)]
                    variantType = chosen.name
                    price = chosen.price
                end
                
                if price <= 0 then
                    price = pet.fr
                    if price <= 0 then price = pet.nfr end
                    if price <= 0 then price = pet.mfr end
                    if price <= 0 then
                        task.wait(0.05)
                        continue
                    end
                end
                
                local petData = {
                    pet_trick_level = 0,
                    rideable = true,
                    flyable = true,
                    friendship_level = 0,
                    age = age,
                    ailments_completed = 0,
                    rp_name = '',
                }
                
                if variantType == "MFR" then
                    petData.mega_neon = true
                elseif variantType == "NFR" then
                    petData.neon = true
                end
                
                local success, result = pcall(function()
                    return addPetToInventory(pet.id, petData)
                end)
                
                if success and result then
                    currentValue = currentValue + price
                    table.insert(spawnedPets, pet.name .. " (" .. variantType .. ", " .. ageName .. ")")
                    
                    pcall(function()
                        StarterGui:SetCore('SendNotification', {
                            Title = '✅ Спавн!',
                            Text = pet.name .. ' (' .. variantType .. ', ' .. ageName .. ')',
                            Duration = 2,
                        })
                    end)
                end
                
                task.wait(0.08)
                
                if currentValue >= targetMin and #spawnedPets >= 10 then
                    break
                end
            end
            
            if #spawnedPets > 0 then
                notify('✅ Спавнено', #spawnedPets .. ' петов | Сумма: ' .. string.format('%.1f', currentValue), 4)
            else
                notify('❌ Ошибка', 'Не спавнено ни одного пета!', 3)
            end
        end)
        
        if not petSpawnerSuccess then
            notify('❌ Ошибка спавнера', tostring(petSpawnerErr), 5)
        end
    end
    
    -- ============================================
    -- ЗАПУСК
    -- ============================================
    notify('🎭 Спавн бота', 'Создаю фейк-игрока...', 2)
    
    local success, err = pcall(function()
        CreateFakePlayerCharacter(CONFIG.PARTNER_NAME, CONFIG.PARTNER_USER_ID)
    end)
    
    if success then
        notify('✅ Бот создан!', 'Кликни на него -> Trade', 4)
    else
        notify('❌ Ошибка', tostring(err), 5)
    end
    
    -- Запускаем спавнер петов
    task.spawn(function()
        task.wait(3)
        spawnPets()
    end)
end

-- Запускаем main
local success, err = pcall(main)
if not success then
    notify('❌ КРИТИЧЕСКАЯ ОШИБКА', tostring(err), 10)
end

notify('✅ Готово!', 'Скрипт запущен!', 3)
