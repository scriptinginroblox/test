                })
            end)
        end

        table.insert(FakePlayers, folder_fake)
        folder_fake:SetAttribute('IsFakePlayer', true)
        folder_fake:SetAttribute('PartnerName', partner_name)
        folder_fake:SetAttribute('PartnerId', partner_id)
        return true
    end

    return attemptCreate()
end

