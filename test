local value = 500
local minVal = 1
local maxVal = 1000
local dragging = false

local function UpdateSlider(val)
    value = math.clamp(val, minVal, maxVal)
    local percent = (value - minVal) / (maxVal - minVal)
    Tween(SliderFill, {Size = UDim2.new(percent, 0, 1, 0)})
    Tween(SliderHandle, {Position = UDim2.new(percent, -9, 1, -7)})
    SliderValue.Text = tostring(value)
end

SliderHandle.MouseButton1Down:Connect(function()
    dragging = true
end)
SliderHandle.MouseButton1Up:Connect(function()
    dragging = false
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

local function GetSliderPos()
    local mouse = UserInputService:GetMouseLocation()
    local trackPos = SliderTrack.AbsolutePosition.X
    local trackSize = SliderTrack.AbsoluteSize.X
    if trackSize == 0 then return 0 end
    return math.clamp((mouse.X - trackPos) / trackSize, 0, 1)
end

RunService.RenderStepped:Connect(function()
    if dragging then
        local percent = GetSliderPos()
        UpdateSlider(minVal + (maxVal - minVal) * percent)
    end
end)

SliderTrack.MouseButton1Down:Connect(function()
    local percent = GetSliderPos()
    UpdateSlider(minVal + (maxVal - minVal) * percent)
end)

