function VoltageHub:GetIcon(name)
    return Icons[name] or name
end

function VoltageHub:CreateIcon(name, size, color)
    local frame = Instance.new("Frame")
    frame.BackgroundTransparency = 1
    frame.Size = size or UDim2.fromOffset(20, 20)
    
    local image = Instance.new("ImageLabel")
    image.BackgroundTransparency = 1
    image.Size = UDim2.new(1, 0, 1, 0)
    image.Image = self:GetIcon(name)
    image.ImageColor3 = color or Color3.fromRGB(255, 255, 255)
    image.Parent = frame
    
    return frame
end

