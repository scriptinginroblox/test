                        local list = {}
                        for k, v in pairs(selectedMulti) do
                            if v then table.insert(list, k) end
                        end
                        ValueLabel.Text = #list > 0 and table.concat(list, ", ") or "None"
                    end
                else
                    selectItem(default, false)
                end
                
                FlagSetters[flag] = function(v)
                    if multi then
                        selectedMulti = {}
                        if type(v) == "table" then
                            for _, item in ipairs(v) do
                                selectedMulti[item] = true
                            end
                        end
                        local list = {}
                        for k, v2 in pairs(selectedMulti) do
                            if v2 then table.insert(list, k) end
                        end
                        ValueLabel.Text = #list > 0 and table.concat(list, ", ") or "None"
                        Flags[flag] = list
                        pcall(callback, list)
                    else
                        selectItem(v, true)
                    end
                end
                
                return {
                    Set = function(v)
