    -- ═══════════════════════════════════════════════════════════════
    -- БАЗОВЫЕ ФУНКЦИИ
    -- ═══════════════════════════════════════════════════════════════

    function Library:Create(Class, Props)
        local Inst = Instance.new(Class)

        if Class:match("Text") then
            if type(Library.Font) == "table" and Library.Font.ClassName == "Font" then
                pcall(function() Inst.FontFace = Library.Font end)
            end
            if not Inst.FontFace then
                pcall(function()
                    if type(Library.Font) == "table" and Library.Font.ClassName == "Font" then
                        Inst.Font = Library.Font
                    else
                        Inst.Font = Library.Font
                    end
                end)
            end
            if not Inst.FontFace and not Inst.Font then
                pcall(function() Inst.Font = Enum.Font.SourceSans end)
            end
            Inst.TextSize = 14
            Inst.TextColor3 = Theme.Text
        end

        if Class == "TextButton" then
            Inst.AutoButtonColor = false
            Inst.Text = ""
        end

        if Class == "ImageButton" then
            Inst.AutoButtonColor = false
        end

        Inst.Name = "\0"

        for K, V in pairs(Props or {}) do
            Inst[K] = V
        end

        return setmetatable({Instance = Inst}, Library)
    end

    function Library:Connect(Sig, Callback)
        local Conn
        if type(Sig) == "Instance" and Sig:IsA("RBXScriptSignal") then
            Conn = Sig:Connect(Callback)
        elseif Sig and type(Sig) == "table" and Sig.Instance then
            Conn = Sig.Instance:Connect(Callback)
        else
            Conn = Sig:Connect(Callback)
        end
        if Conn then
            table.insert(Library.Connections, Conn)
        end
        return Conn
    end

    function Library:Thread(Func)
        local T = coroutine.create(Func)
        coroutine.wrap(function() coroutine.resume(T) end)()
        table.insert(Library.Threads, T)
        return T
    end

    function Library:Tween(Obj, Props, Info)
        local Inst = Obj.Instance or Obj
        Info = Info or TweenInfo.new(Library.TweenSpeed, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
        local T = TweenService:Create(Inst, Info, Props)
        T:Play()
        return T
    end

    function Library:SafeCall(Func, ...)
        if not Func then return end
        local Args = {...}
        local S, R = pcall(Func, table.unpack(Args))
        if not S then warn("[PulseUI]", R) end
        return S, R
    end

    function Library:Round(Num, Dec)
        local M = 10 ^ (Dec or 0)
        return math.floor(Num * M + 0.5) / M
    end

    -- ═══════════════════════════════════════════════════════════════
    -- КОНФИГИ
    -- ═══════════════════════════════════════════════════════════════

    function Library:GetConfig()
        local Cfg = {}
        for Flag, Val in pairs(Library.Flags) do
            if type(Val) == "table" and Val.Color then
                Cfg[Flag] = {Color = Val.Color:ToHex(), Transparency = Val.Transparency}
            elseif type(Val) == "table" and Val.Key then
                Cfg[Flag] = {Key = tostring(Val.Key), Mode = Val.Mode, Active = Val.Active}
            else
                Cfg[Flag] = Val
            end
        end
        return HttpService:JSONEncode(Cfg)
    end

    function Library:LoadConfig(JSON)
        local Cfg = HttpService:JSONDecode(JSON)
        for Flag, Val in pairs(Cfg) do
            local Func = Library.ConfigFlags[Flag]
            if Func then
                if type(Val) == "table" and Val.Color then
                    Func(Color3.fromHex(Val.Color), Val.Transparency)
                elseif type(Val) == "table" and Val.Key then
                    Func({Key = Val.Key, Mode = Val.Mode, Active = Val.Active})
                else
                    Func(Val)
                end
            end
        end
    end

    function Library:SaveConfig(Name)
        if not Name or Name == "" then return end
        local Path = string.format("%s%s/%s.json", Library.Directory, Library.Folders.Configs, Name)
        writefile(Path, Library:GetConfig())
    end

    function Library:LoadConfigFile(Name)
        if not Name or Name == "" then return end
        local Path = string.format("%s%s/%s.json", Library.Directory, Library.Folders.Configs, Name)
        if isfile(Path) then Library:LoadConfig(readfile(Path)) end
    end

    function Library:DeleteConfig(Name)
        if not Name or Name == "" then return end
        local Path = string.format("%s%s/%s.json", Library.Directory, Library.Folders.Configs, Name)
        if isfile(Path) then delfile(Path) end
    end

    function Library:GetConfigsList()
        local List = {}
        local Path = Library.Directory .. Library.Folders.Configs
        for _, File in pairs(listfiles(Path)) do
            local Name = File:gsub(Path .. "/", ""):gsub(Path .. "\\", ""):gsub(".json", "")
            if Name ~= "" then table.insert(List, Name) end
        end
        return List
    end

    function Library:AutoLoad()
        local Configs = Library:GetConfigsList()
        for _, Name in pairs(Configs) do
            Library:LoadConfigFile(Name)
            break
        end
    end

    function Library:Unload()
        for _, C in pairs(Library.Connections) do
            if C and C.Disconnect then pcall(C.Disconnect, C) end
        end
        Library.Connections = {}
        for _, C in pairs(Library.PulseConnections) do
            if C and C.Disconnect then pcall(C.Disconnect, C) end
        end
        Library.PulseConnections = {}
        for _, T in pairs(Library.Threads) do
            if T then pcall(coroutine.close, T) end
        end
        Library.Threads = {}
        if Library.ScreenGui and Library.ScreenGui.Instance then
            pcall(Library.ScreenGui.Instance.Destroy, Library.ScreenGui.Instance)
            Library.ScreenGui = nil
        end
        getgenv().PulseUI = nil
    end

    -- ═══════════════════════════════════════════════════════════════
    -- ПУЛЬСАЦИЯ
    -- ═══════════════════════════════════════════════════════════════

    function Library:AddPulse(Obj, Intensity)
        Intensity = Intensity or 0.12
        local Inst = Obj.Instance or Obj
        
        if Inst:IsA("UIStroke") then
            local Conn = Library:Connect(RunService.RenderStepped, function()
                if Inst and Inst.Parent then
                    local P = math.sin(tick() * Library.PulseSpeed) * 0.08 + 0.2
                    Inst.Transparency = math.clamp(P, 0, 0.5)
                end
            end)
            if Conn then table.insert(Library.PulseConnections, Conn) end
            return
        end
        
        if Inst:IsA("ImageLabel") or Inst:IsA("ImageButton") then
            table.insert(Library.PulseObjects, {
                Object = Inst,
                Intensity = Intensity,
                OriginalColor = Inst.ImageColor3,
                IsImage = true,
            })
            return
        end
        
        table.insert(Library.PulseObjects, {
            Object = Inst,
            Intensity = Intensity,
            OriginalColor = Inst.BackgroundColor3,
            IsImage = false,
        })
    end

    local PulseConnection = Library:Connect(RunService.RenderStepped, function()
        local Time = tick()
        for _, Data in pairs(Library.PulseObjects) do
            if Data.Object and Data.Object.Parent then
                local P = math.sin(Time * Library.PulseSpeed) * Data.Intensity
                if Data.IsImage then
                    local C = Data.OriginalColor
                    Data.Object.ImageColor3 = Color3.new(
                        math.clamp(C.R + P, 0, 1),
                        math.clamp(C.G + P * 0.7, 0, 1),
                        math.clamp(C.B + P * 0.3, 0, 1)
                    )
                else
                    local C = Data.OriginalColor
                    Data.Object.BackgroundColor3 = Color3.new(
                        math.clamp(C.R + P, 0, 1),
                        math.clamp(C.G + P * 0.7, 0, 1),
                        math.clamp(C.B + P * 0.3, 0, 1)
                    )
                end
            end
        end
    end)
    if PulseConnection then table.insert(Library.PulseConnections, PulseConnection) end

    -- ═══════════════════════════════════════════════════════════════
    -- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
