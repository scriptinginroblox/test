-- =========================================================
-- ТЕМА ПО УМОЛЧАНИЮ
-- =========================================================
local DefaultTheme = {
    Bg = Color3.fromRGB(12, 12, 14),
    SidebarBg = Color3.fromRGB(16, 16, 20),
    GroupBg = Color3.fromRGB(20, 20, 25),
    ElementBg = Color3.fromRGB(24, 24, 30),
    ElementHover = Color3.fromRGB(34, 34, 42),
    Text = Color3.fromRGB(255, 255, 255),
    TextDim = Color3.fromRGB(150, 150, 165),
    White = Color3.fromRGB(255, 255, 255),
    ToggleOff = Color3.fromRGB(60, 60, 70),
    ToggleOn = Color3.fromRGB(255, 140, 0),
    OrangeStart = Color3.fromRGB(255, 120, 0),
    Border = Color3.fromRGB(35, 35, 42),
    GradientStart = Color3.fromRGB(255, 200, 80),
    GradientEnd = Color3.fromRGB(255, 120, 0)
}

-- =========================================================
-- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
-- =========================================================
local function Round(obj, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = obj
    return c
end

local function Tween(obj, props, time)
    if not obj then return end
    TweenService:Create(obj, TweenInfo.new(time or 0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), props):Play()
end

local function MakeDraggable(obj)
    local dragging, startPos, dragStart
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            startPos = obj.Position
            dragStart = input.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- =========================================================
-- ФУНКЦИЯ ГРАДИЕНТА (ТОЛЬКО ДЛЯ ИКОНОК)
-- =========================================================
local function CreateGradient(obj, theme)
    theme = theme or DefaultTheme
    local grad = Instance.new("UIGradient")
    grad.Rotation = 45
    grad.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, theme.GradientStart),
        ColorSequenceKeypoint.new(1, theme.GradientEnd)
    }
    grad.Parent = obj
    return grad
end

