local function spawnFakePlayer()
    local partnerName = CONFIG.PARTNER_NAME
    local partnerId = CONFIG.PARTNER_USER_ID
    
    local success, userId = pcall(function()
        return Players:GetUserIdFromNameAsync(partnerName)
    end)
    if success and userId then
        partnerId = userId
        CONFIG.PARTNER_USER_ID = userId
    end
    
    CreateFakePlayerCharacterFromPARTNER_NAME(partnerName, partnerId)
end

