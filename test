        end
    end)
    
    -- Кнопка Close
    createBtn("❌ Close Trade", 270, Color3.fromRGB(150, 40, 40), Color3.fromRGB(200, 50, 50), function()
        if mockState.active then
            mockState.active = false
            mockState.trade = nil
            local gui = getTradeGUI()
