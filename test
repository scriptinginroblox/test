                SwitchKnob.BorderSizePixel = 0
                SwitchKnob.Parent = Switch
                corner(SwitchKnob, 8)
                
                local State = default
                
                local function setState(value, fire)
                    State = value
                    local pos = value and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
                    tween(SwitchKnob, {Position = pos}, 0.15)
                    tween(Switch, {BackgroundColor3 = value and Theme.Voltage or Theme.Element}, 0.15)
                    Flags[flag] = value
                    if fire then pcall(callback, value) end
                end
                
                setState(default, false)
                
                ToggleContainer.MouseButton1Click:Connect(function()
                    setState(not State, true)
                end)
                
                FlagSetters[flag] = function(value)
                    setState(value, true)
                end
                
                return {
                    Set = function(value) setState(value, true) end,
                    Get = function() return State end,
                    Toggle = function() setState(not State, true) end,
                }
            end
            
