createBtn(rightCol, "⚔️", "Combat")

-- ===== ОТКРЫТИЕ/ЗАКРЫТИЕ =====
local opened = false

openBtn.MouseButton1Click:Connect(function()
	opened = not opened
	menu.Visible = opened

	if opened then
		updateMenuPos()
	end
end)

openBtn:GetPropertyChangedSignal("AbsolutePosition"):Connect(function()
	if menu.Visible then
		updateMenuPos()
	end
end)
