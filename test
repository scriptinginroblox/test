-- ============================================
-- ПОИСК ЭЛЕМЕНТОВ В GUI
-- ============================================
local function findElement(gui, path)
    if not gui then return nil end
    local current = gui
    for _, name in ipairs(path) do
        current = current:FindFirstChild(name)
        if not current then return nil end
    end
    return current
end

