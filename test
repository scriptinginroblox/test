local Window = {}
Window._open = false
Window._main = nil
Window._tabs = {}
Window._currentTab = nil

function Window:Toggle()
    self._open = not self._open
    if self._open then
        self._main.Visible = true
        tween(self._main, { BackgroundTransparency = 0 }, 0.3)
        if self._currentTab then
            self:SelectTab(self._currentTab)
        elseif #self._tabs > 0 then
            self:SelectTab(self._tabs[1].name)
        end
    else
        tween(self._main, { BackgroundTransparency = 1 }, 0.25)
        task.wait(0.25)
        self._main.Visible = false
    end
end

function Window:SelectTab(name)
    for _, tab in ipairs(self._tabs) do
        if tab.name == name then
            self._currentTab = name
            for _, child in ipairs(tab.container:GetChildren()) do
                if child:IsA("Frame") then
                    child.Visible = false
                end
            end
            if tab.content then
                tab.content.Visible = true
            end
            for _, btn in ipairs(self._tabButtons) do
                if btn.tabName == name then
                    btn.BackgroundTransparency = 0
                    btn.TextColor3 = Color3.new(1, 1, 1)
                else
                    btn.BackgroundTransparency = 1
                    btn.TextColor3 = Color3.fromRGB(180, 190, 200)
                end
            end
            break
        end
    end
end

