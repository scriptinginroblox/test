    titleLabel.Size = UDim2.new(1, -20, 0, 38)
    titleLabel.Position = UDim2.new(0, 10, 0, 95)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = window.Title
    titleLabel.TextColor3 = self.Theme.Text
    titleLabel.FontFace = self.FontBold
    titleLabel.TextSize = 28
    titleLabel.TextXAlignment = Enum.TextXAlignment.Center
    titleLabel.Parent = leftPanel
    
    local subLabel = Instance.new("TextLabel")
    subLabel.Size = UDim2.new(1, -20, 0, 20)
    subLabel.Position = UDim2.new(0, 10, 0, 135)
    subLabel.BackgroundTransparency = 1
    subLabel.Text = window.Subtitle
    subLabel.TextColor3 = self.Theme.TextDim
    subLabel.FontFace = self.Font
    subLabel.TextSize = 14
    subLabel.TextXAlignment = Enum.TextXAlignment.Center
    subLabel.Parent = leftPanel
    
    local divider2 = Instance.new("Frame")
    divider2.Size = UDim2.new(0.8, 0, 0, 1)
    divider2.Position = UDim2.new(0.1, 0, 0, 165)
    divider2.BackgroundColor3 = self.Theme.Border
    divider2.BackgroundTransparency = 0.5
    divider2.BorderSizePixel = 0
    divider2.Parent = leftPanel
    
    -- Nav Buttons
    local navContainer = Instance.new("Frame")
    navContainer.Size = UDim2.new(0.85, 0, 0, 200)
    navContainer.Position = UDim2.new(0.075, 0, 0, 180)
    navContainer.BackgroundTransparency = 1
    navContainer.Parent = leftPanel
    
    -- Right Panel
    local rightPanel = Instance.new("Frame")
    rightPanel.Size = UDim2.new(0, RIGHT_WIDTH, 1, 0)
    rightPanel.Position = UDim2.new(0, LEFT_WIDTH + 10, 0, 0)
    rightPanel.BackgroundTransparency = 1
    rightPanel.Parent = main
    
    local contentContainer = Instance.new("ScrollingFrame")
    contentContainer.Size = UDim2.new(1, -20, 1, -20)
    contentContainer.Position = UDim2.new(0, 10, 0, 10)
    contentContainer.BackgroundTransparency = 1
    contentContainer.BorderSizePixel = 0
    contentContainer.ScrollBarThickness = 3
    contentContainer.ScrollBarImageColor3 = self.Theme.Accent
    contentContainer.Parent = rightPanel
    
    -- Tab System
    local navButtons = {}
    local selectedTab = nil
    local tabContent = {}
    
    local tabData = {
        {name = "Home", icon = "home"},
        {name = "Scripts", icon = "scripts"},
        {name = "Visuals", icon = "visuals"},
        {name = "Stats", icon = "stats"},
        {name = "Aim", icon = "aim"},
        {name = "Combat", icon = "combat"},
        {name = "Settings", icon = "settings"},
    }
    
    for i, data in ipairs(tabData) do
        local row = math.floor((i-1) / 2)
        local col = (i-1) % 2
        
        local btn = Instance.new("TextButton")
        btn.Name = data.name
        btn.Size = UDim2.new(0.42, 0, 0, 45)
        btn.Position = UDim2.new(0.04 + col * 0.52, 0, row * 55 + 5, 0)
        btn.BackgroundColor3 = self.Theme.Surface
        btn.BackgroundTransparency = 0.7
        btn.BorderSizePixel = 0
        btn.Text = ""
        btn.AutoButtonColor = false
        btn.Parent = navContainer
        
        Utilities:Corner(btn, 10)
        
        local icon = self:CreateIcon(data.icon, UDim2.fromOffset(20, 20), self.Theme.TextDim)
        icon.Position = UDim2.new(0.15, 0, 0.5, -10)
        icon.Parent = btn
        
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0.5, 0, 1, 0)
        label.Position = UDim2.new(0.4, 0, 0, 0)
        label.BackgroundTransparency = 1
        label.Text = data.name
        label.TextColor3 = self.Theme.TextDim
        label.FontFace = self.Font
        label.TextSize = 11
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = btn
        
        local indicator = Instance.new("Frame")
        indicator.Size = UDim2.new(0, 3, 1, -8)
        indicator.Position = UDim2.new(0, 0, 0, 4)
        indicator.BackgroundColor3 = self.Theme.Accent
        indicator.BackgroundTransparency = 0.7
        indicator.BorderSizePixel = 0
        indicator.Parent = btn
        
        Utilities:Corner(indicator, 2)
        
        local content = Instance.new("Frame")
        content.Size = UDim2.new(1, 0, 1, 0)
        content.BackgroundTransparency = 1
        content.Visible = false
        content.Parent = contentContainer
        
        tabContent[data.name] = content
        
        btn.MouseEnter:Connect(function()
            if selectedTab ~= data.name then
                Utilities:Tween(btn, {BackgroundTransparency = 0.5}, 0.15)
                local img = icon:FindFirstChildWhichIsA("ImageLabel")
                if img then Utilities:Tween(img, {ImageColor3 = self.Theme.Text}, 0.15) end
                Utilities:Tween(label, {TextColor3 = self.Theme.Text}, 0.15)
            end
        end)
        
        btn.MouseLeave:Connect(function()
            if selectedTab ~= data.name then
                Utilities:Tween(btn, {BackgroundTransparency = 0.7}, 0.15)
                local img = icon:FindFirstChildWhichIsA("ImageLabel")
                if img then Utilities:Tween(img, {ImageColor3 = self.Theme.TextDim}, 0.15) end
                Utilities:Tween(label, {TextColor3 = self.Theme.TextDim}, 0.15)
            end
        end)
        
        btn.MouseButton1Click:Connect(function()
            for _, v in pairs(navContainer:GetChildren()) do
                if v:IsA("TextButton") then
                    local ind = v:FindFirstChildWhichIsA("Frame")
                    if ind then
                        Utilities:Tween(ind, {BackgroundTransparency = 0.7}, 0.2)
                    end
                end
            end
            
            for name, frame in pairs(tabContent) do
                frame.Visible = (name == data.name)
            end
            
            Utilities:Tween(indicator, {BackgroundTransparency = 0}, 0.2)
            selectedTab = data.name
        end)
        
        if i == 1 then
            for name, frame in pairs(tabContent) do
                frame.Visible = (name == data.name)
            end
            Utilities:Tween(indicator, {BackgroundTransparency = 0}, 0.2)
            selectedTab = data.name
        end
        
        navButtons[data.name] = btn
    end
    
    -- Tab Builder
    function window:Tab(name)
        local content = tabContent[name]
        if not content then
            content = Instance.new("Frame")
            content.Size = UDim2.new(1, 0, 1, 0)
            content.BackgroundTransparency = 1
            content.Visible = false
            content.Parent = contentContainer
            tabContent[name] = content
        end
        
        return {
            Content = content,
            Section = function(config) return self:CreateSection(content, config) end,
            Toggle = function(config) return self:CreateToggle(content, config) end,
            Slider = function(config) return self:CreateSlider(content, config) end,
            Dropdown = function(config) return self:CreateDropdown(content, config) end,
            Button = function(config) return self:CreateButton(content, config) end,
            Label = function(config) return self:CreateLabel(content, config) end,
            ColorPicker = function(config) return self:CreateColorPicker(content, config) end,
            Keybind = function(config) return self:CreateKeybind(content, config) end,
            TextInput = function(config) return self:CreateTextInput(content, config) end,
            Paragraph = function(config) return self:CreateParagraph(content, config) end,
        }
    end
    
    -- Window management
    Utilities:MakeDraggable(main)
    Utilities:MakeResizeable(main, Vector2.new(400, 300))
    
    function window:Toggle()
        window.IsOpen = not window.IsOpen
        if window.IsOpen then
            main.Visible = true
            Utilities:Tween(main, {BackgroundTransparency = 0.05}, 0.3)
            Utilities:Tween(UIScale, {Scale = 1}, 0.3, Enum.EasingStyle.Back)
        else
            Utilities:Tween(UIScale, {Scale = 0}, 0.2, Enum.EasingStyle.Quad)
            Utilities:Tween(main, {BackgroundTransparency = 1}, 0.2)
            task.wait(0.2)
            main.Visible = false
        end
        
        -- Обновляем видимость плавающей кнопки
        if self._floatingButton then
            self._floatingButton.Visible = not window.IsOpen
        end
    end
    
    function window:Open()
        if not window.IsOpen then window:Toggle() end
    end
    
    function window:Close()
        if window.IsOpen then window:Toggle() end
    end
    
    -- Keybind
    self:Connect(Services.UserInput.InputBegan, function(input)
        if input.KeyCode == window.Keybind then
            window:Toggle()
        end
    end)
    
    table.insert(self.Windows, window)
    
    return window
end

