-- SPEEDHACK
-- ═══════════════════════════════════════════════════════════════════════

local SpeedHack = {
    enabled = false,
    speed = 2.0,
    connections = {},
}

function SpeedHack:Toggle(state)
    self.enabled = state
    if state then
        self:Enable()
    else
        self:Disable()
    end
end

function SpeedHack:SetSpeed(speed)
    self.speed = math.max(0.5, math.min(10, speed))
    if self.enabled then
        self:ApplySpeed()
    end
end

function SpeedHack:Enable()
    if self.enabled then return end
    self.enabled = true
    self:ApplySpeed()
    
    local conn = RunService.Heartbeat:Connect(function()
        if self.enabled then self:ApplySpeed() end
    end)
    table.insert(self.connections, conn)
end

function SpeedHack:Disable()
    if not self.enabled then return end
    self.enabled = false
    for _, conn in ipairs(self.connections) do
        conn:Disconnect()
    end
    self.connections = {}
    
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = 16 end
    end
end

function SpeedHack:ApplySpeed()
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = 16 * self.speed end
    end
end

