            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            ScrollBarThickness = 2,
            ScrollBarImageColor3 = Theme.Outline,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
        })

        Library:Create("UIListLayout", {
            Parent = MenuList.Instance,
            Padding = UDim.new(0, 2),
            SortOrder = Enum.SortOrder.LayoutOrder,
        })

        Library:Create("UIPadding", {
            Parent = MenuList.Instance,
            PaddingTop = UDim.new(0, 4),
            PaddingBottom = UDim.new(0, 4),
            PaddingLeft = UDim.new(0, 4),
            PaddingRight = UDim.new(0, 4),
        })

        local Options = {}

        function Element:UpdateMenu()
            for _, Child in pairs(MenuList.Instance:GetChildren()) do
                if Child:IsA("TextButton") then
                    Child:Destroy()
                end
            end
            Options = {}

            for _, Item in pairs(Element.Items) do
                local Option = Library:Create("TextButton", {
                    Parent = MenuList.Instance,
                    Size = UDim2.new(1, 0, 0, 30),
                    BackgroundColor3 = Theme.Background2,
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Text = Item,
                    TextColor3 = Theme.TextDim,
                    FontFace = Library.Font,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                })

                Library:Create("UICorner", {
                    Parent = Option.Instance,
                    CornerRadius = UDim.new(0, 4),
                })

                Library:Create("UIPadding", {
                    Parent = Option.Instance,
                    PaddingLeft = UDim.new(0, 10),
                })

                local Check = Library:Create("ImageLabel", {
                    Parent = Option.Instance,
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, -8, 0.5, 0),
                    Size = UDim2.new(0, 14, 0, 14),
                    BackgroundTransparency = 1,
                    Image = Icons.check,
                    ImageColor3 = Theme.Accent1,
                    ImageTransparency = 1,
                })

                Option.Instance.MouseEnter:Connect(function()
                    Option.Instance.BackgroundColor3 = Theme.ElementHover
                    Option.Instance.BackgroundTransparency = 0
                end)

                Option.Instance.MouseLeave:Connect(function()
                    Option.Instance.BackgroundColor3 = Theme.Background2
                    Option.Instance.BackgroundTransparency = 1
                end)

                Option.Instance.MouseButton1Click:Connect(function()
                    if Element.Multi then
                        local Index = table.find(Element.Value, Item)
                        if Index then
                            table.remove(Element.Value, Index)
                            Check.ImageTransparency = 1
                        else
                            table.insert(Element.Value, Item)
                            Check.ImageTransparency = 0
                        end
                    else
                        Element.Value = {Item}
                        for _, Opt in pairs(Options) do
                            Opt.Check.ImageTransparency = 1
                        end
                        Check.ImageTransparency = 0
                        Element:CloseMenu()
                    end

                    Element:UpdateDisplay()
                    Library.SafeCall(Element.Callback, Element.Multi and Element.Value or Element.Value[1])
                end)

                table.insert(Options, {
                    Instance = Option,
                    Check = Check,
                    Item = Item,
                })
            end

            for _, Opt in pairs(Options) do
                if table.find(Element.Value, Opt.Item) then
                    Opt.Check.ImageTransparency = 0
                end
            end
        end

        function Element:UpdateDisplay()
            if #Element.Value == 0 then
                Display.Text = "Select..."
            elseif Element.Multi then
                Display.Text = table.concat(Element.Value, ", ")
            else
                Display.Text = Element.Value[1] or "Select..."
            end
        end

        function Element:OpenMenu()
            Element.IsOpen = true
            local Pos = Display.Instance.AbsolutePosition
            Menu.Instance.Position = UDim2.new(0, Pos.X, 0, Pos.Y + Display.Instance.AbsoluteSize.Y + 4)
            Menu.Instance.Size = UDim2.new(0, Display.Instance.AbsoluteSize.X, 0, 0)
            Menu.Instance.Visible = true
            Menu.Instance.Size = UDim2.new(0, Display.Instance.AbsoluteSize.X, 0, math.min(MenuList.Instance.AbsoluteContentSize.Y + 8, 200))
            Arrow.Rotation = 180
        end

        function Element:CloseMenu()
            Element.IsOpen = false
            Menu.Instance.Size = UDim2.new(0, Display.Instance.AbsoluteSize.X, 0, 0)
            Menu.Instance.Visible = false
            Arrow.Rotation = 0
        end

        function Element:ToggleMenu()
            if Element.IsOpen then
                Element:CloseMenu()
            else
                Element:OpenMenu()
            end
        end

        Display.Instance.MouseButton1Click:Connect(function()
            Element:ToggleMenu()
        end)

        Library:Connect(UserInputService.InputBegan, function(Input)
            if Element.IsOpen and (Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch) then
                if not Library:IsMouseOver(Menu.Instance) and not Library:IsMouseOver(Display.Instance) then
                    Element:CloseMenu()
                end
            end
        end)

        Element:UpdateMenu()

        if Element.Default then
            if Element.Multi and type(Element.Default) == "table" then
                Element.Value = Element.Default
            elseif not Element.Multi then
                Element.Value = {Element.Default}
            end
            Element:UpdateDisplay()
        end

        Element.Instance = Container.Instance
        Library.Elements[Element.Flag] = Element
        Library.ConfigFlags[Element.Flag] = function(Value)
            if Element.Multi then
                Element.Value = Value or {}
            else
                Element.Value = {Value}
            end
            Element:UpdateDisplay()
            Element:UpdateMenu()
            Library.SafeCall(Element.Callback, Element.Multi and Element.Value or Element.Value[1])
        end

        return Element
    end

