        box.Position = UDim2.new(0, 0, 0, 22)
        box.BackgroundColor3 = VoltageUI.Theme.Element
        box.Text = default
        box.PlaceholderText = placeholder
        box.TextColor3 = VoltageUI.Theme.Text
        box.PlaceholderColor3 = VoltageUI.Theme.SubText
        box.TextSize = 15
        box.Font = Enum.Font.Gotham
        box.TextXAlignment = Enum.TextXAlignment.Left
        box.ZIndex = 12
        box.Parent = frame
        corner(box, 6)
        pad(box, 8)

        box.FocusLost:Connect(function()
            VoltageUI.Flags[flag] = box.Text
            callback(box.Text)
        end)

        local obj = { Set = function(t) box.Text = t; callback(t) end,
                      Get = function() return box.Text end }
        VoltageUI.Config[flag] = obj
        return obj
    end

    function sectionObj:Label(config)
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 24)
        frame.BackgroundTransparency = 1
        frame.ZIndex = 11
        frame.Parent = content

        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = config.text or "Label"
        lbl.TextColor3 = VoltageUI.Theme.SubText
        lbl.TextSize = 13
        lbl.Font = Enum.Font.Gotham
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.ZIndex = 12
        lbl.Parent = frame

        return { Set = function(t) lbl.Text = t end }
    end

    return sectionObj
end

