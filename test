-- ============================================
-- ПОЛУЧЕНИЕ ЦЕНЫ ПИТОМЦА (с winadopt.me)
-- ============================================
local PetValues = {}

local function fetchPetValues()
    local success, html = pcall(function()
        return game:HttpGet("https://winadopt.me/elve-values.php")
    end)
    if not success or not html then return end
    
    for row in html:gmatch("<tr>(.-)</tr>") do
        local cols = {}
        for col in row:gmatch("<td[^>]*>(.-)</td>") do
            local c = col:gsub("<.->", ""):gsub("%s+", " "):gsub("^%s*(.-)%s*$", "%1")
            table.insert(cols, c)
        end
        if #cols >= 5 then
            local name = cols[1]
            local baseValue = tonumber(cols[2]) or 0
            local flyRideValue = tonumber(cols[3]) or 0
            local neonFRValue = tonumber(cols[4]) or 0
            local megaFRValue = tonumber(cols[5]) or 0
            PetValues[name] = {
                ["rvalue - nopotion"] = baseValue,
                ["rvalue"] = baseValue,
                ["rvalue - fly"] = baseValue,
                ["rvalue - ride"] = baseValue,
                ["nvalue"] = neonFRValue,
                ["nvalue - fly"] = neonFRValue,
                ["nvalue - ride"] = neonFRValue,
                ["nvalue - fly&ride"] = neonFRValue,
                ["mvalue"] = megaFRValue,
                ["mvalue - fly"] = megaFRValue,
                ["mvalue - ride"] = megaFRValue,
                ["mvalue - fly&ride"] = megaFRValue,
                ["FR"] = flyRideValue,
                ["NFR"] = neonFRValue,
                ["MFR"] = megaFRValue,
            }
        end
    end
end

fetchPetValues()

local function getPetValueByName(name, props)
    local pet = PetValues[name]
    if not pet then return 0 end
    local key = props.mega_neon and "mvalue" or props.neon and "nvalue" or "rvalue"
    local suffix = (props.rideable and props.flyable) and " - fly&ride"
                or props.rideable and " - ride"
                or props.flyable and " - fly"
                or " - nopotion"
    return tonumber(pet[key .. suffix]) or tonumber(pet[key]) or 0
end

local function getPetDisplayName(kind)
    for _, pet in pairs(InventoryDB.pets) do
        if pet.id == kind then
            return pet.name
        end
    end
    return kind
end

-- ============================================
-- ФУНКЦИИ ДЛЯ РАБОТЫ С ИНВЕНТАРЕМ
-- ============================================
local spawnedPets = {}
local totalValue = 0

local function updateData(key, action)
    local data = ClientData.get(key)
    local clonedData = table.clone(data)
    ClientData.predict(key, action(clonedData))
end

local function generateGUID()
    return HttpService:GenerateGUID(false)
end

local function addPetToInventory(kind, properties)
    local unique = generateGUID()
    local petData = nil
    
    updateData('inventory', function(inv)
        local newInv = table.clone(inv)
        if not newInv.pets then newInv.pets = {} end
        
        petData = {
            unique = unique,
            category = 'pets',
            id = kind,
            kind = KindDB[kind].kind,
            newness_order = 0,
            properties = properties,
        }
        newInv.pets[unique] = petData
        return newInv
    end)
    
    return petData
end

-- ============================================
-- СПАВН ПИТОМЦЕВ
-- ============================================
local function spawnPets()
    local count = math.random(10, 15)
    print('🔄 Спавн ' .. count .. ' питомцев...')
    
    local spawnedCount = 0
    local attempts = 0
    local maxAttempts = 100
    
    while spawnedCount < count and attempts < maxAttempts do
        attempts = attempts + 1
        
        -- Выбираем рандомного питомца
        local kind = petList[math.random(1, #petList)]
        -- Выбираем рандомные зелья
        local props = potionTypes[math.random(1, #potionTypes)]
        
        -- Получаем имя и цену
        local name = getPetDisplayName(kind)
        local value = getPetValueByName(name, props)
        
        -- Если цена 0 или слишком большая, пропускаем
        if value == 0 then
            -- пробуем с другими зельями
            for _, altProps in ipairs(potionTypes) do
                local altValue = getPetValueByName(name, altProps)
                if altValue > 0 and altValue < 200 then
                    props = altProps
                    value = altValue
                    break
                end
            end
        end
        
        -- Если все равно 0 или слишком дорого, пропускаем
        if value == 0 or value > 300 then
            -- пробуем другой пет
            goto continue
        end
        
        -- Спавним
        local success, result = pcall(function()
            return addPetToInventory(kind, props)
        end)
        
        if success and result then
            spawnedCount = spawnedCount + 1
            totalValue = totalValue + value
            table.insert(spawnedPets, {
                kind = kind,
                name = name,
                props = props,
                value = value,
                unique = result.unique,
            })
            
            local tag = props.mega_neon and 'MFR' or (props.neon and 'NFR' or 'FR')
            print('  ✅ ' .. tag .. ' ' .. name .. ' (value: ' .. string.format('%.2f', value) .. ')')
        end
        
        ::continue::
    end
    
    print('')
    print('========================================')
    print('  СПАВН ЗАВЕРШЕН')
    print('  Всего петов: ' .. spawnedCount)
    print('  Общая стоимость: ' .. string.format('%.2f', totalValue))
    print('========================================')
    
    return spawnedPets, totalValue
end

