                Label.Parent = Frame
                
                return {
                    Set = function(t) Label.Text = t end,
                }
            end
            
            -- Divider
            function SectionAPI:Divider()
                local Frame = Instance.new("Frame")
                Frame.Size = UDim2.new(1, -20, 0, 1)
                Frame.Position = UDim2.new(0, 10, 0, 4)
                Frame.BackgroundColor3 = Theme.Border
                Frame.BorderSizePixel = 0
                Frame.Parent = SectionContent
            end
            
            return SectionAPI
        end
        
        TabData.CreateSection = createSection
        
        Pages[name] = TabData
        
        if not CurrentTab then
            Voltage:SelectTab(TabData)
        end
        
        return {
            Tab = TabData,
            Section = createSection,
        }
    end
    
    -- ── Select Tab ──
    function Voltage:SelectTab(tab)
        if CurrentTab == tab then return end
        
        if CurrentTab then
            tween(CurrentTab.Button, {BackgroundTransparency = 1})
            tween(CurrentTab.Label, {TextColor3 = Theme.TextDim})
            tween(CurrentTab.Icon, {ImageColor3 = Theme.TextDim})
            tween(CurrentTab.Indicator, {BackgroundTransparency = 1})
            CurrentTab.Content.Visible = false
        end
        
        CurrentTab = tab
        tween(tab.Button, {BackgroundTransparency = 0.85})
        tween(tab.Label, {TextColor3 = Theme.Text})
        tween(tab.Icon, {ImageColor3 = Theme.Voltage})
        tween(tab.Indicator, {BackgroundTransparency = 0})
        tab.Content.Visible = true
        
        TitleText.Text = tab.Name
    end
    
    -- ── SpeedHack Tab ──
    function Voltage:AddSpeedHackTab(config)
        config = config or {}
        local tabName = config.TabName or "Speed"
        local tabIcon = config.TabIcon or SVG.speed
        
        local tab = createTab({Name = tabName, Icon = tabIcon})
        local section = tab:Section({Name = "SpeedHack"})
        
        section:Toggle({
            Name = "Enable SpeedHack",
            Flag = "SpeedHackEnabled",
            Default = false,
            Callback = function(value)
                SpeedHack:Toggle(value)
            end
        })
        
        section:Slider({
            Name = "Speed Multiplier",
            Flag = "SpeedHackMultiplier",
            Min = 0.5,
            Max = 10,
            Default = 2,
            Suffix = "x",
            Decimals = 1,
            Callback = function(value)
                SpeedHack:SetSpeed(value)
            end
        })
        
        section:Label({Text = "Status: Disabled"})
        
        task.spawn(function()
            while true do
                task.wait(0.5)
                for _, child in ipairs(section._content:GetChildren()) do
                    if child:IsA("TextLabel") and child.Text:find("Status:") then
                        child.Text = SpeedHack.enabled and "Status: Enabled (" .. SpeedHack.speed .. "x)" or "Status: Disabled"
                    end
                end
            end
        end)
        
        section:Divider()
        section:Label({Text = "SpeedHack modifies your movement speed"})
        section:Label({Text = "Toggle above to enable/disable"})
        
        return section
    end
    
    -- ── Notifications ──
    local NotificationContainer = Instance.new("Frame")
    NotificationContainer.Size = UDim2.new(0, 320, 1, -40)
    NotificationContainer.Position = UDim2.new(1, -340, 0, 20)
    NotificationContainer.BackgroundTransparency = 1
    NotificationContainer.ZIndex = 1000
    NotificationContainer.Parent = ScreenGui
    
    local NotifLayout = Instance.new("UIListLayout")
    NotifLayout.Padding = UDim.new(0, 8)
    NotifLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right
    NotifLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
    NotifLayout.SortOrder = Enum.SortOrder.LayoutOrder
    NotifLayout.Parent = NotificationContainer
    
    function Voltage:Notify(title, text, duration, type)
        duration = duration or 3
        type = type or "info"
        
        local colors = {
            info = Theme.Voltage,
            success = Theme.Success,
            warning = Theme.Warning,
            error = Theme.Error,
        }
        local accent = colors[type] or Theme.Voltage
        
        local card = Instance.new("Frame")
        card.Size = UDim2.new(1, 0, 0, 54)
        card.BackgroundColor3 = Theme.Surface
        card.BackgroundTransparency = 0.1
        card.Parent = NotificationContainer
        corner(card, 10)
        stroke(card, Theme.Border, 1)
        
        local accentBar = Instance.new("Frame")
        accentBar.Size = UDim2.new(0, 3, 1, -12)
        accentBar.Position = UDim2.new(0, 4, 0.5, 0)
        accentBar.AnchorPoint = Vector2.new(0, 0.5)
        accentBar.BackgroundColor3 = accent
        accentBar.BorderSizePixel = 0
        accentBar.Parent = card
        corner(accentBar, 2)
        
        local titleLabel = Instance.new("TextLabel")
        titleLabel.Size = UDim2.new(1, -20, 0, 20)
        titleLabel.Position = UDim2.new(0, 14, 0, 6)
        titleLabel.BackgroundTransparency = 1
        titleLabel.Font = Enum.Font.GothamBold
        titleLabel.Text = title
        titleLabel.TextColor3 = Theme.Text
        titleLabel.TextSize = 14
        titleLabel.TextXAlignment = Enum.TextXAlignment.Left
        titleLabel.Parent = card
        
        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, -20, 0, 20)
        textLabel.Position = UDim2.new(0, 14, 0, 28)
        textLabel.BackgroundTransparency = 1
        textLabel.Font = Enum.Font.Gotham
        textLabel.Text = text
        textLabel.TextColor3 = Theme.TextDim
        textLabel.TextSize = 12
        textLabel.TextXAlignment = Enum.TextXAlignment.Left
        textLabel.TextWrapped = true
        textLabel.Parent = card
        
        local progress = Instance.new("Frame")
        progress.Size = UDim2.new(1, 0, 0, 2)
        progress.Position = UDim2.new(0, 0, 1, -2)
        progress.BackgroundColor3 = accent
        progress.BorderSizePixel = 0
        progress.Parent = card
        corner(progress, 2)
        
        tween(progress, {Size = UDim2.new(0, 0, 0, 2)}, TweenInfo.new(duration, Enum.EasingStyle.Linear))
        
        task.delay(duration, function()
            tween(card, {BackgroundTransparency = 1}, 0.3)
            tween(card, {Size = UDim2.new(1, 0, 0, 0)}, 0.3)
            task.wait(0.35)
            card:Destroy()
        end)
    end
    
    -- ── Keybind Handler ──
    UserInputService.InputBegan:Connect(function(input)
        if input.KeyCode == keybind then
            local vis = not Main.Visible
            Main.Visible = vis
            if vis then
                tween(UIScale, {Scale = 1}, 0.3)
                tween(Main, {BackgroundTransparency = 0}, 0.3)
            else
                tween(UIScale, {Scale = 0}, 0.3)
                tween(Main, {BackgroundTransparency = 1}, 0.3)
                task.wait(0.35)
                Main.Visible = false
            end
        end
    end)
    
    -- ── API ──
    local windowAPI = {
        ScreenGui = ScreenGui,
        Main = Main,
        Tab = createTab,
        SetTitle = function(text) TitleText.Text = text end,
        Notify = Voltage.Notify,
        SaveConfig = Voltage.SaveConfig,
        LoadConfig = Voltage.LoadConfig,
        AddSpeedHackTab = Voltage.AddSpeedHackTab,
        SpeedHack = SpeedHack,
        Theme = Theme,
        Flags = Flags,
        FlagSetters = FlagSetters,
    }
    
    table.insert(Voltage._windows, windowAPI)
    return windowAPI
end

