    local arrow = Library:CreateIcon("ChevronDown", UDim2.fromOffset(12, 12), Library.Theme.TextDim)
    arrow.AnchorPoint = Vector2.new(1, 0.5)
    arrow.Position = UDim2.new(1, -6, 0.5, 0)
    arrow.Parent = selectBg
    
    local listFrame = Instance.new("ScrollingFrame")
    listFrame.Size = UDim2.new(1, -2, 0, 100)
    listFrame.Position = UDim2.new(0, 1, 0, 38)
    listFrame.BackgroundColor3 = Library.Theme.Surface
    listFrame.BorderSizePixel = 0
    listFrame.Visible = false
    listFrame.ScrollBarThickness = 2
    listFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    listFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    listFrame.Parent = frame.Instance
    Library:Corner(listFrame, 4)
    Library:Stroke(listFrame, Library.Theme.Border)
    
    local listLayout = Instance.new("UIListLayout")
    listLayout.Padding = UDim.new(0, 3)
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder
    listLayout.Parent = listFrame
    
    local function updateSize()
        local total = #options > 0 and math.min(#options * 25 + 6, 120) or 40
        frame.Instance.Size = UDim2.new(1, 0, 0, dropdown.Open and 38 + total or 38)
    end
    
    function dropdown:Add(option)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 22)
        btn.BackgroundColor3 = Library.Theme.Surface
        btn.Text = ""
        btn.AutoButtonColor = false
        btn.Parent = listFrame
        Library:Corner(btn, 3)
        
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, -16, 1, 0)
        lbl.Position = UDim2.new(0, 6, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = option
        lbl.TextColor3 = Library.Theme.TextDim
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 12
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = btn
        
        local check = Library:CreateIcon("Check", UDim2.fromOffset(10, 10), Library.Theme.Accent)
        check.AnchorPoint = Vector2.new(1, 0.5)
        check.Position = UDim2.new(1, -6, 0.5, 0)
        check.ImageTransparency = 1
        check.Parent = btn
        
        btn.MouseEnter:Connect(function()
            Library:Tween(btn, { BackgroundColor3 = Library.Theme.Hover })
        end)
        btn.MouseLeave:Connect(function()
            Library:Tween(btn, { BackgroundColor3 = Library.Theme.Surface })
        end)
        btn.MouseButton1Click:Connect(function()
            if dropdown.Multi then
                local idx = table.find(dropdown.Value, option)
                if idx then
                    table.remove(dropdown.Value, idx)
                    Library:Tween(check, { ImageTransparency = 1 })
                else
                    table.insert(dropdown.Value, option)
                    Library:Tween(check, { ImageTransparency = 0 })
                end
                selectText.Text = #dropdown.Value > 0 and table.concat(dropdown.Value, ", ") or "Select..."
            else
                dropdown.Value = { option }
                for _, opt in pairs(options) do
                    opt.check.ImageTransparency = 1
                end
                Library:Tween(check, { ImageTransparency = 0 })
                selectText.Text = option
                dropdown:SetOpen(false)
                dropdown.Callback(option)
            end
        end)
        
        local data = { btn = btn, lbl = lbl, check = check }
        table.insert(options, data)
        updateSize()
        return data
    end
    
    function dropdown:Set(value)
        if type(value) == "table" then
            dropdown.Value = value
            for _, opt in pairs(options) do
                opt.check.ImageTransparency = table.find(value, opt.lbl.Text) and 0 or 1
            end
            selectText.Text = #value > 0 and table.concat(value, ", ") or "Select..."
        else
            dropdown.Value = { value }
            for _, opt in pairs(options) do
                opt.check.ImageTransparency = opt.lbl.Text == value and 0 or 1
            end
            selectText.Text = value or "Select..."
        end
        dropdown.Callback(dropdown.Value)
    end
    
    function dropdown:Refresh(items)
        for _, opt in pairs(options) do
            opt.btn:Destroy()
        end
        options = {}
        for _, item in ipairs(items or {}) do
            dropdown:Add(item)
        end
        updateSize()
    end
    
    function dropdown:SetOpen(open)
        dropdown.Open = open
        listFrame.Visible = open
        Library:Tween(arrow, { Rotation = open and 180 or 0 })
        updateSize()
    end
    
    function dropdown:SetText(text)
        dropdown.Name = text
        text.Text = text
    end
    
    function dropdown:SetVisible(visible)
        frame.Instance.Visible = visible
    end
    
    selectBg.MouseButton1Click:Connect(function()
        dropdown:SetOpen(not dropdown.Open)
    end)
    
    UserInputService.InputBegan:Connect(function(input)
        if dropdown.Open and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            if not frame.Instance:IsDescendantOf(frame.Instance) then return end
            local pos = Mouse.X
            local abs = frame.Instance.AbsolutePosition.X
            local size = frame.Instance.AbsoluteSize.X
            if pos < abs or pos > abs + size then
                dropdown:SetOpen(false)
            end
        end
    end)
    
    for _, item in ipairs(dropdown.Items) do
        dropdown:Add(item)
    end
    
    if dropdown.Default then
        dropdown:Set(dropdown.Default)
    end
    
    Library.ConfigFlags[dropdown.Flag] = dropdown.Set
    
    return dropdown
end

