            BorderSizePixel = 0,
            Text = Element.Default,
            TextColor3 = Theme.Text,
            FontFace = Library.Font,
            TextSize = 14,
            PlaceholderText = Element.Placeholder,
            PlaceholderColor3 = Theme.TextDark,
            TextXAlignment = Enum.TextXAlignment.Left,
            ClearTextOnFocus = false,
        })

        Library:Create("UICorner", {
            Parent = Input.Instance,
            CornerRadius = UDim.new(0, 6),
        })

        Library:Create("UIPadding", {
            Parent = Input.Instance,
            PaddingLeft = UDim.new(0, 12),
        })

        Input.Instance:GetPropertyChangedSignal("Text"):Connect(function()
            local Value = Input.Text
            if Element.Numeric and Value ~= "" then
                if not tonumber(Value) then
                    Input.Text = Element.Value or ""
                    return
                end
            end
            Element.Value = Value
            Library.Flags[Element.Flag] = Value
            Library.SafeCall(Element.Callback, Value)
        end)

        Input.Instance.FocusLost:Connect(function()
            if Element.Numeric and Input.Text ~= "" then
                Input.Text = tostring(tonumber(Input.Text))
            end
        end)

        Element.Instance = Container.Instance
        Library.Elements[Element.Flag] = Element
        Library.ConfigFlags[Element.Flag] = function(Value)
            Input.Text = tostring(Value)
        end

        return Element
    end

