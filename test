                local List = Instance.new("ScrollingFrame")
                List.Size = UDim2.new(1, -4, 0, 0)
                List.Position = UDim2.new(0, 2, 0, 4)
                List.BackgroundColor3 = Theme.Surface
                List.BorderSizePixel = 0
                List.ScrollBarThickness = 2
                List.AutomaticCanvasSize = Enum.AutomaticSize.Y
                List.CanvasSize = UDim2.new(0, 0, 0, 0)
                List.Visible = false
                List.ClipsDescendants = true
                List.Parent = DropdownBtn
                registerTheme(List, "BackgroundColor3", "Surface")
                registerTheme(List, "ScrollBarImageColor3", "VoltageDim")
                corner(List, 8)
                stroke(List, Theme.Border, 1, 0.5)
                
                local ListLayout = Instance.new("UIListLayout")
                ListLayout.Padding = UDim.new(0, 2)
                ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
                ListLayout.Parent = List
                
                local isOpen = false
                local selected = default
                local selectedMulti = {}
                
                local function closeList()
                    isOpen = false
                    tween(Arrow, {Rotation = 0}, 0.15)
                    tween(DropdownBtn, {Size = UDim2.new(1, 0, 0, 36)}, 0.15)
                    task.wait(0.15)
                    List.Visible = false
                    List.Size = UDim2.new(1, -4, 0, 0)
                end
                
                local function openList()
                    isOpen = true
                    List.Visible = true
                    tween(Arrow, {Rotation = 180}, 0.15)
                    local height = clamp(#items * 28 + 8, 0, 150)
                    List.Size = UDim2.new(1, -4, 0, height)
                    tween(DropdownBtn, {Size = UDim2.new(1, 0, 0, 36 + height + 4)}, 0.15)
                end
                
                local function selectItem(item, fire)
                    if multi then
                        if selectedMulti[item] then
                            selectedMulti[item] = nil
                        else
                            selectedMulti[item] = true
                        end
                        local list = {}
                        for k, v in pairs(selectedMulti) do
                            if v then table.insert(list, k) end
                        end
                        ValueLabel.Text = #list > 0 and table.concat(list, ", ") or "None"
                        Flags[flag] = list
                        if fire then pcall(callback, list) end
                    else
                        selected = item
                        ValueLabel.Text = tostring(item)
                        Flags[flag] = item
                        if fire then pcall(callback, item) end
                        closeList()
                    end
                end
                
                -- Build items
                local itemButtons = {}
                for _, item in ipairs(items) do
                    local itemFrame = Instance.new("TextButton")
                    itemFrame.Size = UDim2.new(1, -8, 0, 28)
                    itemFrame.Position = UDim2.new(0, 4, 0, 0)
                    itemFrame.BackgroundTransparency = 1
                    itemFrame.Text = ""
                    itemFrame.AutoButtonColor = false
                    itemFrame.Parent = List
                    
                    local itemLabel = Instance.new("TextLabel")
                    itemLabel.Size = UDim2.new(1, -20, 1, 0)
                    itemLabel.Position = UDim2.new(0, 12, 0, 0)
                    itemLabel.BackgroundTransparency = 1
                    itemLabel.Font = Enum.Font.Gotham
                    itemLabel.Text = tostring(item)
                    itemLabel.TextColor3 = Theme.TextDim
                    itemLabel.TextSize = 13
                    itemLabel.TextXAlignment = Enum.TextXAlignment.Left
                    itemLabel.Parent = itemFrame
                    registerTheme(itemLabel, "TextColor3", "TextDim")
                    
                    local check = makeIcon(itemFrame, SVG.check, UDim2.fromOffset(12, 12), Theme.Voltage)
                    check.Position = UDim2.new(1, -18, 0.5, -6)
                    check.ImageTransparency = 1
                    
                    itemFrame.MouseEnter:Connect(function()
                        tween(itemFrame, {BackgroundTransparency = 0.85})
                        tween(itemLabel, {TextColor3 = Theme.Text})
                    end)
                    itemFrame.MouseLeave:Connect(function()
                        tween(itemFrame, {BackgroundTransparency = 1})
                        tween(itemLabel, {TextColor3 = Theme.TextDim})
                    end)
                    itemFrame.MouseButton1Click:Connect(function()
                        selectItem(item, true)
                    end)
                    
                    itemButtons[item] = {frame = itemFrame, label = itemLabel, check = check}
                end
                
                DropdownBtn.MouseButton1Click:Connect(function()
                    if isOpen then
                        closeList()
                    else
                        openList()
                    end
                end)
                
                UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        if isOpen then
                            local pos = input.Position
                            local abs = DropdownBtn.AbsolutePosition
                            local size = DropdownBtn.AbsoluteSize
                            if pos.X < abs.X or pos.X > abs.X + size.X or pos.Y < abs.Y or pos.Y > abs.Y + size.Y then
                                closeList()
                            end
                        end
                    end
                end)
                
                if multi then
                    if type(default) == "table" then
                        for _, v in ipairs(default) do
                            selectedMulti[v] = true
                        end
                        local list = {}
                        for k, v in pairs(selectedMulti) do
                            if v then table.insert(list, k) end
                        end
                        ValueLabel.Text = #list > 0 and table.concat(list, ", ") or "None"
                    end
                else
                    selectItem(default, false)
                end
                
                FlagSetters[flag] = function(v)
                    if multi then
                        selectedMulti = {}
                        if type(v) == "table" then
                            for _, item in ipairs(v) do
                                selectedMulti[item] = true
                            end
                        end
                        local list = {}
                        for k, v2 in pairs(selectedMulti) do
                            if v2 then table.insert(list, k) end
                        end
                        ValueLabel.Text = #list > 0 and table.concat(list, ", ") or "None"
                        Flags[flag] = list
                        pcall(callback, list)
                    else
                        selectItem(v, true)
                    end
                end
                
                return {
                    Set = function(v)
                        if multi then
                            selectedMulti = {}
                            if type(v) == "table" then
                                for _, item in ipairs(v) do
                                    selectedMulti[item] = true
                                end
                            end
                            local list = {}
                            for k, v2 in pairs(selectedMulti) do
                                if v2 then table.insert(list, k) end
                            end
                            ValueLabel.Text = #list > 0 and table.concat(list, ", ") or "None"
                            Flags[flag] = list
                            pcall(callback, list)
                        else
                            selectItem(v, true)
                        end
                    end,
                    Get = function()
                        if multi then
                            local list = {}
                            for k, v in pairs(selectedMulti) do
                                if v then table.insert(list, k) end
                            end
                            return list
                        end
                        return selected
                    end,
                    Refresh = function(newItems)
                        for _, btn in pairs(itemButtons) do
                            btn.frame:Destroy()
                        end
                        itemButtons = {}
                        items = newItems or {}
                        for _, item in ipairs(items) do
                            local itemFrame = Instance.new("TextButton")
                            itemFrame.Size = UDim2.new(1, -8, 0, 28)
                            itemFrame.Position = UDim2.new(0, 4, 0, 0)
                            itemFrame.BackgroundTransparency = 1
                            itemFrame.Text = ""
                            itemFrame.AutoButtonColor = false
                            itemFrame.Parent = List
                            
                            local itemLabel = Instance.new("TextLabel")
                            itemLabel.Size = UDim2.new(1, -20, 1, 0)
                            itemLabel.Position = UDim2.new(0, 12, 0, 0)
                            itemLabel.BackgroundTransparency = 1
                            itemLabel.Font = Enum.Font.Gotham
                            itemLabel.Text = tostring(item)
                            itemLabel.TextColor3 = Theme.TextDim
                            itemLabel.TextSize = 13
                            itemLabel.TextXAlignment = Enum.TextXAlignment.Left
                            itemLabel.Parent = itemFrame
                            registerTheme(itemLabel, "TextColor3", "TextDim")
                            
                            local check = makeIcon(itemFrame, SVG.check, UDim2.fromOffset(12, 12), Theme.Voltage)
                            check.Position = UDim2.new(1, -18, 0.5, -6)
                            check.ImageTransparency = 1
                            
                            itemFrame.MouseEnter:Connect(function()
                                tween(itemFrame, {BackgroundTransparency = 0.85})
                                tween(itemLabel, {TextColor3 = Theme.Text})
                            end)
                            itemFrame.MouseLeave:Connect(function()
                                tween(itemFrame, {BackgroundTransparency = 1})
                                tween(itemLabel, {TextColor3 = Theme.TextDim})
                            end)
                            itemFrame.MouseButton1Click:Connect(function()
                                selectItem(item, true)
                            end)
                            
