-- UTILITY FUNCTIONS
-- ═══════════════════════════════════════════════════════════════════════

function Library:Create(class, properties)
    local obj = Instance.new(class)
    for prop, val in pairs(properties or {}) do
        obj[prop] = val
    end
    if class == "TextButton" then
        obj.AutoButtonColor = false
        obj.Text = ""
    end
    return setmetatable({ Instance = obj }, Library)
end

function Library:Corner(obj, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = obj.Instance or obj
    return c
end

function Library:Stroke(obj, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or self.Theme.Border
    s.Thickness = thickness or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = obj.Instance or obj
    return s
end

function Library:Tween(obj, properties, time, style, direction)
    local target = obj.Instance or obj
    local info = TweenInfo.new(time or self.TweenTime, style or self.TweenStyle, direction or self.TweenDirection)
    local tween = TweenService:Create(target, info, properties)
    tween:Play()
    return tween
end

function Library:Connect(event, callback)
    local conn = event:Connect(callback)
    table.insert(self.Connections, conn)
    return conn
end

function Library:Thread(func)
    local thread = coroutine.create(func)
    coroutine.resume(thread)
    table.insert(self.Threads, thread)
    return thread
end

function Library:SafeCall(func, ...)
    local args = {...}
    local success, result = pcall(func, unpack(args))
    if not success then warn(result) end
    return success, result
end

function Library:Round(num, decimals)
    local mult = 10 ^ (decimals or 0)
    return math.floor(num * mult + 0.5) / mult
end

function Library:Clamp(num, min, max)
    return math.max(min, math.min(max, num))
end

function Library:Lerp(a, b, t)
    return a + (b - a) * t
end

