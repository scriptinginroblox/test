-- OfferItem
if Remotes.OfferItem then
    Remotes.OfferItem.FireServer = function(self, itemId, itemType)
        if mockState.active and mockState.trade then
            if mockState.trade.current_stage == "completed" then
                return
            end
            
            local itemData = nil
            for _, data in ipairs(ItemDatabase) do
                if data.name == itemId then
                    itemData = data
                    break
                end
            end
            
            local item = {
                id = itemId,
                name = itemId,
                type = itemType or "Weapons",
                amount = 1,
                icon = itemData and itemData.icon or "2005276185",
                rarity = itemData and itemData.rarity or "Unknown",
            }
            
            table.insert(mockState.trade.sender_offer.items, item)
            mockState.trade.offer_version = mockState.trade.offer_version + 1
            updateTradeUI()
            return
        end
        return originals.OfferItem and originals.OfferItem(self, itemId, itemType)
    end
end

-- RemoveOffer
if Remotes.RemoveOffer then
    Remotes.RemoveOffer.FireServer = function(self, itemId)
        if mockState.active and mockState.trade then
            for i, item in ipairs(mockState.trade.sender_offer.items) do
                if item.id == itemId then
                    table.remove(mockState.trade.sender_offer.items, i)
                    mockState.trade.offer_version = mockState.trade.offer_version + 1
                    updateTradeUI()
                    return
                end
            end
            return
        end
        return originals.RemoveOffer and originals.RemoveOffer(self, itemId)
    end
end

-- EndTrade
if Remotes.EndTrade then
    Remotes.EndTrade.FireServer = function(self)
        if mockState.active and mockState.trade then
            mockState.active = false
            mockState.trade = nil
            updateTradeUI()
            return
        end
        return originals.EndTrade and originals.EndTrade(self)
    end
end

-- UpdateTrade
if Remotes.UpdateTrade then
    Remotes.UpdateTrade.FireServer = function(self, data)
        if mockState.active and mockState.trade then
            if data then
                if data.sender_offer then
                    mockState.trade.sender_offer.items = data.sender_offer.items or {}
                end
                if data.recipient_offer then
                    mockState.trade.recipient_offer.items = data.recipient_offer.items or {}
                end
                if data.current_stage then
                    mockState.trade.current_stage = data.current_stage
                end
                mockState.trade.offer_version = mockState.trade.offer_version + 1
                updateTradeUI()
            end
            return
        end
        return originals.UpdateTrade and originals.UpdateTrade(self, data)
    end
end

-- CancelAccept
if Remotes.CancelAccept then
    Remotes.CancelAccept.FireServer = function(self)
        if mockState.active and mockState.trade then
            mockState.trade.sender_offer.confirmed = false
            mockState.trade.offer_version = mockState.trade.offer_version + 1
            updateTradeUI()
            return
        end
        return originals.CancelAccept and originals.CancelAccept(self)
    end
end

-- ============================================
-- АВТОДЕЙСТВИЯ ПАРТНЁРА
-- ============================================
local function partnerAutoAction()
    if not mockState.active or not mockState.trade or mockState.partnerActionPending then
        return
    end
    
    mockState.partnerActionPending = true
    
    if mockState.trade.current_stage == "negotiation" then
        task.wait(CONFIG.AUTO_ACCEPT_DELAY)
        
        if mockState.active and mockState.trade then
            mockState.trade.recipient_offer.negotiated = true
            mockState.trade.offer_version = mockState.trade.offer_version + 1
            
            if mockState.trade.sender_offer.negotiated then
                mockState.trade.current_stage = "confirmation"
                mockState.trade.offer_version = mockState.trade.offer_version + 1
                updateTradeUI()
            end
            updateTradeUI()
        end
        
    elseif mockState.trade.current_stage == "confirmation" then
        task.wait(CONFIG.AUTO_CONFIRM_DELAY)
        
        if mockState.active and mockState.trade then
            mockState.trade.recipient_offer.confirmed = true
            mockState.trade.offer_version = mockState.trade.offer_version + 1
            
            if mockState.trade.sender_offer.confirmed then
                mockState.trade.current_stage = "completed"
                mockState.trade.offer_version = mockState.trade.offer_version + 1
                updateTradeUI()
            end
            updateTradeUI()
        end
    end
    
    mockState.partnerActionPending = false
end

-- ============================================
-- ЗАПУСК ФЕЙКОВОГО ТРЕЙДА
-- ============================================
local function startMockTrade()
    if mockState.active then return end
    
    mockState.trade = createMockTrade()
    mockState.active = true
    
    local gui = getTradeGUI()
    if gui then
        gui.Enabled = true
        gui.Visible = true
    end
    
    updateTradeUI()
    task.spawn(partnerAutoAction)
    
    print("[MM2 Fake Trade] Started! Partner: " .. CONFIG.PARTNER_NAME)
end

