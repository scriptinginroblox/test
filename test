                        local pos = input.Position
                        local abs = HueBar.AbsolutePosition
                        local size = HueBar.AbsoluteSize
                        hue = clamp((pos.X - abs.X) / size.X, 0, 1)
                        updateColor()
                    end
                end)
                
                local alphaDragging = false
                AlphaBar.InputBegan:Connect(function(input)
