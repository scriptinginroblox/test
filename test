local function getRandomPlayerFromServer()
    local players = Players:GetPlayers()
    local filtered = {}
    
    for _, player in ipairs(players) do
        if player ~= LocalPlayer and not fakePlayerIds[player.UserId] then
            table.insert(filtered, player)
