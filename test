        Callback = function(color)
            Library:Theme.Accent = color
            Library:RefreshTheme("Accent", color)
        end
    })
    
    local uiSection = page:Section({ Name = "UI Settings" })
    
    uiSection:Keybind({
        Name = "Menu Keybind",
        Default = Enum.KeyCode.RightShift,
        Callback = function()
            window.Keybind = Library.Flags["MenuKeybind"] and Library.Flags["MenuKeybind"].Key or Enum.KeyCode.RightShift
        end,
        Flag = "MenuKeybind"
    })
    
    local watermarkToggle = uiSection:Toggle({
