        dot.BorderSizePixel = 0
        dot.Parent = palette
        Library:Corner(dot, 4)
        Library:Stroke(dot, Color3.new(0, 0, 0), 1, 0.3)
        
        local hueBar = Instance.new("Frame")
        hueBar.Size = UDim2.new(1, -20, 0, 12)
        hueBar.Position = UDim2.new(0, 10, 0, 118)
        hueBar.BorderSizePixel = 0
        hueBar.Parent = picker
        Library:Corner(hueBar, 4)
        
        local hueGrad = Instance.new("UIGradient")
        hueGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
            ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
            ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
            ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
            ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0)),
        })
        hueGrad.Parent = hueBar
        
        local hueDot = Instance.new("Frame")
        hueDot.AnchorPoint = Vector2.new(0.5, 0.5)
        hueDot.Size = UDim2.new(0, 6, 1, 4)
        hueDot.Position = UDim2.new(h, 0, 0.5, 0)
        hueDot.BackgroundColor3 = Color3.new(1, 1, 1)
        hueDot.BorderSizePixel = 0
        hueDot.Parent = hueBar
        Library:Corner(hueDot, 3)
        Library:Stroke(hueDot, Color3.new(0, 0, 0), 1, 0.3)
        
        local alphaBar = Instance.new("Frame")
        alphaBar.Size = UDim2.new(1, -20, 0, 10)
        alphaBar.Position = UDim2.new(0, 10, 0, 136)
        alphaBar.BackgroundColor3 = Color3.fromHSV(h, s, v)
        alphaBar.BorderSizePixel = 0
        alphaBar.Parent = picker
        Library:Corner(alphaBar, 4)
        Library:Stroke(alphaBar, Library.Theme.Border)
        
        local alphaDot = Instance.new("Frame")
        alphaDot.AnchorPoint = Vector2.new(0.5, 0.5)
        alphaDot.Size = UDim2.new(0, 6, 1, 4)
        alphaDot.Position = UDim2.new(1 - colorpicker.Alpha, 0, 0.5, 0)
        alphaDot.BackgroundColor3 = Color3.new(1, 1, 1)
        alphaDot.BorderSizePixel = 0
        alphaDot.Parent = alphaBar
        Library:Corner(alphaDot, 3)
        Library:Stroke(alphaDot, Color3.new(0, 0, 0), 1, 0.3)
        
        local hexInput = Instance.new("TextBox")
        hexInput.Size = UDim2.new(1, -20, 0, 18)
        hexInput.Position = UDim2.new(0, 10, 0, 152)
        hexInput.BackgroundColor3 = Library.Theme.Element
        hexInput.Text = "#" .. colorpicker.Color:ToHex()
        hexInput.TextColor3 = Library.Theme.Text
        hexInput.Font = Enum.Font.Gotham
        hexInput.TextSize = 12
        hexInput.TextXAlignment = Enum.TextXAlignment.Center
        hexInput.Parent = picker
        Library:Corner(hexInput, 4)
        
        local cancelBtn = Instance.new("TextButton")
        cancelBtn.Size = UDim2.new(0, 80, 0, 20)
        cancelBtn.Position = UDim2.new(0, 10, 0, 175)
        cancelBtn.BackgroundColor3 = Library.Theme.Element
        cancelBtn.Text = "Cancel"
        cancelBtn.TextColor3 = Library.Theme.Text
        cancelBtn.Font = Enum.Font.Gotham
        cancelBtn.TextSize = 12
        cancelBtn.Parent = picker
        Library:Corner(cancelBtn, 4)
        
        local confirmBtn = Instance.new("TextButton")
        confirmBtn.Size = UDim2.new(0, 80, 0, 20)
        confirmBtn.Position = UDim2.new(1, -90, 0, 175)
        confirmBtn.BackgroundColor3 = Library.Theme.Accent
        confirmBtn.Text = "Confirm"
        confirmBtn.TextColor3 = Color3.new(1, 1, 1)
        confirmBtn.Font = Enum.Font.GothamBold
        confirmBtn.TextSize = 12
        confirmBtn.Parent = picker
        Library:Corner(confirmBtn, 4)
        
        local dragging = false
        
        function updateColor()
            local col = Color3.fromHSV(h, s, v)
            swatch.BackgroundColor3 = col
            alphaBar.BackgroundColor3 = col
            hexInput.Text = "#" .. col:ToHex()
            colorpicker.Color = col
            Library.Flags[colorpicker.Flag] = { Color = "#" .. col:ToHex(), HexValue = col:ToHex(), Alpha = colorpicker.Alpha }
            colorpicker.Callback(col, colorpicker.Alpha)
        end
        
        palette.MouseButton1Down:Connect(function()
            dragging = true
        end)
        palette.MouseButton1Up:Connect(function()
            dragging = false
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local x = (input.Position.X - palette.AbsolutePosition.X) / palette.AbsoluteSize.X
                local y = (input.Position.Y - palette.AbsolutePosition.Y) / palette.AbsoluteSize.Y
                s = Library:Clamp(x, 0, 1)
                v = 1 - Library:Clamp(y, 0, 1)
                dot.Position = UDim2.new(s, 0, 1 - v, 0)
                palette.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                updateColor()
            end
        end)
        
        local hueDragging = false
        hueBar.MouseButton1Down:Connect(function()
            hueDragging = true
        end)
        hueBar.MouseButton1Up:Connect(function()
            hueDragging = false
        end)
        UserInputService.InputChanged:Connect(function(input)
            if hueDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local x = (input.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X
                h = Library:Clamp(x, 0, 1)
                hueDot.Position = UDim2.new(h, 0, 0.5, 0)
                palette.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                updateColor()
            end
        end)
        
        local alphaDragging = false
        alphaBar.MouseButton1Down:Connect(function()
            alphaDragging = true
        end)
        alphaBar.MouseButton1Up:Connect(function()
            alphaDragging = false
        end)
        UserInputService.InputChanged:Connect(function(input)
            if alphaDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local x = (input.Position.X - alphaBar.AbsolutePosition.X) / alphaBar.AbsoluteSize.X
                colorpicker.Alpha = 1 - Library:Clamp(x, 0, 1)
                alphaDot.Position = UDim2.new(1 - colorpicker.Alpha, 0, 0.5, 0)
                updateColor()
            end
        end)
        
        hexInput.FocusLost:Connect(function(enter)
            if enter then
                local hex = hexInput.Text:gsub("#", "")
                if #hex == 6 then
                    local col = Color3.fromHex(hex)
                    h, s, v = Color3.toHSV(col)
                    dot.Position = UDim2.new(s, 0, 1 - v, 0)
                    hueDot.Position = UDim2.new(h, 0, 0.5, 0)
                    palette.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                    updateColor()
                end
            end
        end)
        
        cancelBtn.MouseButton1Click:Connect(function()
            colorpicker.Open = false
            picker:Destroy()
        end)
        
        confirmBtn.MouseButton1Click:Connect(function()
            colorpicker.Open = false
            picker:Destroy()
        end)
    end
    
    swatch.MouseButton1Click:Connect(openPicker)
    
    return colorpicker
end

