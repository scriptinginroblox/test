        tween(progress, {Size = UDim2.new(0, 0, 0, 2)}, TweenInfo.new(duration, Enum.EasingStyle.Linear))
        
        task.delay(duration, function()
            tween(card, {BackgroundTransparency = 1}, 0.3)
            tween(card, {Size = UDim2.new(1, 0, 0, 0)}, 0.3)
            task.wait(0.35)
            card:Destroy()
        end)
    end
    
    -- ── Keybind Handler ──
    UserInputService.InputBegan:Connect(function(input)
        if input.KeyCode == keybind then
            local vis = not Main.Visible
            Main.Visible = vis
            if vis then
                tween(UIScale, {Scale = 1}, 0.3, Enum.EasingStyle.Back)
                tween(Main, {BackgroundTransparency = 0}, 0.3, Enum.EasingStyle.Quart)
            else
                tween(UIScale, {Scale = 0}, 0.3, Enum.EasingStyle.Back)
                tween(Main, {BackgroundTransparency = 1}, 0.3, Enum.EasingStyle.Quart)
                task.wait(0.35)
                Main.Visible = false
            end
        end
    end)
    
    -- ── Window API ──
    local windowAPI = {
        ScreenGui = ScreenGui,
        Main = Main,
        Tab = createTab,
        SetTitle = function(text) TitleText.Text = text end,
        Notify = Voltage.Notify,
