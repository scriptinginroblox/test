-- ═══════════════════════════════════════════════════════════════════════════════
--  CONFIG SYSTEM
-- ═══════════════════════════════════════════════════════════════════════════════

function VoltageHub:GetConfig()
    local config = {}
    for key, value in pairs(self.Flags) do
        if type(value) == "Color3" then
            config[key] = {Color = Utilities:RGBToHex(value)}
        elseif type(value) == "table" and value.Key then
            config[key] = {Key = value.Key, Mode = value.Mode}
        else
            config[key] = value
        end
    end
    return Services.Http:JSONEncode(config)
end

function VoltageHub:LoadConfig(data)
    local success, decoded = pcall(Services.Http.JSONDecode, Services.Http, data)
    if not success then return false end
    for key, value in pairs(decoded) do
        if type(value) == "table" and value.Color then
            self.Flags[key] = Utilities:HexToRGB(value.Color)
        elseif type(value) == "table" and value.Key then
            self.Flags[key] = {Key = value.Key, Mode = value.Mode}
        else
            self.Flags[key] = value
        end
    end
    return true
end

function VoltageHub:SaveConfig(name)
    if not isfolder(self._configFolder) then
        makefolder(self._configFolder)
    end
    writefile(self._configFolder .. "/" .. name .. ".json", self:GetConfig())
end

function VoltageHub:LoadConfigFile(name)
    if isfile(self._configFolder .. "/" .. name .. ".json") then
        return self:LoadConfig(readfile(self._configFolder .. "/" .. name .. ".json"))
    end
    return false
end

function VoltageHub:GetConfigs()
    local files = {}
    if isfolder(self._configFolder) then
        for _, file in ipairs(listfiles(self._configFolder)) do
            local name = file:match("([^/\\]+)%.json$")
            if name then table.insert(files, name) end
        end
    end
    return files
end

function VoltageHub:DeleteConfig(name)
    if isfile(self._configFolder .. "/" .. name .. ".json") then
        delfile(self._configFolder .. "/" .. name .. ".json")
    end
end

-- ═══════════════════════════════════════════════════════════════════════════════
--  THEME MANAGEMENT
-- ═══════════════════════════════════════════════════════════════════════════════

function VoltageHub:SetTheme(name)
    if Themes[name] then
        self.Theme = Themes[name]
        self.CurrentTheme = name
        self:RefreshTheme()
    end
end

function VoltageHub:RefreshTheme()
    for _, elem in ipairs(self.Elements) do
        if elem.UpdateTheme then
            elem:UpdateTheme(self.Theme)
        end
    end
    if self._watermark then
        self._watermark:UpdateTheme(self.Theme)
    end
end

function VoltageHub:GetTheme()
    return self.Theme
end

function VoltageHub:GetThemes()
    local names = {}
    for name, _ in pairs(Themes) do
        table.insert(names, name)
    end
    return names
end

-- ═══════════════════════════════════════════════════════════════════════════════
--  CONNECTIONS & THREADS
-- ═══════════════════════════════════════════════════════════════════════════════

function VoltageHub:Connect(signal, callback)
    local conn = signal:Connect(callback)
    table.insert(self.Connections, conn)
    return conn
end

function VoltageHub:Thread(func)
    local thread = coroutine.create(func)
    coroutine.wrap(function() coroutine.resume(thread) end)()
    table.insert(self.Threads, thread)
    return thread
end

function VoltageHub:Unload()
    for _, conn in ipairs(self.Connections) do
        pcall(function() conn:Disconnect() end)
    end
    for _, thread in ipairs(self.Threads) do
        pcall(function() coroutine.close(thread) end)
    end
    if self._gui then
        pcall(function() self._gui:Destroy() end)
    end
    self._gui = nil
    self._main = nil
    self._watermark = nil
    self._keyList = nil
    self._floatingButton = nil
end

