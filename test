local function getMyInventoryPets()
    local pets = {}
    local inv = ClientData.get('inventory')
    if not inv or not inv.pets then return pets end
    
    for unique, data in pairs(inv.pets) do
        if data.category == 'pets' then
            local petInfo = InventoryDB.pets[data.id]
            if petInfo and petInfo.name then
                local props = data.properties or {}
                local value = getPetValueByName(petInfo.name, props)
                if value > 0 then
                    table.insert(pets, {
                        unique = unique,
                        id = data.id,
                        kind = data.kind,
                        name = petInfo.name,
                        props = props,
                        value = value,
                        tag = getPetTag(props),
                    })
                end
            end
        end
    end
    
    for i = #pets, 2, -1 do
        local j = math.random(1, i)
        pets[i], pets[j] = pets[j], pets[i]
    end
    
    return pets
end

