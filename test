            -- ========== МУЛЬТИ-ДРОПДАУН (ВЫБОР НЕСКОЛЬКИХ ФУНКЦИЙ) ==========
            function GroupObj:AddMultiDropdown(config)
                local name = config.Name or "Multi Dropdown"
                local flag = config.Flag or name
                local items = config.Items or {}
                local default = config.Default or {}
                local callback = config.Callback or function() end

                local Frame = Instance.new("Frame")
                Frame.Size = UDim2.new(1, 0, 0, 28)
                Frame.BackgroundTransparency = 1
                Frame.Parent = Container

                local Label = Instance.new("TextLabel")
                Label.Text = name
                Label.Size = UDim2.new(0.5, 0, 1, 0)
                Label.BackgroundTransparency = 1
                Label.Font = Enum.Font.GothamMedium
                Label.TextSize = 12
                Label.TextColor3 = Theme.White
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = Frame

                local DropBtn = Instance.new("TextButton")
                DropBtn.Size = UDim2.new(0.45, 0, 1, 0)
                DropBtn.Position = UDim2.new(0.55, 0, 0, 0)
                DropBtn.BackgroundColor3 = Theme.ElementBg
                DropBtn.Text = "  Select..."
                DropBtn.Font = Enum.Font.GothamMedium
                DropBtn.TextSize = 12
                DropBtn.TextColor3 = Theme.Text
                DropBtn.TextXAlignment = Enum.TextXAlignment.Left
                DropBtn.Parent = Frame
                Round(DropBtn, 4)

                local Arrow = Instance.new("ImageLabel")
                Arrow.Size = UDim2.new(0, 10, 0, 10)
                Arrow.Position = UDim2.new(1, -6, 0.5, 0)
                Arrow.AnchorPoint = Vector2.new(1, 0.5)
                Arrow.BackgroundTransparency = 1
                Arrow.Image = "rbxassetid://134243273101015"
                Arrow.ImageColor3 = Theme.TextDim
                Arrow.Parent = DropBtn

                local DropList = Instance.new("Frame")
                DropList.Size = UDim2.new(1, 0, 0, 0)
                DropList.Position = UDim2.new(0, 0, 1, 2)
                DropList.BackgroundColor3 = Theme.ElementBg
                DropList.Visible = false
                DropList.ZIndex = 10
                DropList.Parent = DropBtn
                Round(DropList, 4)
                
                Instance.new("UIStroke", DropList).Color = Theme.Border
                Instance.new("UIStroke", DropList).Thickness = 1
                Instance.new("UIListLayout", DropList)

                local SelectedItems = {}
                for _, item in ipairs(default) do
                    SelectedItems[item] = true
                end
                
                local ItemButtons = {}
                
                local function UpdateButtonText()
                    local selectedList = {}
                    for item, selected in pairs(SelectedItems) do
                        if selected then
                            table.insert(selectedList, item)
                        end
                    end
                    if #selectedList == 0 then
                        DropBtn.Text = "  Select..."
                    elseif #selectedList == 1 then
                        DropBtn.Text = "  " .. selectedList[1]
                    else
                        DropBtn.Text = "  " .. #selectedList .. " selected"
                    end
                end

                for _, item in ipairs(items) do
                    local ItemBtn = Instance.new("TextButton")
                    ItemBtn.Size = UDim2.new(1, 0, 0, 22)
                    ItemBtn.BackgroundTransparency = 1
                    ItemBtn.Text = "  " .. item
                    ItemBtn.Font = Enum.Font.GothamMedium
                    ItemBtn.TextSize = 11
                    ItemBtn.TextColor3 = SelectedItems[item] and Theme.White or Theme.TextDim
                    ItemBtn.TextXAlignment = Enum.TextXAlignment.Left
                    ItemBtn.ZIndex = 10
                    ItemBtn.Parent = DropList
                    
                    -- Индикатор выбора
                    local Indicator = Instance.new("Frame")
                    Indicator.Size = UDim2.new(0, 4, 0, 4)
                    Indicator.Position = UDim2.new(1, -8, 0.5, 0)
                    Indicator.AnchorPoint = Vector2.new(1, 0.5)
                    Indicator.BackgroundColor3 = Theme.ToggleOn
                    Indicator.Visible = SelectedItems[item] or false
                    Indicator.Parent = ItemBtn
                    Round(Indicator, 2)
                    
                    ItemBtn.MouseEnter:Connect(function()
                        ItemBtn.BackgroundTransparency = 0.9
                        ItemBtn.BackgroundColor3 = Theme.ElementHover
                        if not SelectedItems[item] then
                            ItemBtn.TextColor3 = Theme.White
                        end
                    end)
                    ItemBtn.MouseLeave:Connect(function()
                        ItemBtn.BackgroundTransparency = 1
                        if not SelectedItems[item] then
                            ItemBtn.TextColor3 = Theme.TextDim
                        end
                    end)
                    ItemBtn.MouseButton1Click:Connect(function()
                        SelectedItems[item] = not SelectedItems[item]
                        Indicator.Visible = SelectedItems[item]
                        ItemBtn.TextColor3 = SelectedItems[item] and Theme.White or Theme.TextDim
                        
                        local selectedList = {}
                        for itm, selected in pairs(SelectedItems) do
                            if selected then
                                table.insert(selectedList, itm)
                            end
                        end
                        
                        Window.Flags[flag] = selectedList
                        UpdateButtonText()
                        callback(selectedList)
                    end)
                    
                    ItemButtons[item] = ItemBtn
                end
                DropList.Size = UDim2.new(1, 0, 0, #items * 22)

                local MultiDropdown = {}
                
                function MultiDropdown:Set(items_list)
                    -- Сброс
                    for item, _ in pairs(SelectedItems) do
                        SelectedItems[item] = false
                        if ItemButtons[item] then
                            ItemButtons[item].TextColor3 = Theme.TextDim
                            if ItemButtons[item]:FindFirstChild("Frame") then
                                ItemButtons[item]:FindFirstChild("Frame").Visible = false
                            end
                        end
                    end
                    
                    -- Установка новых значений
                    for _, item in ipairs(items_list) do
                        if SelectedItems[item] ~= nil then
                            SelectedItems[item] = true
                            if ItemButtons[item] then
                                ItemButtons[item].TextColor3 = Theme.White
                                if ItemButtons[item]:FindFirstChild("Frame") then
                                    ItemButtons[item]:FindFirstChild("Frame").Visible = true
                                end
                            end
                        end
                    end
                    
                    Window.Flags[flag] = items_list
                    UpdateButtonText()
                    callback(items_list)
                end
                
                function MultiDropdown:Get()
                    local selectedList = {}
                    for item, selected in pairs(SelectedItems) do
                        if selected then
                            table.insert(selectedList, item)
                        end
                    end
                    return selectedList
                end
                
                DropBtn.MouseButton1Click:Connect(function()
                    DropList.Visible = not DropList.Visible
                end)
                
                UpdateButtonText()
                Window.Flags[flag] = default
                
                return MultiDropdown
            end

