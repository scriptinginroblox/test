    function Library:Toggle(State)
        if State ~= nil then Library.IsOpen = State else Library.IsOpen = not Library.IsOpen end
        if Library.ScreenGui then Library.ScreenGui.Instance.Enabled = Library.IsOpen end
    end

    function Library:Unload()
        for i = #Library.Connections, 1, -1 do
            local C = Library.Connections[i]
            if type(C) == "table" and C.Disconnect then pcall(C.Disconnect, C) end
            Library.Connections[i] = nil
        end
        Library.Connections = {}
        for i = #Library.PulseConnections, 1, -1 do
            local C = Library.PulseConnections[i]
            if type(C) == "table" and C.Disconnect then pcall(C.Disconnect, C) end
            Library.PulseConnections[i] = nil
        end
        Library.PulseConnections = {}
        if Library.ScreenGui and Library.ScreenGui.Instance then
            pcall(Library.ScreenGui.Instance.Destroy, Library.ScreenGui.Instance)
            Library.ScreenGui = nil
        end
        getgenv().PulseUI = nil
    end

