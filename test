-- Функция создания кнопки категории
local function createCategoryButton(parent, emoji, text, order)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 0, 80)
    button.BackgroundColor3 = Color3.fromRGB(74, 81, 97)
    button.Text = ""
    button.AutoButtonColor = false
    button.Parent = parent
    
    -- Скругление
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = button
    
    -- Эмодзи
    local emojiLabel = Instance.new("TextLabel")
    emojiLabel.Size = UDim2.new(1, 0, 0, 42)
    emojiLabel.Position = UDim2.new(0, 0, 0, 4)
    emojiLabel.BackgroundTransparency = 1
    emojiLabel.Text = emoji
    emojiLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    emojiLabel.TextSize = 28
    emojiLabel.Font = Enum.Font.GothamBold
    emojiLabel.TextWrapped = true
    emojiLabel.Parent = button
    
    -- Название
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0, 20)
    nameLabel.Position = UDim2.new(0, 0, 0, 48)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = text
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextSize = 13
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextWrapped = true
    nameLabel.Parent = button
    
    -- Ховер эффект
    button.MouseEnter:Connect(function()
        button.BackgroundColor3 = Color3.fromRGB(50, 55, 70)
    end)
    button.MouseLeave:Connect(function()
        button.BackgroundColor3 = Color3.fromRGB(74, 81, 97)
    end)
    
    return button
end

-- Создаем UIListLayout для каждой колонки (снизу вверх)
local function setupColumn(parent)
    local layout = Instance.new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Vertical
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 6)
    layout.Parent = parent
end

