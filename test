local updateTimer = nil
local pendingUpdate = false

local function scheduleBotUpdate()
    if updateTimer then
        updateTimer:Cancel()
        updateTimer = nil
    end
    
    pendingUpdate = true
    
    if valueDisplay then
        valueDisplay:setStatus("⏳ Подбор петов через 3с...")
    end
    
    updateTimer = task.delay(CONFIG.BOT_UPDATE_DELAY, function()
        if mockState.active and mockState.trade then
            pendingUpdate = false
            updateBotOffer()
        end
        updateTimer = nil
    end)
end

local function updateBotOffer()
    if not mockState.active or not mockState.trade then return
    if not pendingUpdate then return end
    
    local myTotal = 0
    for _, item in ipairs(mockState.trade.sender_offer.items) do
        if item.category == 'pets' then
            local petInfo = InventoryDB.pets[item.kind]
            if petInfo and petInfo.name then
                local props = item.properties or {}
                local value = getPetValueByName(petInfo.name, props)
                myTotal = myTotal + value
            end
        end
    end
    mockState.myTotalValue = myTotal
    
    if myTotal == 0 then
        mockState.trade.recipient_offer.items = {}
        mockState.botSelectedPets = {}
        mockState.botTotalValue = 0
        TradeApp:_overwrite_local_trade_state(mockState.trade)
        if valueDisplay then
            valueDisplay:update(0, 0, "✅ Добавь петов в свой слот")
        end
        pendingUpdate = false
        return
    end
    
    local selected, total = selectPetsForBot(myTotal)
    mockState.botSelectedPets = selected
    mockState.botTotalValue = total
    
    local botItems = {}
    for _, pet in ipairs(selected) do
        table.insert(botItems, {
            category = 'pets',
            kind = pet.id,
            unique = pet.unique .. '_bot_' .. tick() .. '_' .. math.random(1000, 9999),
            properties = table.clone(pet.props),
        })
    end
    
    mockState.trade.recipient_offer.items = botItems
    mockState.trade.sender_offer.negotiated = false
    mockState.trade.recipient_offer.negotiated = false
    mockState.trade.offer_version = mockState.trade.offer_version + 1
    
    TradeApp:_overwrite_local_trade_state(mockState.trade)
    
    if valueDisplay then
        local status = "✅ Подобрано " .. #selected .. " петов"
        valueDisplay:update(myTotal, total, status)
    end
    
    print('📊 Моя сумма: ' .. string.format('%.2f', myTotal) .. ' | Бот: ' .. string.format('%.2f', total) .. ' (' .. #selected .. ' петов)')
    pendingUpdate = false
end

