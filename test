UserInputService.InputChanged:Connect(function(input)
    if fabDrag and input.UserInputType == Enum.UserInputType.MouseMovement then
        local pos = Vector2.new(input.Position.X - fabOffset.X, input.Position.Y - fabOffset.Y)
        FAB.Position = UDim2.new(0, pos.X, 0, pos.Y)
