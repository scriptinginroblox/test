    function Library:Create(Class, Properties)
        local Instance = Instance.new(Class)

        if Class == "TextButton" or Class == "TextLabel" or Class == "TextBox" then
            pcall(function()
                if type(Library.Font) == "table" then
                    Instance.FontFace = Library.Font
                else
                    Instance.Font = Library.Font
                end
            end)
            
            if not Instance.FontFace and not Instance.Font then
                pcall(function()
                    Instance.Font = Enum.Font.SourceSans
                end)
            end
            
            Instance.TextSize = 14
            Instance.TextColor3 = Theme.Text
        end

        if Class == "TextButton" then
            Instance.AutoButtonColor = false
            Instance.Text = ""
        end

        if Class == "ImageButton" then
            Instance.AutoButtonColor = false
        end

        Instance.Name = "\0"

        for Property, Value in pairs(Properties or {}) do
            if Property == "Parent" then
                Instance.Parent = Value
            else
                Instance[Property] = Value
            end
        end

        return setmetatable({Instance = Instance}, Library)
    end

    function Library:Connect(Signal, Callback)
        local Connection
        if type(Signal) == "Instance" and Signal:IsA("RBXScriptSignal") then
            Connection = Signal:Connect(Callback)
        elseif Signal and type(Signal) == "table" and Signal.Instance then
            Connection = Signal.Instance:Connect(Callback)
        else
            Connection = Signal:Connect(Callback)
        end
        table.insert(Library.Connections, Connection)
        return Connection
    end

    function Library:Thread(Func)
        local Thread = coroutine.create(Func)
        coroutine.wrap(function()
            coroutine.resume(Thread)
        end)()
        table.insert(Library.Threads, Thread)
        return Thread
    end

    function Library:Tween(Object, Properties, Info)
        local Instance = Object.Instance or Object
        Info = Info or TweenInfo.new(Library.TweenSpeed, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
        local Tween = TweenService:Create(Instance, Info, Properties)
        Tween:Play()
        return Tween
    end

    function Library:GetTransparency(Object)
        local Instance = Object.Instance or Object
        if Instance:IsA("Frame") then
            return {"BackgroundTransparency"}
        elseif Instance:IsA("TextLabel") or Instance:IsA("TextButton") then
            return {"TextTransparency", "BackgroundTransparency"}
        elseif Instance:IsA("ImageLabel") or Instance:IsA("ImageButton") then
            return {"BackgroundTransparency", "ImageTransparency"}
        elseif Instance:IsA("ScrollingFrame") then
            return {"BackgroundTransparency", "ScrollBarImageTransparency"}
        elseif Instance:IsA("TextBox") then
            return {"TextTransparency", "BackgroundTransparency"}
        elseif Instance:IsA("UIStroke") then
            return {"Transparency"}
        end
        return nil
    end

    function Library:Fade(Object, Property, Visible)
        local Instance = Object.Instance or Object
        local OldTransparency = Instance[Property]
        Instance[Property] = Visible and 1 or OldTransparency
        local Tween = Library:Tween(Object, {
            [Property] = Visible and OldTransparency or 1
        })
        Library:Connect(Tween.Completed, function()
            if not Visible then
                Instance[Property] = OldTransparency
            end
        end)
        return Tween
    end

    function Library:FadeDescendants(Object, Visible, Callback)
        local Instance = Object.Instance or Object
        if Visible then
            Instance.Visible = true
        end
        local Children = Instance:GetDescendants()
        table.insert(Children, Instance)
        local LastTween
        for _, Child in pairs(Children) do
            local Props = Library:GetTransparency(Child)
            if Props then
                for _, Prop in pairs(Props) do
                    LastTween = Library:Fade(Child, Prop, Visible)
                end
            end
        end
        if LastTween then
            Library:Connect(LastTween.Completed, function()
                Instance.Visible = Visible
                if Callback then Callback() end
            end)
        else
            Instance.Visible = Visible
            if Callback then Callback() end
        end
    end

    function Library:MakeDraggable(Object)
        local Instance = Object.Instance or Object
        local Dragging = false
        local DragStart, StartPos
        Instance.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Dragging = true
                DragStart = Input.Position
                StartPos = Instance.Position
                local Changed
                Changed = Input.Changed:Connect(function()
                    if Input.UserInputState == Enum.UserInputState.End then
                        Dragging = false
                        Changed:Disconnect()
                    end
                end)
            end
        end)
        Library:Connect(UserInputService.InputChanged, function(Input)
            if Dragging and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                local Delta = Input.Position - DragStart
                Instance.Position = UDim2.new(
                    StartPos.X.Scale, StartPos.X.Offset + Delta.X,
                    StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y
                )
            end
        end)
    end

    function Library:MakeResizable(Object, MinSize)
        local Instance = Object.Instance or Object
        MinSize = MinSize or Vector2.new(300, 200)
        local Resizing = false
        local StartPos, StartSize
        local Handle = Library:Create("ImageButton", {
            Parent = Instance,
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, -4, 1, -4),
            Size = UDim2.new(0, 16, 0, 16),
            BackgroundTransparency = 1,
            Image = Icons.resize,
            ImageColor3 = Theme.TextDim,
            ZIndex = 999,
        })
        Handle.Instance.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Resizing = true
                StartPos = Input.Position
                StartSize = Instance.Size
            end
        end)
        Library:Connect(UserInputService.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Resizing = false
            end
        end)
        Library:Connect(UserInputService.InputChanged, function(Input)
            if Resizing and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                local Delta = Input.Position - StartPos
                local NewX = math.max(StartSize.X.Offset + Delta.X, MinSize.X)
                local NewY = math.max(StartSize.Y.Offset + Delta.Y, MinSize.Y)
                Instance.Size = UDim2.new(0, NewX, 0, NewY)
            end
        end)
    end

    function Library:SafeCall(Func, ...)
        if not Func then return end
        local Args = {...}
        local Success, Result = pcall(Func, table.unpack(Args))
        if not Success then
            warn("[PulseUI] Error:", Result)
        end
        return Success, Result
    end

    function Library:Round(Number, Decimals)
        local Multiplier = 10 ^ (Decimals or 0)
        return math.floor(Number * Multiplier + 0.5) / Multiplier
    end

    function Library:GetConfig()
        local Config = {}
        for Flag, Value in pairs(Library.Flags) do
            if type(Value) == "table" and Value.Color then
                Config[Flag] = {
                    Color = Value.Color:ToHex(),
                    Transparency = Value.Transparency
                }
            elseif type(Value) == "table" and Value.Key then
                Config[Flag] = {
                    Key = tostring(Value.Key),
                    Mode = Value.Mode,
                    Active = Value.Active
                }
            else
                Config[Flag] = Value
            end
        end
        return HttpService:JSONEncode(Config)
    end

    function Library:LoadConfig(JSON)
        local Config = HttpService:JSONDecode(JSON)
        for Flag, Value in pairs(Config) do
            local Func = Library.ConfigFlags[Flag]
            if Func then
                if type(Value) == "table" and Value.Color then
                    Func(Color3.fromHex(Value.Color), Value.Transparency)
                elseif type(Value) == "table" and Value.Key then
                    Func({Key = Value.Key, Mode = Value.Mode, Active = Value.Active})
                else
                    Func(Value)
                end
            end
        end
    end

    function Library:SaveConfig(Name)
        if not Name or Name == "" then return end
        local Path = string.format("%s%s/%s.json", Library.Directory, Library.Folders.Configs, Name)
        writefile(Path, Library:GetConfig())
    end

    function Library:LoadConfigFile(Name)
        if not Name or Name == "" then return end
        local Path = string.format("%s%s/%s.json", Library.Directory, Library.Folders.Configs, Name)
        if isfile(Path) then
            Library:LoadConfig(readfile(Path))
        end
    end

    function Library:DeleteConfig(Name)
        if not Name or Name == "" then return end
        local Path = string.format("%s%s/%s.json", Library.Directory, Library.Folders.Configs, Name)
        if isfile(Path) then delfile(Path) end
    end

    function Library:GetConfigsList()
        local List = {}
        local Path = Library.Directory .. Library.Folders.Configs
        for _, File in pairs(listfiles(Path)) do
            local Name = File:gsub(Path .. "/", ""):gsub(Path .. "\\", ""):gsub(".json", "")
            if Name ~= "" then
                table.insert(List, Name)
            end
        end
        return List
    end

    function Library:Unload()
        for _, Connection in pairs(Library.Connections) do
            pcall(Connection.Disconnect, Connection)
        end
        for _, Thread in pairs(Library.Threads) do
            pcall(coroutine.close, Thread)
        end
        if Library.ScreenGui then
            Library.ScreenGui.Instance:Destroy()
        end
        getgenv().PulseUI = nil
    end

