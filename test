            -- ========== КЕЙБИНД ==========
            function GroupObj:AddKeybind(config)
                local name = config.Name or "Keybind"
                local flag = config.Flag or name
                local default = config.Default or "None"
                local callback = config.Callback or function() end

                local Frame = Instance.new("Frame")
                Frame.Size = UDim2.new(1, 0, 0, 24)
                Frame.BackgroundTransparency = 1
                Frame.Parent = Container

                local Label = Instance.new("TextLabel")
                Label.Text = name
                Label.Size = UDim2.new(0.6, 0, 1, 0)
                Label.BackgroundTransparency = 1
                Label.Font = Enum.Font.GothamMedium
                Label.TextSize = 12
                Label.TextColor3 = Theme.White
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = Frame

                local KeyBtn = Instance.new("TextButton")
                KeyBtn.Size = UDim2.new(0, 0, 0, 20)
                KeyBtn.Position = UDim2.new(1, 0, 0.5, 0)
                KeyBtn.AnchorPoint = Vector2.new(1, 0.5)
                KeyBtn.BackgroundColor3 = Theme.ElementBg
                KeyBtn.Text = ""
                KeyBtn.Parent = Frame
                Round(KeyBtn, 4)
                KeyBtn.AutomaticSize = Enum.AutomaticSize.X

                local KeyText = Instance.new("TextLabel")
                KeyText.Text = default
                KeyText.Size = UDim2.new(1, -8, 1, 0)
                KeyText.Position = UDim2.new(0, 4, 0, 0)
                KeyText.BackgroundTransparency = 1
                KeyText.Font = Enum.Font.GothamMedium
                KeyText.TextSize = 11
                KeyText.TextColor3 = Theme.White
                KeyText.TextXAlignment = Enum.TextXAlignment.Center
                KeyText.Parent = KeyBtn

                local Keybind = {}
                
                function Keybind:Set(val)
                    Window.Flags[flag] = val
                    KeyText.Text = val
                    callback(val)
                end
                
                function Keybind:Get()
                    return Window.Flags[flag]
                end

                KeyBtn.MouseButton1Click:Connect(function()
                    KeyText.Text = "..."
                    local con = UserInputService.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            local key = input.KeyCode.Name
                            Keybind:Set(key == "Escape" and "None" or key)
                            con:Disconnect()
                        end
                    end)
                end)
                
                Keybind:Set(default)
                return Keybind
            end

            return GroupObj
        end

        if not Window.ActiveTab then Select() end
        table.insert(Window.Tabs, Tab)
        return Tab
    end

    return Window
end

return PyroHubLibrary
