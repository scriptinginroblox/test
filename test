--  ПЛАВАЮЩАЯ КНОПКА ДЛЯ ОТКРЫТИЯ/ЗАКРЫТИЯ МЕНЮ
-- ═══════════════════════════════════════════════════════════════════════════════

function VoltageHub:CreateFloatingButton(window)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 60, 0, 60)
    btn.Position = UDim2.new(0, 20, 1, -90)
    btn.AnchorPoint = Vector2.new(0, 1)
    btn.BackgroundColor3 = self.Theme.Surface
    btn.BackgroundTransparency = 0.2
    btn.BorderSizePixel = 0
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.ZIndex = 100
    btn.Visible = false -- Скрыта пока меню открыто
    btn.Parent = self._gui
    
    Utilities:Corner(btn, 30)
    Utilities:Stroke(btn, self.Theme.Accent, 2, 0.4)
    
    -- Логотип внутри кнопки
    local logo = self:CreateIcon("logo", UDim2.fromOffset(32, 32), self.Theme.Accent)
    logo.Position = UDim2.new(0.5, -16, 0.5, -16)
    logo.Parent = btn
    
    -- Эффект свечения
    local glow = Instance.new("ImageLabel")
    glow.Size = UDim2.new(1.8, 0, 1.8, 0)
    glow.Position = UDim2.new(0.5, 0, 0.5, 0)
    glow.AnchorPoint = Vector2.new(0.5, 0.5)
    glow.BackgroundTransparency = 1
    glow.Image = "rbxassetid://18245826428"
    glow.ImageColor3 = self.Theme.Accent
    glow.ImageTransparency = 0.7
    glow.ScaleType = Enum.ScaleType.Slice
    glow.SliceCenter = Rect.new(Vector2.new(21, 21), Vector2.new(79, 79))
    glow.ZIndex = -1
    glow.Parent = btn
    
    -- Текст "MENU" под иконкой
    local menuLabel = Instance.new("TextLabel")
    menuLabel.Size = UDim2.new(1, 0, 0, 14)
    menuLabel.Position = UDim2.new(0, 0, 1, -2)
    menuLabel.BackgroundTransparency = 1
    menuLabel.Text = "MENU"
    menuLabel.TextColor3 = self.Theme.TextDim
    menuLabel.FontFace = self.FontBold
    menuLabel.TextSize = 10
    menuLabel.TextScaled = false
    menuLabel.Parent = btn
    
    -- Пульсация
    task.spawn(function()
        local direction = 1
        while btn.Parent and btn.Visible do
            local scale = 1 + direction * 0.05
            Utilities:Tween(btn, {Size = UDim2.new(0, 60 * scale, 0, 60 * scale)}, 0.5)
            direction = direction * -1
            task.wait(0.5)
        end
    end)
    
    -- Наведение (для ПК)
    btn.MouseEnter:Connect(function()
        Utilities:Tween(btn, {BackgroundTransparency = 0.05}, 0.15)
        local img = logo:FindFirstChildWhichIsA("ImageLabel")
        if img then Utilities:Tween(img, {ImageColor3 = Color3.fromRGB(255, 255, 255)}, 0.15) end
        Utilities:Tween(menuLabel, {TextColor3 = self.Theme.Text}, 0.15)
    end)
    
    btn.MouseLeave:Connect(function()
        Utilities:Tween(btn, {BackgroundTransparency = 0.2}, 0.15)
        local img = logo:FindFirstChildWhichIsA("ImageLabel")
        if img then Utilities:Tween(img, {ImageColor3 = self.Theme.Accent}, 0.15) end
        Utilities:Tween(menuLabel, {TextColor3 = self.Theme.TextDim}, 0.15)
    end)
    
    -- Открытие меню
    btn.MouseButton1Click:Connect(function()
        window:Toggle()
    end)
    
    -- Сохраняем ссылку на кнопку
    self._floatingButton = btn
    
    return btn
end

