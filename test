        -- ФУНКЦИЯ СОЗДАНИЯ БЛОКА
        -- ═══════════════════════════════════════════════════════════
        local function CreateBlock(Parent, Title, Desc)
            local Block = Library:Create("Frame", {
                Parent = Parent.Instance,
                Size = UDim2.new(1, 0, 0, 0),
                BackgroundColor3 = Theme.Background2,
                BorderSizePixel = 0,
                AutomaticSize = Enum.AutomaticSize.Y,
                ClipsDescendants = true,
            })

            Library:Create("UICorner", {
                Parent = Block.Instance,
                CornerRadius = UDim.new(0, 10),
            })

            Library:Create("UIStroke", {
                Parent = Block.Instance,
                Color = Theme.Outline,
                Thickness = 1,
            })

            Library:Create("UIPadding", {
                Parent = Block.Instance,
                PaddingBottom = UDim.new(0, 14),
                PaddingTop = UDim.new(0, 14),
                PaddingLeft = UDim.new(0, 14),
                PaddingRight = UDim.new(0, 14),
            })

            -- Заголовок блока
            local BlockTitle = Library:Create("TextLabel", {
                Parent = Block.Instance,
                Text = Title,
                FontFace = Library.FontBold,
                TextSize = 14,
                TextColor3 = Theme.Text,
                Position = UDim2.new(0, 0, 0, 0),
                BackgroundTransparency = 1,
            })

            if Desc then
                local BlockDesc = Library:Create("TextLabel", {
                    Parent = Block.Instance,
                    Text = Desc,
                    FontFace = Library.Font,
                    TextSize = 12,
                    TextColor3 = Theme.TextDim,
                    Position = UDim2.new(0, 0, 0, 22),
                    BackgroundTransparency = 1,
                })
            end

            -- Контейнер для элементов
            local Content = Library:Create("Frame", {
                Parent = Block.Instance,
                Position = UDim2.new(0, 0, 0, Desc and 40 or 24),
                Size = UDim2.new(1, 0, 0, 0),
                BackgroundTransparency = 1,
                BorderSizePixel = 0,
                AutomaticSize = Enum.AutomaticSize.Y,
            })

            Library:Create("UIListLayout", {
                Parent = Content.Instance,
                Padding = UDim.new(0, 6),
                SortOrder = Enum.SortOrder.LayoutOrder,
            })

            return {
                Instance = Block,
                Content = Content,
                Add = function(self, Element)
                    if Element and Element.Instance then
                        Element.Instance.Parent = Content.Instance
                    end
                    return Element
                end
            }
        end

        -- ═══════════════════════════════════════════════════════════
        -- ФУНКЦИЯ СОЗДАНИЯ TOGGLE
        -- ═══════════════════════════════════════════════════════════
        local function CreateToggle(Parent, Label, Desc, Default, Callback)
            local Container = Library:Create("Frame", {
                Parent = Parent.Instance,
                Size = UDim2.new(1, 0, 0, 0),
                BackgroundTransparency = 1,
                BorderSizePixel = 0,
                AutomaticSize = Enum.AutomaticSize.Y,
            })

            local ToggleFrame = Library:Create("Frame", {
                Parent = Container.Instance,
                Size = UDim2.new(1, 0, 0, 44),
                BackgroundColor3 = Theme.Element,
                BorderSizePixel = 0,
            })

            Library:Create("UICorner", {
                Parent = ToggleFrame.Instance,
                CornerRadius = UDim.new(0, 8),
            })

            -- Заголовок
            local Lbl = Library:Create("TextLabel", {
                Parent = ToggleFrame.Instance,
                Text = Label,
                FontFace = Library.FontBold,
                TextSize = 13,
                TextColor3 = Theme.Text,
                Position = UDim2.new(0, 14, 0, 6),
                BackgroundTransparency = 1,
            })

            if Desc then
                local DescLbl = Library:Create("TextLabel", {
                    Parent = ToggleFrame.Instance,
                    Text = Desc,
                    FontFace = Library.Font,
                    TextSize = 11,
                    TextColor3 = Theme.TextDim,
                    Position = UDim2.new(0, 14, 0, 26),
                    BackgroundTransparency = 1,
                })
            end

            -- Переключатель
            local Track = Library:Create("TextButton", {
                Parent = ToggleFrame.Instance,
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -14, 0.5, 0),
                Size = UDim2.new(0, 40, 0, 22),
                BackgroundColor3 = Theme.Element,
                BorderSizePixel = 0,
            })

            Library:Create("UICorner", {
                Parent = Track.Instance,
                CornerRadius = UDim.new(1, 0),
            })

            local Knob = Library:Create("Frame", {
                Parent = Track.Instance,
                Size = UDim2.new(0, 16, 0, 16),
                Position = UDim2.new(0, 3, 0.5, -8),
                BackgroundColor3 = Theme.TextDim,
                BorderSizePixel = 0,
            })

            Library:Create("UICorner", {
                Parent = Knob.Instance,
                CornerRadius = UDim.new(1, 0),
            })

            local Value = Default or false

            local function Set(State)
                Value = State
                if State then
                    Track.Instance.BackgroundColor3 = Theme.Accent1
                    Knob.Instance.Position = UDim2.new(1, -19, 0.5, -8)
                    Knob.Instance.BackgroundColor3 = Theme.Text
                else
                    Track.Instance.BackgroundColor3 = Theme.Element
                    Knob.Instance.Position = UDim2.new(0, 3, 0.5, -8)
                    Knob.Instance.BackgroundColor3 = Theme.TextDim
                end
                Library.SafeCall(Callback, State)
            end

            Track.Instance.MouseButton1Click:Connect(function()
                Set(not Value)
            end)

            Set(Default or false)

            return {
                Instance = Container.Instance,
                Set = Set,
                Get = function() return Value end,
            }
        end

        -- ═══════════════════════════════════════════════════════════
        -- ФУНКЦИЯ СОЗДАНИЯ BUTTON
        -- ═══════════════════════════════════════════════════════════
        local function CreateButton(Parent, Label, Callback)
            local Container = Library:Create("Frame", {
                Parent = Parent.Instance,
                Size = UDim2.new(1, 0, 0, 36),
                BackgroundTransparency = 1,
                BorderSizePixel = 0,
            })

            local Button = Library:Create("TextButton", {
                Parent = Container.Instance,
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundColor3 = Theme.Element,
                BorderSizePixel = 0,
                Text = Label,
                TextColor3 = Theme.Text,
                FontFace = Library.FontBold,
                TextSize = 13,
            })

            Library:Create("UICorner", {
                Parent = Button.Instance,
                CornerRadius = UDim.new(0, 8),
            })

            Button.Instance.MouseEnter:Connect(function()
                Button.Instance.BackgroundColor3 = Theme.ElementHover
            end)

            Button.Instance.MouseLeave:Connect(function()
                Button.Instance.BackgroundColor3 = Theme.Element
            end)

            Button.Instance.MouseButton1Click:Connect(function()
                Library.SafeCall(Callback)
                Button.Instance.BackgroundColor3 = Theme.Accent2
                task.wait(0.08)
                Button.Instance.BackgroundColor3 = Theme.Element
            end)

            return Container
        end

