-- ── Перетаскивание FAB ──────────────────────────────────────────────
-- При нажатии запоминаем смещение. При движении обновляем позицию.
-- При отпускании проверяем, был ли сдвиг. Если нет — это клик.
-- ================================================================
local fabDrag = false
local fabOffset = Vector2.new()
local fabMoved = false

FAB.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        fabDrag = true
        fabMoved = false
        fabOffset = Vector2.new(input.Position.X - FAB.AbsolutePosition.X,
                                input.Position.Y - FAB.AbsolutePosition.Y)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if fabDrag and input.UserInputType == Enum.UserInputType.MouseMovement then
        local pos = Vector2.new(input.Position.X - fabOffset.X, input.Position.Y - fabOffset.Y)
        FAB.Position = UDim2.new(0, pos.X, 0, pos.Y)
        fabMoved = true
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and fabDrag then
        fabDrag = false
        if not fabMoved then  -- Если не двигали — открываем меню
            Window:Toggle()
        end
    end
end)

-- ================================================================
-- 6. ОКНО (Main Window)
-- ================================================================
-- Основное окно меню. Имеет левую панель с аватаром и вкладками,
-- и правую панель с содержимым. Поддерживает перетаскивание.
-- ================================================================
local Window = {}
Window._open = false
Window._tabs = {}
Window._tabButtons = {}
Window._currentTab = nil

-- ── Создание окна ──────────────────────────────────────────────────
function Window:Create(config)
    config = config or {}
    local title = config.title or "Voltage Hub"
    local width = config.width or 620
    local height = config.height or 480

    -- Главный фрейм окна
    local main = Instance.new("Frame")
    main.Size = UDim2.new(0, width, 0, height)
    main.Position = UDim2.new(0, 100, 0, 100)
    main.BackgroundColor3 = Theme.Background
    main.BackgroundTransparency = 1
    main.Visible = false
    main.ZIndex = 5
    main.Parent = ScreenGui
    corner(main, 12)
    stroke(main, Theme.Stroke, 1.5)

    -- ── Акриловый блюр (эффект стекла) ────────────────────────────
    -- Создаём DepthOfFieldEffect для размытия фона за окном.
    -- Это делает интерфейс современным и "парящим".
    -- Вдохновлено Ventura UI и macOS.
    local blur = Instance.new("DepthOfFieldEffect")
    blur.Name = "VoltageBlur"
    blur.FarIntensity = 0
    blur.InFocusRadius = 0.1
    blur.NearIntensity = 0.8
    blur.Parent = Lighting

    -- Создаём стеклянную часть, которая повторяет размеры окна
    local blurPart = Instance.new("Part")
    blurPart.Size = Vector3.new(1, 1, 0.01)
    blurPart.Material = Enum.Material.Glass
    blurPart.Transparency = 0.99
    blurPart.Anchored = true
    blurPart.CanCollide = false
    blurPart.CastShadow = false
    blurPart.Parent = workspace.CurrentCamera

    -- Обновляем позицию стеклянной части каждый кадр
    RunService.RenderStepped:Connect(function()
        if main.Visible then
            local pos = main.AbsolutePosition
            local size = main.AbsoluteSize
            local camera = workspace.CurrentCamera
            local topLeft = camera:ScreenPointToRay(pos.X, pos.Y, 0.01)
            local bottomRight = camera:ScreenPointToRay(pos.X + size.X, pos.Y + size.Y, 0.01)
            local center = (topLeft.Origin + bottomRight.Origin) / 2
            blurPart.CFrame = CFrame.new(center)
            blurPart.Size = Vector3.new(size.X / camera.ViewportSize.X * 10, 
                                        size.Y / camera.ViewportSize.Y * 10, 0.01)
        end
    end)

    -- ── Левая панель ────────────────────────────────────────────────
    -- Содержит аватар, название и кнопки вкладок.
    local leftPanel = Instance.new("Frame")
    leftPanel.Size = UDim2.new(0, 200, 1, 0)
    leftPanel.BackgroundTransparency = 1
    leftPanel.ZIndex = 6
    leftPanel.Parent = main

    -- Верхняя часть левой панели (аватар + название)
    local topContainer = Instance.new("Frame")
    topContainer.Size = UDim2.new(1, 0, 0, 150)
    topContainer.BackgroundTransparency = 1
    topContainer.ZIndex = 7
    topContainer.Parent = leftPanel
    pad(topContainer, 10, 0, 0, 0)

    -- Аватар игрока
    local avatar = Instance.new("Frame")
    avatar.Size = UDim2.new(0, 70, 0, 70)
    avatar.BackgroundColor3 = Theme.Accent
    avatar.ZIndex = 8
    avatar.Parent = topContainer
    corner(avatar, 35)

    -- Картинка аватара
    local avatarImg = Instance.new("ImageLabel")
    avatarImg.Size = UDim2.new(1, -4, 1, -4)
    avatarImg.Position = UDim2.new(0.5, 0, 0.5, 0)
    avatarImg.AnchorPoint = Vector2.new(0.5, 0.5)
    avatarImg.BackgroundTransparency = 1
    avatarImg.Image = "rbxthumb://type=AvatarHeadShot&id=" .. LocalPlayer.UserId .. "&w=150&h=150"
    avatarImg.ZIndex = 9
    avatarImg.Parent = avatar
    corner(avatarImg, 35)

    -- Название
    local titleLbl = Instance.new("TextLabel")
    titleLbl.Size = UDim2.new(0, 180, 0, 40)
    titleLbl.BackgroundTransparency = 1
    titleLbl.Text = title
    titleLbl.TextColor3 = Color3.new(1, 1, 1)
    titleLbl.TextSize = 32
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextXAlignment = Enum.TextXAlignment.Center
    titleLbl.ZIndex = 8
    titleLbl.Parent = topContainer

    -- Контейнер для кнопок вкладок
    local btnContainer = Instance.new("Frame")
    btnContainer.Size = UDim2.new(1, 0, 1, -150)
    btnContainer.Position = UDim2.new(0, 0, 0, 150)
    btnContainer.BackgroundTransparency = 1
    btnContainer.ZIndex = 7
    btnContainer.Parent = leftPanel
    pad(btnContainer, 8, 8, 8, 8)
    
    local btnLayout = Instance.new("UIListLayout")
    btnLayout.SortOrder = Enum.SortOrder.LayoutOrder
    btnLayout.Padding = UDim.new(0, 4)
    btnLayout.Parent = btnContainer

    -- ── Правая панель ───────────────────────────────────────────────
    -- Содержит содержимое выбранной вкладки.
    local rightPanel = Instance.new("Frame")
    rightPanel.Size = UDim2.new(1, -200, 1, 0)
    rightPanel.Position = UDim2.new(0, 200, 0, 0)
    rightPanel.BackgroundTransparency = 1
    rightPanel.ZIndex = 6
    rightPanel.Parent = main
    pad(rightPanel, 12, 12, 12, 12)

    -- ── Перетаскивание окна ────────────────────────────────────────
    -- Можно перетаскивать за левую панель (аватар и заголовок).
    local dragWin = false
    local dragOffsetWin = Vector2.new()
    leftPanel.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragWin = true
            dragOffsetWin = Vector2.new(input.Position.X - main.AbsolutePosition.X,
                                        input.Position.Y - main.AbsolutePosition.Y)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragWin and input.UserInputType == Enum.UserInputType.MouseMovement then
            local pos = Vector2.new(input.Position.X - dragOffsetWin.X, input.Position.Y - dragOffsetWin.Y)
            main.Position = UDim2.new(0, pos.X, 0, pos.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragWin = false
        end
    end)

    -- ── Методы окна ──────────────────────────────────────────────────
    function Window:Toggle()
        self._open = not self._open
        if self._open then
            main.Visible = true
            tween(main, { BackgroundTransparency = 0 }, 0.2)
            if self._currentTab then
                self:SelectTab(self._currentTab)
            elseif #self._tabs > 0 then
                self:SelectTab(self._tabs[1].name)
            end
        else
            tween(main, { BackgroundTransparency = 1 }, 0.15)
            task.wait(0.15)
            main.Visible = false
        end
    end

    function Window:SelectTab(name)
        self._currentTab = name
        for _, tab in ipairs(self._tabs) do
            tab.container.Visible = (tab.name == name)
        end
        for _, btn in ipairs(self._tabButtons) do
            if btn.tabName == name then
                btn.BackgroundTransparency = 0
                btn.TextColor3 = Color3.new(1, 1, 1)
            else
                btn.BackgroundTransparency = 1
                btn.TextColor3 = Theme.SubText
            end
        end
    end

    function Window:CreateTab(config)
        local tabName = config.name or "Tab"
        local icon = config.icon or "📁"
        local tab = {
            name = tabName,
            container = Instance.new("Frame"),
        }
        tab.container.Size = UDim2.new(1, 0, 1, 0)
        tab.container.BackgroundTransparency = 1
        tab.container.Visible = false
        tab.container.Parent = rightPanel

        -- Кнопка вкладки в левой панели
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 55)
        btn.BackgroundTransparency = 1
        btn.Text = ""
        btn.ZIndex = 10
        btn.Parent = btnContainer
        corner(btn, 8)

        -- Иконка вкладки (эмодзи)
        local iconLbl = Instance.new("TextLabel")
        iconLbl.Size = UDim2.new(0, 30, 0, 30)
        iconLbl.Position = UDim2.new(0, 10, 0, 3)
        iconLbl.BackgroundTransparency = 1
        iconLbl.Text = icon
        iconLbl.TextSize = 24
        iconLbl.TextColor3 = Color3.new(1, 1, 1)
        iconLbl.ZIndex = 11
        iconLbl.Parent = btn

        -- Название вкладки
        local nameLbl = Instance.new("TextLabel")
        nameLbl.Size = UDim2.new(1, -50, 0, 20)
        nameLbl.Position = UDim2.new(0, 50, 0, 8)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text = tabName
        nameLbl.TextColor3 = Theme.SubText
        nameLbl.TextSize = 15
        nameLbl.Font = Enum.Font.GothamBold
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.ZIndex = 11
        nameLbl.Parent = btn

        -- Описание вкладки
        local descLbl = Instance.new("TextLabel")
        descLbl.Size = UDim2.new(1, -50, 0, 16)
        descLbl.Position = UDim2.new(0, 50, 0, 30)
        descLbl.BackgroundTransparency = 1
        descLbl.Text = config.description or ""
        descLbl.TextColor3 = Color3.fromRGB(130, 140, 155)
        descLbl.TextSize = 11
        descLbl.Font = Enum.Font.Gotham
        descLbl.TextXAlignment = Enum.TextXAlignment.Left
        descLbl.ZIndex = 11
        descLbl.Parent = btn

        btn.tabName = tabName
        btn.MouseButton1Click:Connect(function()
            Window:SelectTab(tabName)
        end)

        table.insert(self._tabs, tab)
        table.insert(self._tabButtons, btn)

        if #self._tabs == 1 then
            Window:SelectTab(tabName)
        end

        -- Возвращаем объект для создания секций
        local tabObj = {}
        function tabObj:Section(config)
            return self:_createSection(config, tab.container)
        end
        return tabObj
    end

    -- ── Создание секции ─────────────────────────────────────────────
    function Window:_createSection(config, parent)
        local secName = config.name or "Section"
        local secFrame = Instance.new("Frame")
        secFrame.Size = UDim2.new(1, 0, 0, 0)
        secFrame.BackgroundTransparency = 1
        secFrame.AutomaticSize = Enum.AutomaticSize.Y
        secFrame.ZIndex = 9
        secFrame.Parent = parent

        -- Заголовок секции
        local header = Instance.new("Frame")
        header.Size = UDim2.new(1, 0, 0, 30)
        header.BackgroundTransparency = 1
        header.Parent = secFrame

        -- Название секции (заглавными буквами)
        local title = Instance.new("TextLabel")
        title.Size = UDim2.new(1, -20, 1, 0)
        title.BackgroundTransparency = 1
        title.Text = secName:upper()
        title.TextColor3 = Theme.SubText
        title.TextSize = 12
        title.Font = Enum.Font.GothamBold
        title.TextXAlignment = Enum.TextXAlignment.Left
        title.ZIndex = 10
        title.Parent = header

        -- Разделительная линия
        local line = Instance.new("Frame")
        line.Size = UDim2.new(1, 0, 0, 1)
        line.Position = UDim2.new(0, 0, 1, 0)
        line.BackgroundColor3 = Theme.Stroke
        line.BorderSizePixel = 0
        line.ZIndex = 9
        line.Parent = header

        -- Контейнер для элементов
        local content = Instance.new("Frame")
        content.Size = UDim2.new(1, 0, 0, 0)
        content.BackgroundTransparency = 1
        content.AutomaticSize = Enum.AutomaticSize.Y
        content.ZIndex = 10
        content.Parent = secFrame
        
        local layout = Instance.new("UIListLayout")
        layout.SortOrder = Enum.SortOrder.LayoutOrder
        layout.Padding = UDim.new(0, 8)
        layout.Parent = content
        pad(content, 0, 0, 0, 0)

        -- Возвращаем объект с методами для добавления элементов
        local sectionObj = {}
        
        -- ── Toggle (переключатель) ──────────────────────────────────
        -- Визуально: текст слева, ползунок справа.
        -- При клике меняет состояние с анимацией.
        function sectionObj:Toggle(config)
            local flag = config.flag or "toggle_" .. tostring(math.random(1000, 9999))
            local default = config.default or false
            local callback = config.callback or function() end

            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, 32)
            frame.BackgroundTransparency = 1
            frame.ZIndex = 11
            frame.Parent = content

            -- Текст
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, -60, 1, 0)
            label.BackgroundTransparency = 1
            label.Text = config.name or "Toggle"
            label.TextColor3 = Theme.Text
            label.TextSize = 15
            label.Font = Enum.Font.Gotham
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.ZIndex = 12
            label.Parent = frame

            -- Ползунок (фон)
            local pill = Instance.new("Frame")
            pill.Size = UDim2.new(0, 40, 0, 22)
            pill.Position = UDim2.new(1, -40, 0.5, -11)
            pill.AnchorPoint = Vector2.new(0, 0.5)
            pill.BackgroundColor3 = default and Theme.Accent or Color3.fromRGB(60, 70, 85)
            pill.BorderSizePixel = 0
            pill.ZIndex = 12
            pill.Parent = frame
            corner(pill, 11)

            -- Круглая ручка
            local knob = Instance.new("Frame")
            knob.Size = UDim2.new(0, 18, 0, 18)
            knob.Position = default and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
            knob.AnchorPoint = Vector2.new(0, 0.5)
            knob.BackgroundColor3 = Color3.new(1, 1, 1)
            knob.BorderSizePixel = 0
            knob.ZIndex = 13
            knob.Parent = pill
            corner(knob, 9)

            local state = default
            local function setState(v)
                state = v
                tween(pill, { BackgroundColor3 = state and Theme.Accent or Color3.fromRGB(60, 70, 85) }, 0.15)
                tween(knob, { Position = state and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9) }, 0.15)
                VoltageUI.Flags[flag] = state
                callback(state)
            end

            frame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    setState(not state)
                end
            end)

            setState(default)
            return { Set = setState, Get = function() return state end }
        end

        -- ── Slider (ползунок) ───────────────────────────────────────
        -- Визуально: текст сверху, значение справа, полоса снизу.
        -- Можно перетаскивать кружок или кликать на полосу.
        function sectionObj:Slider(config)
            local flag = config.flag or "slider_" .. tostring(math.random(1000, 9999))
            local min = config.min or 0
            local max = config.max or 100
            local default = config.default or 50
            local suffix = config.suffix or ""
            local decimals = config.decimals or 0
            local callback = config.callback or function() end

            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, 50)
            frame.BackgroundTransparency = 1
            frame.ZIndex = 11
            frame.Parent = content

            -- Текст
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, -80, 0, 20)
            label.BackgroundTransparency = 1
            label.Text = config.name or "Slider"
            label.TextColor3 = Theme.Text
            label.TextSize = 15
            label.Font = Enum.Font.Gotham
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.ZIndex = 12
            label.Parent = frame

            -- Значение
            local valLbl = Instance.new("TextLabel")
            valLbl.Size = UDim2.new(0, 70, 0, 20)
            valLbl.Position = UDim2.new(1, -70, 0, 0)
            valLbl.AnchorPoint = Vector2.new(1, 0)
            valLbl.BackgroundTransparency = 1
            valLbl.Text = tostring(default) .. suffix
            valLbl.TextColor3 = Theme.Accent
            valLbl.TextSize = 15
            valLbl.Font = Enum.Font.GothamBold
            valLbl.TextXAlignment = Enum.TextXAlignment.Right
            valLbl.ZIndex = 12
            valLbl.Parent = frame

            -- Полоса
            local track = Instance.new("Frame")
            track.Size = UDim2.new(1, 0, 0, 6)
            track.Position = UDim2.new(0, 0, 1, -6)
            track.BackgroundColor3 = Color3.fromRGB(40, 48, 58)
            track.BorderSizePixel = 0
            track.ZIndex = 12
            track.Parent = frame
            corner(track, 3)

            -- Заполнение полосы
            local fill = Instance.new("Frame")
            fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
            fill.BackgroundColor3 = Theme.Accent
            fill.BorderSizePixel = 0
            fill.ZIndex = 13
            fill.Parent = track
            corner(fill, 3)

            -- Кружок для перетаскивания
            local knob = Instance.new("TextButton")
            knob.Size = UDim2.new(0, 16, 0, 16)
            knob.Position = UDim2.new((default - min) / (max - min), -8, 0.5, -8)
            knob.AnchorPoint = Vector2.new(0, 0.5)
            knob.BackgroundColor3 = Color3.new(1, 1, 1)
            knob.BorderSizePixel = 0
            knob.ZIndex = 14
            knob.Text = ""
            knob.Parent = track
            corner(knob, 8)

            local dragging = false
            local function setValue(val)
                val = math.clamp(val, min, max)
                local alpha = (val - min) / (max - min)
                fill.Size = UDim2.new(alpha, 0, 1, 0)
                knob.Position = UDim2.new(alpha, -8, 0.5, -8)
                valLbl.Text = tostring(math.round(val * (10^decimals)) / (10^decimals)) .. suffix
                callback(val)
            end

            -- Обработка перетаскивания
            track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    local pos = input.Position.X - track.AbsolutePosition.X
                    local alpha = math.clamp(pos / track.AbsoluteSize.X, 0, 1)
                    setValue(min + alpha * (max - min))
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local pos = input.Position.X - track.AbsolutePosition.X
                    local alpha = math.clamp(pos / track.AbsoluteSize.X, 0, 1)
                    setValue(min + alpha * (max - min))
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)

            setValue(default)
            return { Set = setValue, Get = function() return val end }
        end

        -- ── Dropdown (выпадающий список) ─────────────────────────────
        -- При клике раскрывается список опций.
        -- Поддерживает поиск (можно добавить при необходимости).
        function sectionObj:Dropdown(config)
            local flag = config.flag or "dropdown_" .. tostring(math.random(1000, 9999))
            local items = config.items or {}
            local default = config.default or items[1]
            local callback = config.callback or function() end

            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, 38)
            frame.BackgroundTransparency = 1
            frame.ZIndex = 11
            frame.Parent = content

            -- Текст
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(0, 100, 0, 20)
            label.Position = UDim2.new(0, 0, 0, 0)
            label.BackgroundTransparency = 1
            label.Text = config.name or "Dropdown"
            label.TextColor3 = Theme.Text
            label.TextSize = 15
            label.Font = Enum.Font.Gotham
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.ZIndex = 12
            label.Parent = frame

            -- Само поле выбора
            local dropdown = Instance.new("TextButton")
            dropdown.Size = UDim2.new(1, -110, 0, 30)
            dropdown.Position = UDim2.new(0, 110, 0, 4)
            dropdown.BackgroundColor3 = Theme.Element
            dropdown.Text = ""
            dropdown.ZIndex = 12
            dropdown.Parent = frame
            corner(dropdown, 6)

            -- Текст выбранного значения
            local ddText = Instance.new("TextLabel")
            ddText.Size = UDim2.new(1, -30, 1, 0)
            ddText.Position = UDim2.new(0, 10, 0, 0)
            ddText.BackgroundTransparency = 1
            ddText.Text = default or "..."
            ddText.TextColor3 = Theme.Text
            ddText.TextSize = 15
            ddText.Font = Enum.Font.Gotham
            ddText.TextXAlignment = Enum.TextXAlignment.Left
            ddText.ZIndex = 13
            ddText.Parent = dropdown

            -- Стрелка вниз
            local arrow = Instance.new("TextLabel")
            arrow.Size = UDim2.new(0, 20, 1, 0)
            arrow.Position = UDim2.new(1, -20, 0, 0)
            arrow.BackgroundTransparency = 1
            arrow.Text = "⌄"
            arrow.TextColor3 = Theme.SubText
            arrow.TextSize = 18
            arrow.Font = Enum.Font.Gotham
            arrow.ZIndex = 13
            arrow.Parent = dropdown

            -- Список опций
            local list = Instance.new("Frame")
            list.Size = UDim2.new(1, 0, 0, 0)
            list.Position = UDim2.new(0, 0, 0, 34)
            list.BackgroundColor3 = Theme.Element
            list.Visible = false
            list.ZIndex = 15
            list.Parent = dropdown
            corner(list, 6)
            local listLayout = Instance.new("UIListLayout")
            listLayout.SortOrder = Enum.SortOrder.LayoutOrder
            listLayout.Padding = UDim.new(0, 2)
            listLayout.Parent = list

            local selected = default
            local function setSelected(val)
                selected = val
                ddText.Text = val
                callback(val)
            end

            -- Создаём опции
            for _, item in ipairs(items) do
                local opt = Instance.new("TextButton")
                opt.Size = UDim2.new(1, 0, 0, 30)
                opt.BackgroundTransparency = 1
                opt.Text = item
                opt.TextColor3 = Theme.Text
                opt.TextSize = 15
                opt.Font = Enum.Font.Gotham
                opt.TextXAlignment = Enum.TextXAlignment.Left
                opt.ZIndex = 16
                opt.Parent = list
                pad(opt, 8, 0, 8, 8)
                opt.MouseButton1Click:Connect(function()
                    setSelected(item)
                    list.Visible = false
                end)
            end

            -- Открытие/закрытие списка
            dropdown.MouseButton1Click:Connect(function()
                list.Visible = not list.Visible
                if list.Visible then
                    list.Size = UDim2.new(1, 0, 0, #items * 32)
                end
            end)

            setSelected(selected)
            return { Set = setSelected, Get = function() return selected end }
        end

        -- ── Button (кнопка) ──────────────────────────────────────────
        -- Простая кнопка с анимацией при нажатии.
        function sectionObj:Button(config)
            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, 36)
            frame.BackgroundTransparency = 1
            frame.ZIndex = 11
            frame.Parent = content

            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 1, 0)
            btn.BackgroundColor3 = Theme.Accent
            btn.Text = config.name or "Button"
            btn.TextColor3 = Color3.new(1, 1, 1)
            btn.TextSize = 16
            btn.Font = Enum.Font.GothamBold
            btn.ZIndex = 12
            btn.Parent = frame
            corner(btn, 6)

            btn.MouseEnter:Connect(function()
                tween(btn, { BackgroundColor3 = Color3.fromRGB(
                    Theme.Accent.R*255 + 20,
                    Theme.Accent.G*255 + 20,
                    Theme.Accent.B*255 + 20
                ) }, 0.15)
            end)
            btn.MouseLeave:Connect(function()
                tween(btn, { BackgroundColor3 = Theme.Accent }, 0.15)
            end)

            btn.MouseButton1Click:Connect(function()
                pcall(config.callback or function() end)
            end)
            return { Press = function() pcall(config.callback or function() end) end }
        end

        -- ── Colorpicker (выбор цвета) ───────────────────────────────
        -- При клике меняет цвет на случайный (для демонстрации).
        -- Можно доработать до полноценного пикера.
        function sectionObj:Colorpicker(config)
            local flag = config.flag or "color_" .. tostring(math.random(1000, 9999))
            local default = config.default or Color3.fromRGB(255, 255, 255)
            local callback = config.callback or function() end

            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, 36)
            frame.BackgroundTransparency = 1
            frame.ZIndex = 11
            frame.Parent = content

            -- Текст
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, -50, 1, 0)
            label.BackgroundTransparency = 1
            label.Text = config.name or "Color"
            label.TextColor3 = Theme.Text
            label.TextSize = 15
            label.Font = Enum.Font.Gotham
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.ZIndex = 12
            label.Parent = frame

            -- Превью цвета
            local preview = Instance.new("TextButton")
            preview.Size = UDim2.new(0, 30, 0, 30)
            preview.Position = UDim2.new(1, -30, 0.5, -15)
            preview.AnchorPoint = Vector2.new(0, 0.5)
            preview.BackgroundColor3 = default
            preview.Text = ""
            preview.ZIndex = 12
            preview.Parent = frame
            corner(preview, 6)

            local currentColor = default
            preview.MouseButton1Click:Connect(function()
                -- Для демонстрации: случайный цвет
                local r = math.random(0, 255)
                local g = math.random(0, 255)
                local b = math.random(0, 255)
                currentColor = Color3.fromRGB(r, g, b)
                preview.BackgroundColor3 = currentColor
                callback(currentColor)
            end)

            return { Set = function(c) currentColor = c; preview.BackgroundColor3 = c; callback(c) end,
                     Get = function() return currentColor end }
        end

        -- ── Keybind (привязка клавиш) ──────────────────────────────
        -- При клике ожидает нажатия клавиши.
        -- Поддерживает режимы: Toggle, Hold.
        function sectionObj:Keybind(config)
            local flag = config.flag or "keybind_" .. tostring(math.random(1000, 9999))
            local default = config.default or Enum.KeyCode.E
            local callback = config.callback or function() end
            local mode = config.mode or "Toggle"

            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, 36)
            frame.BackgroundTransparency = 1
            frame.ZIndex = 11
            frame.Parent = content

            -- Текст
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, -120, 1, 0)
            label.BackgroundTransparency = 1
            label.Text = config.name or "Keybind"
            label.TextColor3 = Theme.Text
            label.TextSize = 15
            label.Font = Enum.Font.Gotham
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.ZIndex = 12
            label.Parent = frame

            -- Поле с названием клавиши
            local keyBtn = Instance.new("TextButton")
            keyBtn.Size = UDim2.new(0, 100, 0, 30)
            keyBtn.Position = UDim2.new(1, -100, 0.5, -15)
            keyBtn.AnchorPoint = Vector2.new(0, 0.5)
            keyBtn.BackgroundColor3 = Theme.Element
            keyBtn.Text = tostring(default.Name)
            keyBtn.TextColor3 = Theme.Text
            keyBtn.TextSize = 15
            keyBtn.Font = Enum.Font.GothamBold
            keyBtn.ZIndex = 12
            keyBtn.Parent = frame
            corner(keyBtn, 6)

            local listening = false
            local currentKey = default
            local function setKey(key)
                currentKey = key
                keyBtn.Text = key.Name
                callback(key)
            end

            -- Ожидание нажатия клавиши
            keyBtn.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true
                keyBtn.Text = "..."
                local conn
                conn = UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        setKey(input.KeyCode)
                        listening = false
                        conn:Disconnect()
                    end
                end)
            end)

            -- Обработка нажатий
            local state = false
            UserInputService.InputBegan:Connect(function(input)
                if input.KeyCode == currentKey then
                    if mode == "Toggle" then
                        state = not state
                        callback(state)
                    elseif mode == "Hold" then
                        state = true
                        callback(true)
                    end
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.KeyCode == currentKey and mode == "Hold" then
                    state = false
                    callback(false)
                end
            end)

            return { Set = setKey, Get = function() return currentKey end }
        end

        -- ── Textbox (поле ввода) ─────────────────────────────────────
        -- Поле для ввода текста с заголовком.
        function sectionObj:Textbox(config)
            local flag = config.flag or "textbox_" .. tostring(math.random(1000, 9999))
            local default = config.default or ""
            local placeholder = config.placeholder or "Enter text..."
            local callback = config.callback or function() end

            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, 44)
            frame.BackgroundTransparency = 1
            frame.ZIndex = 11
            frame.Parent = content

            -- Заголовок
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, 0, 0, 20)
            label.BackgroundTransparency = 1
            label.Text = config.name or "Textbox"
            label.TextColor3 = Theme.Text
            label.TextSize = 15
            label.Font = Enum.Font.Gotham
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.ZIndex = 12
            label.Parent = frame

            -- Поле ввода
            local box = Instance.new("TextBox")
            box.Size = UDim2.new(1, 0, 0, 30)
            box.Position = UDim2.new(0, 0, 0, 22)
            box.BackgroundColor3 = Theme.Element
            box.Text = default
            box.PlaceholderText = placeholder
            box.TextColor3 = Theme.Text
            box.PlaceholderColor3 = Theme.SubText
            box.TextSize = 15
            box.Font = Enum.Font.Gotham
            box.TextXAlignment = Enum.TextXAlignment.Left
            box.ZIndex = 12
            box.Parent = frame
            corner(box, 6)
            pad(box, 8, 8, 8, 8)

            box.FocusLost:Connect(function()
                callback(box.Text)
            end)

            return { Set = function(t) box.Text = t; callback(t) end,
                     Get = function() return box.Text end }
        end

        -- ── Label (надпись) ──────────────────────────────────────────
        -- Простой текст, используется как заголовок или разделитель.
        function sectionObj:Label(config)
            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, 24)
            frame.BackgroundTransparency = 1
            frame.ZIndex = 11
            frame.Parent = content

            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(1, 0, 1, 0)
            lbl.BackgroundTransparency = 1
            lbl.Text = config.text or "Label"
            lbl.TextColor3 = Theme.SubText
            lbl.TextSize = 13
            lbl.Font = Enum.Font.Gotham
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.ZIndex = 12
            lbl.Parent = frame

            return { Set = function(t) lbl.Text = t end }
        end

        return sectionObj
    end

    -- Сохраняем ссылки
    self._main = main
    self._rightPanel = rightPanel
    
    return Window
end

