                        local pos = input.Position
                        local abs = AlphaBar.AbsolutePosition
                        local size = AlphaBar.AbsoluteSize
                        alphaVal = clamp((pos.X - abs.X) / size.X, 0, 1)
                        updateColor()
                    end
                end)
                
                updateColor()
                
                FlagSetters[flag] = function(c, a)
                    if c then
                        hue, sat, val = Color3.toHSV(c)
                        if a ~= nil then alphaVal = a end
                        updateColor()
                    end
                end
                
                return {
                    Set = function(c, a)
                        if c then
                            hue, sat, val = Color3.toHSV(c)
                            if a ~= nil then alphaVal = a end
                            updateColor()
                        end
