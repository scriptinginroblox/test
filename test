local function copyCharacterAppearance(fromCharacter, toCharacter)
    if not fromCharacter or not toCharacter then return end
    
    for _, part in ipairs(fromCharacter:GetChildren()) do
        if part:IsA('BasePart') or part:IsA('Accessory') or part:IsA('Shirt') or part:IsA('Pants') or part:IsA('Hat') then
            local newPart = part:Clone()
            newPart.Parent = toCharacter
        end
    end
    
    local fromHumanoid = fromCharacter:FindFirstChild('Humanoid')
    local toHumanoid = toCharacter:FindFirstChild('Humanoid')
    if fromHumanoid and toHumanoid then
        toHumanoid.WalkSpeed = fromHumanoid.WalkSpeed
        toHumanoid.JumpPower = fromHumanoid.JumpPower
        toHumanoid.MaxHealth = fromHumanoid.MaxHealth
        toHumanoid.Health = fromHumanoid.Health
    end
end

