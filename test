    topbar.BorderSizePixel = 0
    topbar.Parent = main.Instance
    
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, -100, 0, 16)
    title.Position = UDim2.new(0, 48, 0, 5)
    title.BackgroundTransparency = 1
    title.Text = window.Name
    title.TextColor3 = Library.Theme.Text
    title.Font = Enum.Font.GothamBold
    title.TextSize = 14
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Parent = topbar
    
    local subtitle = Instance.new("TextLabel")
    subtitle.Size = UDim2.new(1, -100, 0, 12)
    subtitle.Position = UDim2.new(0, 48, 0, 22)
    subtitle.BackgroundTransparency = 1
    subtitle.Text = window.Subtitle
    subtitle.TextColor3 = Library.Theme.TextDim
    subtitle.Font = Enum.Font.Gotham
    subtitle.TextSize = 10
    subtitle.TextXAlignment = Enum.TextXAlignment.Left
    subtitle.Parent = topbar
    
    local logo = Library:CreateIcon(window.Icon, UDim2.fromOffset(24, 24), Library.Theme.Accent)
    logo.AnchorPoint = Vector2.new(0, 0.5)
    logo.Position = UDim2.new(0, 12, 0.5, 0)
    logo.Parent = topbar
    
    local closeBtn = Instance.new("ImageButton")
    closeBtn.Size = UDim2.new(0, 18, 0, 18)
    closeBtn.Position = UDim2.new(1, -26, 0.5, -9)
    closeBtn.BackgroundTransparency = 1
    closeBtn.Image = Library:GetIcon("Close")
    closeBtn.ImageColor3 = Library.Theme.TextDim
    closeBtn.Parent = topbar
    closeBtn.MouseEnter:Connect(function()
        Library:Tween(closeBtn, { ImageColor3 = Library.Theme.Text })
    end)
    closeBtn.MouseLeave:Connect(function()
        Library:Tween(closeBtn, { ImageColor3 = Library.Theme.TextDim })
    end)
    
    local minBtn = Instance.new("ImageButton")
    minBtn.Size = UDim2.new(0, 16, 0, 16)
    minBtn.Position = UDim2.new(1, -52, 0.5, -8)
    minBtn.BackgroundTransparency = 1
    minBtn.Image = Library:GetIcon("Minimize")
    minBtn.ImageColor3 = Library.Theme.TextDim
    minBtn.Parent = topbar
    minBtn.MouseEnter:Connect(function()
        Library:Tween(minBtn, { ImageColor3 = Library.Theme.Text })
    end)
    minBtn.MouseLeave:Connect(function()
        Library:Tween(minBtn, { ImageColor3 = Library.Theme.TextDim })
    end)
    
    local divider = Instance.new("Frame")
    divider.Position = UDim2.new(0, 0, 1, 0)
    divider.Size = UDim2.new(1, 0, 0, 1)
    divider.BackgroundColor3 = Library.Theme.Border
    divider.BorderSizePixel = 0
    divider.Parent = topbar
    
    local sideBar = Instance.new("Frame")
    sideBar.Size = UDim2.new(0, 45, 1, -36)
    sideBar.Position = UDim2.new(0, 0, 0, 36)
    sideBar.BackgroundColor3 = Library.Theme.Surface
    sideBar.BorderSizePixel = 0
    sideBar.Parent = main.Instance
    
    local sideDivider = Instance.new("Frame")
    sideDivider.Position = UDim2.new(1, 0, 0, 0)
    sideDivider.Size = UDim2.new(0, 1, 1, 0)
    sideDivider.BackgroundColor3 = Library.Theme.Border
    sideDivider.BorderSizePixel = 0
    sideDivider.Parent = sideBar
    
    local tabList = Instance.new("Frame")
    tabList.Size = UDim2.new(1, 0, 1, 0)
    tabList.BackgroundTransparency = 1
    tabList.Parent = sideBar
    
    local tabLayout = Instance.new("UIListLayout")
    tabLayout.Padding = UDim.new(0, 4)
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabLayout.Parent = tabList
    
    local contentArea = Instance.new("Frame")
    contentArea.Size = UDim2.new(1, -45, 1, -36)
    contentArea.Position = UDim2.new(0, 45, 0, 36)
    contentArea.BackgroundTransparency = 1
    contentArea.Parent = main.Instance
    
    local pages = {}
    local activePage = nil
    
    local function createTabButton(page)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 36)
        btn.BackgroundTransparency = 1
        btn.Text = ""
        btn.AutoButtonColor = false
        btn.Parent = tabList
        
        local icon = Library:CreateIcon(page._icon or "Home", UDim2.fromOffset(20, 20), Library.Theme.TextDim)
        icon.Position = UDim2.new(0.5, 0, 0.5, 0)
        icon.Parent = btn
        
        btn.MouseEnter:Connect(function()
            if page ~= activePage then
                Library:Tween(icon, { ImageColor3 = Library.Theme.Text })
            end
        end)
        btn.MouseLeave:Connect(function()
            if page ~= activePage then
                Library:Tween(icon, { ImageColor3 = Library.Theme.TextDim })
            end
        end)
        btn.MouseButton1Click:Connect(function()
            for _, p in pairs(pages) do
                p._frame.Instance.Visible = false
                p._btn.ImageColor3 = Library.Theme.TextDim
            end
            page._frame.Instance.Visible = true
            activePage = page
            Library:Tween(page._btn, { ImageColor3 = Library.Theme.Accent })
        end)
        
        page._btn = icon
        return btn
    end
    
    function window:Page(data)
        data.Parent = contentArea
        local page = Library:Page(data)
        page._icon = data.Icon or "Home"
        page._frame = page._frame or frame
        page._btn = nil
        table.insert(pages, page)
        createTabButton(page)
        if not activePage then
            page._frame.Instance.Visible = true
            activePage = page
            Library:Tween(page._btn, { ImageColor3 = Library.Theme.Accent })
        end
        return page
    end
    
    function window:SetOpen(open)
        window.Open = open
        main.Instance.Visible = open
    end
    
    function window:Toggle()
        window:SetOpen(not window.Open)
    end
    
    closeBtn.MouseButton1Click:Connect(function()
        window:SetOpen(false)
    end)
    
    minBtn.MouseButton1Click:Connect(function()
        window:SetOpen(false)
    end)
    
    UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == window.Keybind then
            window:Toggle()
        end
    end)
    
    -- Drag
    local dragging, dragStart, startPos
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = main.Instance.Position
        end
    end)
    topbar.InputEnded:Connect(function()
        dragging = false
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            main.Instance.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    -- Resize
    local resizeHandle = Instance.new("Frame")
    resizeHandle.Size = UDim2.new(0, 12, 0, 12)
    resizeHandle.Position = UDim2.new(1, -12, 1, -12)
    resizeHandle.AnchorPoint = Vector2.new(1, 1)
    resizeHandle.BackgroundTransparency = 1
    resizeHandle.Parent = main.Instance
    
    local resizeIcon = Library:CreateIcon("ChevronRight", UDim2.fromOffset(8, 8), Library.Theme.TextDim)
    resizeIcon.Position = UDim2.new(0.5, 0, 0.5, 0)
    resizeIcon.Rotation = -45
    resizeIcon.Parent = resizeHandle
    
    local resizing, resizeStart, resizeSize
    resizeHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            resizing = true
            resizeStart = input.Position
            resizeSize = main.Instance.Size
        end
    end)
    resizeHandle.InputEnded:Connect(function()
        resizing = false
    end)
    UserInputService.InputChanged:Connect(function(input)
        if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - resizeStart
            local newW = math.max(resizeSize.X.Offset + delta.X, window.MinSize.X)
            local newH = math.max(resizeSize.Y.Offset + delta.Y, window.MinSize.Y)
            main.Instance.Size = UDim2.new(0, newW, 0, newH)
        end
    end)
    
    window._main = main
    window._pages = pages
    
    return window
end

