                PaddingBottom = UDim.new(0, 4),
                PaddingLeft = UDim.new(0, 4),
                PaddingRight = UDim.new(0, 4),
            })

            local Options = {}

            function Element:UpdateMenu()
                for _, Child in pairs(MenuList.Instance:GetChildren()) do
                    if Child:IsA("TextButton") then Child:Destroy() end
                end
                Options = {}

                for _, Item in pairs(Element.Items) do
                    local Option = Library:Create("TextButton", {
                        Parent = MenuList.Instance,
                        Size = UDim2.new(1, 0, 0, 28),
                        BackgroundColor3 = Theme.Background2,
                        BackgroundTransparency = 1,
                        BorderSizePixel = 0,
                        Text = Item,
                        TextColor3 = Theme.TextDim,
                        FontFace = Library.Font,
                        TextSize = 13,
                        TextXAlignment = Enum.TextXAlignment.Left,
                    })

                    Library:Create("UICorner", {
                        Parent = Option.Instance,
                        CornerRadius = UDim.new(0, 4),
                    })

                    Library:Create("UIPadding", {
                        Parent = Option.Instance,
                        PaddingLeft = UDim.new(0, 10),
                    })

                    local Check = Library:Create("ImageLabel", {
                        Parent = Option.Instance,
                        AnchorPoint = Vector2.new(1, 0.5),
                        Position = UDim2.new(1, -8, 0.5, 0),
                        Size = UDim2.new(0, 12, 0, 12),
                        BackgroundTransparency = 1,
                        Image = Icons.check,
                        ImageColor3 = Theme.Accent1,
                        ImageTransparency = 1,
                    })

                    Option.Instance.MouseEnter:Connect(function()
                        Option.Instance.BackgroundColor3 = Theme.ElementHover
                        Option.Instance.BackgroundTransparency = 0
                    end)

                    Option.Instance.MouseLeave:Connect(function()
                        Option.Instance.BackgroundColor3 = Theme.Background2
                        Option.Instance.BackgroundTransparency = 1
                    end)

                    Option.Instance.MouseButton1Click:Connect(function()
                        Element.Value = {Item}
                        for _, Opt in pairs(Options) do Opt.Check.ImageTransparency = 1 end
                        Check.ImageTransparency = 0
                        Element:CloseMenu()
                        Element:UpdateDisplay()
                        Library.SafeCall(Element.Callback, Item)
                    end)

                    table.insert(Options, {
                        Instance = Option,
                        Check = Check,
                        Item = Item,
                    })
                end

                for _, Opt in pairs(Options) do
                    if table.find(Element.Value, Opt.Item) then
                        Opt.Check.ImageTransparency = 0
                    end
                end
            end

            function Element:UpdateDisplay()
                Display.Text = Element.Value[1] or "Select..."
            end

            function Element:OpenMenu()
                Element.IsOpen = true
                local Pos = Display.Instance.AbsolutePosition
                Menu.Instance.Position = UDim2.new(0, Pos.X, 0, Pos.Y + Display.Instance.AbsoluteSize.Y + 4)
                Menu.Instance.Size = UDim2.new(0, Display.Instance.AbsoluteSize.X, 0, 0)
                Menu.Instance.Visible = true
                Menu.Instance.Size = UDim2.new(0, Display.Instance.AbsoluteSize.X, 0, math.min(MenuList.Instance.AbsoluteContentSize.Y + 8, 150))
                Arrow.Rotation = 180
            end

            function Element:CloseMenu()
                Element.IsOpen = false
                Menu.Instance.Size = UDim2.new(0, Display.Instance.AbsoluteSize.X, 0, 0)
                Menu.Instance.Visible = false
                Arrow.Rotation = 0
            end

            function Element:ToggleMenu()
                if Element.IsOpen then Element:CloseMenu() else Element:OpenMenu() end
            end

            Display.Instance.MouseButton1Click:Connect(function() Element:ToggleMenu() end)

            Library:Connect(UserInputService.InputBegan, function(Input)
                if Element.IsOpen and (Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch) then
                    if not Library:IsMouseOver(Menu.Instance) and not Library:IsMouseOver(Display.Instance) then
                        Element:CloseMenu()
                    end
                end
            end)

            Element:UpdateMenu()
            if Element.Default then Element.Value = {Element.Default} end
            Element:UpdateDisplay()

            Element.Instance = Container.Instance
            Library.Elements[Element.Flag] = Element
            Library.ConfigFlags[Element.Flag] = function(Value)
                Element.Value = {Value}
                Element:UpdateDisplay()
                Element:UpdateMenu()
                Library.SafeCall(Element.Callback, Value)
            end

            return Element
        end

        -- INPUT
        function Window:Input(Params)
            Params = Params or {}

            local Element = {
                Name = Params.Name or "Input",
                Flag = Params.Flag or "Input_" .. tostring(#Library.Elements + 1),
                Default = Params.Default or "",
                Placeholder = Params.Placeholder or "Type here...",
                Callback = Params.Callback or function() end,
                Numeric = Params.Numeric or false,
            }

            local Container = Library:Create("Frame", {
                Size = UDim2.new(1, 0, 0, 44),
                BackgroundTransparency = 1,
                BorderSizePixel = 0,
            })

            local Label = Library:Create("TextLabel", {
                Parent = Container.Instance,
                Text = Element.Name,
                FontFace = Library.Font,
                TextSize = 14,
                TextColor3 = Theme.Text,
                Position = UDim2.new(0, 0, 0, 0),
                BackgroundTransparency = 1,
            })

            local Input = Library:Create("TextBox", {
                Parent = Container.Instance,
                AnchorPoint = Vector2.new(0, 1),
                Position = UDim2.new(0, 0, 1, -2),
                Size = UDim2.new(1, 0, 0, 26),
                BackgroundColor3 = Theme.Element,
                BorderSizePixel = 0,
                Text = Element.Default,
                TextColor3 = Theme.Text,
                FontFace = Library.Font,
                TextSize = 14,
                PlaceholderText = Element.Placeholder,
                PlaceholderColor3 = Theme.TextDark,
                TextXAlignment = Enum.TextXAlignment.Left,
                ClearTextOnFocus = false,
            })

            Library:Create("UICorner", {
                Parent = Input.Instance,
                CornerRadius = UDim.new(0, 6),
            })

            Library:Create("UIPadding", {
                Parent = Input.Instance,
                PaddingLeft = UDim.new(0, 12),
            })

            Input.Instance:GetPropertyChangedSignal("Text"):Connect(function()
                local Value = Input.Text
                if Element.Numeric and Value ~= "" then
                    if not tonumber(Value) then
                        Input.Text = Element.Value or ""
                        return
                    end
                end
                Element.Value = Value
                Library.Flags[Element.Flag] = Value
                Library.SafeCall(Element.Callback, Value)
            end)

            Input.Instance.FocusLost:Connect(function()
                if Element.Numeric and Input.Text ~= "" then
                    Input.Text = tostring(tonumber(Input.Text))
                end
            end)

            Element.Instance = Container.Instance
            Library.Elements[Element.Flag] = Element
            Library.ConfigFlags[Element.Flag] = function(Value)
                Input.Text = tostring(Value)
            end

            return Element
        end

        -- LABEL
        function Window:Label(Params)
            Params = Params or {}

            local Element = {
