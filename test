local Utilities = {}

function Utilities:Clamp(v, min, max) return math.max(min, math.min(max, v)) end
function Utilities:Lerp(a, b, t) return a + (b - a) * t end
function Utilities:Round(num, decimals)
    local mult = 10 ^ (decimals or 0)
    return math.floor(num * mult + 0.5) / mult
end

function Utilities:HexToRGB(hex)
    hex = hex:gsub("#", "")
    return Color3.fromRGB(
        tonumber(hex:sub(1,2), 16) or 0,
        tonumber(hex:sub(3,4), 16) or 0,
        tonumber(hex:sub(5,6), 16) or 0
    )
end

function Utilities:RGBToHex(color)
    return string.format("#%02X%02X%02X",
        math.floor(color.R * 255),
        math.floor(color.G * 255),
        math.floor(color.B * 255)
    )
end

function Utilities:IsMouseOver(frame)
    if not frame then return false end
    local pos = frame.AbsolutePosition
    local size = frame.AbsoluteSize
    return Mouse.X >= pos.X and Mouse.X <= pos.X + size.X
        and Mouse.Y >= pos.Y and Mouse.Y <= pos.Y + size.Y
end

function Utilities:Corner(frame, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = frame
    return c
end

function Utilities:Stroke(frame, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Color = color or Color3.fromRGB(50, 50, 50)
    s.Thickness = thickness or 1
    s.Transparency = transparency or 0
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = frame
    return s
end

function Utilities:Padding(frame, top, right, bottom, left)
    local p = Instance.new("UIPadding")
    p.PaddingTop = UDim.new(0, top or 0)
    p.PaddingRight = UDim.new(0, right or 0)
    p.PaddingBottom = UDim.new(0, bottom or 0)
    p.PaddingLeft = UDim.new(0, left or 0)
    p.Parent = frame
    return p
end

function Utilities:ListLayout(frame, padding, direction, alignment)
    local l = Instance.new("UIListLayout")
    l.Padding = UDim.new(0, padding or 5)
    l.SortOrder = Enum.SortOrder.LayoutOrder
    if direction then l.FillDirection = direction end
    if alignment then l.HorizontalAlignment = alignment end
    l.Parent = frame
    return l
end

function Utilities:GridLayout(frame, cellSize, padding)
    local g = Instance.new("UIGridLayout")
    g.CellSize = cellSize or UDim2.fromOffset(100, 30)
    g.CellPadding = padding or UDim2.fromOffset(5, 5)
    g.SortOrder = Enum.SortOrder.LayoutOrder
    g.Parent = frame
    return g
end

function Utilities:Tween(obj, props, time, style, dir)
    local t = Services.Tween:Create(obj,
        TweenInfo.new(time or 0.2, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props
    )
    t:Play()
    return t
end

function Utilities:TweenInfo(time, style, dir, repeats, reverse, delay)
    return TweenInfo.new(
        time or 0.2,
        style or Enum.EasingStyle.Quad,
        dir or Enum.EasingDirection.Out,
        repeats or 0,
        reverse or false,
        delay or 0
    )
end

function Utilities:GetTweenProperties(obj)
    if obj:IsA("Frame") then
        return {"BackgroundTransparency"}
    elseif obj:IsA("TextLabel") or obj:IsA("TextButton") then
        return {"TextTransparency", "BackgroundTransparency"}
    elseif obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
        return {"BackgroundTransparency", "ImageTransparency"}
    elseif obj:IsA("ScrollingFrame") then
        return {"BackgroundTransparency", "ScrollBarImageTransparency"}
    elseif obj:IsA("TextBox") then
        return {"TextTransparency", "BackgroundTransparency"}
    elseif obj:IsA("UIStroke") then
        return {"Transparency"}
    end
    return {}
end

function Utilities:Fade(obj, property, visible, speed)
    local old = obj[property]
    obj[property] = visible and 1 or old
    local t = Utilities:Tween(obj, {[property] = visible and old or 1}, speed or 0.2)
    t.Completed:Connect(function()
        if not visible then obj[property] = old end
    end)
    return t
end

function Utilities:FadeDescendants(frame, visible, speed, callback)
    if visible then frame.Visible = true end
    local children = frame:GetDescendants()
    table.insert(children, frame)
    local lastTween
    for _, child in ipairs(children) do
        local props = Utilities:GetTweenProperties(child)
        for _, prop in ipairs(props) do
            lastTween = Utilities:Fade(child, prop, visible, speed)
        end
    end
    if lastTween then
        lastTween.Completed:Connect(function()
            frame.Visible = visible
            if callback then callback() end
        end)
    else
        frame.Visible = visible
        if callback then callback() end
    end
end

function Utilities:MakeDraggable(frame)
    local dragging = false
    local dragStart, startPos
    
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    
    Services.UserInput.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    Services.UserInput.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

function Utilities:MakeResizeable(frame, minSize)
    local resizing = false
    local startMouse, startSize
    
    local handle = Instance.new("TextButton")
    handle.Size = UDim2.new(0, 12, 0, 12)
    handle.Position = UDim2.new(1, -12, 1, -12)
    handle.AnchorPoint = Vector2.new(1, 1)
    handle.BackgroundTransparency = 1
    handle.Text = ""
    handle.AutoButtonColor = false
    handle.Parent = frame
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = true
            startMouse = input.Position
            startSize = frame.Size
        end
    end)
    
    Services.UserInput.InputChanged:Connect(function(input)
        if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - startMouse
            local newW = math.max(minSize and minSize.X or 200, startSize.X.Offset + delta.X)
            local newH = math.max(minSize and minSize.Y or 150, startSize.Y.Offset + delta.Y)
            frame.Size = UDim2.new(0, newW, 0, newH)
        end
    end)
    
    Services.UserInput.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = false
        end
    end)
end

function Utilities:SafeCall(func, ...)
    local args = {...}
    local success, result = pcall(func, table.unpack(args))
    if not success then
        warn("[VoltageHub] Error: " .. tostring(result))
    end
    return success, result
end

function Utilities:Thread(func)
    local thread = coroutine.create(func)
    coroutine.wrap(function() coroutine.resume(thread) end)()
    return thread
end

function Utilities:Connect(signal, callback)
    return signal:Connect(callback)
end

