                    if multi then
                        if selectedMulti[item] then
                            selectedMulti[item] = nil
                        else
                            selectedMulti[item] = true
                        end
                        local list = {}
                        for k, v in pairs(selectedMulti) do
                            if v then table.insert(list, k) end
                        end
                        ValueLabel.Text = #list > 0 and table.concat(list, ", ") or "None"
                        Flags[flag] = list
                        if fire then pcall(callback, list) end
                    else
                        selected = item
                        ValueLabel.Text = tostring(item)
                        Flags[flag] = item
                        if fire then pcall(callback, item) end
                        closeList()
                    end
                end
                
                for _, item in ipairs(items) do
                    local itemFrame = Instance.new("TextButton")
                    itemFrame.Size = UDim2.new(1, -8, 0, 28)
                    itemFrame.Position = UDim2.new(0, 4, 0, 0)
                    itemFrame.BackgroundTransparency = 1
