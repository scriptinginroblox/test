                    Parent = Header.Instance,
                    Size = UDim2.new(0, 8, 0, 8),
                    Position = UDim2.new(1, -16, 0.5, 0),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    BackgroundColor3 = Theme.Accent1,
                    BorderSizePixel = 0,
                })
                Library:Create("UICorner", {
                    Parent = PulseDot.Instance,
                    CornerRadius = UDim.new(1, 0),
                })
                Library:AddPulse(PulseDot, 0.3)

                -- Контент секции
                local Content = Library:Create("Frame", {
                    Parent = Section.Instance,
                    Position = UDim2.new(0, 0, 0, 36),
                    Size = UDim2.new(1, 0, 0, 0),
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    AutomaticSize = Enum.AutomaticSize.Y,
                })

                Library:Create("UIListLayout", {
                    Parent = Content.Instance,
                    Padding = UDim.new(0, 4),
                    SortOrder = Enum.SortOrder.LayoutOrder,
                })

                Library:Create("UIPadding", {
                    Parent = Content.Instance,
                    PaddingBottom = UDim.new(0, 10),
                    PaddingTop = UDim.new(0, 4),
                    PaddingLeft = UDim.new(0, 12),
                    PaddingRight = UDim.new(0, 12),
                })

                return {
                    Instance = Section,
                    Content = Content,
                    Add = function(self, Element)
                        if Element and Element.Instance then
                            Element.Instance.Parent = Content.Instance
                        end
                        return Element
                    end
                }
            end

            -- Метод для добавления Toggle
            function Tab:Toggle(Params)
                Params = Params or {}

                local Container = Library:Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 32),
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                })

                local Label = Library:Create("TextLabel", {
                    Parent = Container.Instance,
                    Text = Params.Name or "Toggle",
                    FontFace = Library.Font,
                    TextSize = 14,
                    TextColor3 = Theme.Text,
                    Position = UDim2.new(0, 0, 0.5, 0),
                    AnchorPoint = Vector2.new(0, 0.5),
                    BackgroundTransparency = 1,
                })

                local Track = Library:Create("TextButton", {
                    Parent = Container.Instance,
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, 0, 0.5, 0),
                    Size = UDim2.new(0, 40, 0, 22),
                    BackgroundColor3 = Theme.Element,
                    BorderSizePixel = 0,
                })

                Library:Create("UICorner", {
                    Parent = Track.Instance,
                    CornerRadius = UDim.new(1, 0),
                })

                local Knob = Library:Create("Frame", {
                    Parent = Track.Instance,
                    Size = UDim2.new(0, 16, 0, 16),
                    Position = UDim2.new(0, 3, 0.5, -8),
                    BackgroundColor3 = Theme.TextDim,
                    BorderSizePixel = 0,
                })

                Library:Create("UICorner", {
                    Parent = Knob.Instance,
                    CornerRadius = UDim.new(1, 0),
                })

                local Value = Params.Default or false
                local Element = {
                    Instance = Container.Instance,
                    Set = function(State)
                        Value = State
                        if State then
                            Track.Instance.BackgroundColor3 = Theme.Accent1
                            Knob.Instance.Position = UDim2.new(1, -19, 0.5, -8)
                            Knob.Instance.BackgroundColor3 = Theme.Text
                        else
                            Track.Instance.BackgroundColor3 = Theme.Element
                            Knob.Instance.Position = UDim2.new(0, 3, 0.5, -8)
                            Knob.Instance.BackgroundColor3 = Theme.TextDim
                        end
                        Library.SafeCall(Params.Callback, State)
                    end,
                    Get = function() return Value end,
                }

                Track.Instance.MouseButton1Click:Connect(function()
                    Element:Set(not Value)
                end)

                Element:Set(Value)
                return Element
            end

            -- Метод для добавления Slider
            function Tab:Slider(Params)
                Params = Params or {}

                local Container = Library:Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 44),
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                })

                local Label = Library:Create("TextLabel", {
                    Parent = Container.Instance,
                    Text = Params.Name or "Slider",
                    FontFace = Library.Font,
                    TextSize = 14,
                    TextColor3 = Theme.Text,
                    Position = UDim2.new(0, 0, 0, 0),
                    BackgroundTransparency = 1,
                })

                local ValueLabel = Library:Create("TextLabel", {
                    Parent = Container.Instance,
                    Text = tostring(Params.Default or 50) .. (Params.Suffix or ""),
                    FontFace = Library.FontBold,
                    TextSize = 14,
                    TextColor3 = Theme.Accent1,
                    AnchorPoint = Vector2.new(1, 0),
                    Position = UDim2.new(1, 0, 0, 0),
                    BackgroundTransparency = 1,
                })

                local Track = Library:Create("TextButton", {
                    Parent = Container.Instance,
                    AnchorPoint = Vector2.new(0, 1),
                    Position = UDim2.new(0, 0, 1, -4),
                    Size = UDim2.new(1, 0, 0, 4),
                    BackgroundColor3 = Theme.Element,
                    BorderSizePixel = 0,
                })

                Library:Create("UICorner", {
                    Parent = Track.Instance,
                    CornerRadius = UDim.new(1, 0),
                })

                local Fill = Library:Create("Frame", {
                    Parent = Track.Instance,
                    Size = UDim2.new(0.5, 0, 1, 0),
                    BackgroundColor3 = Theme.Accent1,
                    BorderSizePixel = 0,
                })
                Library:Create("UICorner", {
                    Parent = Fill.Instance,
                    CornerRadius = UDim.new(1, 0),
                })

                local Knob = Library:Create("Frame", {
                    Parent = Track.Instance,
                    Size = UDim2.new(0, 12, 0, 12),
                    Position = UDim2.new(0.5, -6, 0.5, -6),
                    BackgroundColor3 = Theme.Accent1,
                    BorderSizePixel = 0,
                })
                Library:Create("UICorner", {
                    Parent = Knob.Instance,
                    CornerRadius = UDim.new(1, 0),
                })

                local Value = Params.Default or 50
                local Sliding = false

                local Element = {
                    Instance = Container.Instance,
                    Set = function(NewValue)
                        Value = math.clamp(NewValue, Params.Min or 0, Params.Max or 100)
                        local Percent = (Value - (Params.Min or 0)) / ((Params.Max or 100) - (Params.Min or 0))
                        Fill.Instance.Size = UDim2.new(Percent, 0, 1, 0)
                        Knob.Instance.Position = UDim2.new(Percent, -6, 0.5, -6)
                        ValueLabel.Text = tostring(Value) .. (Params.Suffix or "")
                        Library.SafeCall(Params.Callback, Value)
                    end,
                    Get = function() return Value end,
                }

                Track.Instance.InputBegan:Connect(function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                        Sliding = true
                        local X = (Input.Position.X - Track.Instance.AbsolutePosition.X) / Track.Instance.AbsoluteSize.X
                        local NewValue = (Params.Min or 0) + ((Params.Max or 100) - (Params.Min or 0)) * math.clamp(X, 0, 1)
                        Element:Set(NewValue)
                    end
                end)

                Library:Connect(UserInputService.InputEnded, function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                        Sliding = false
                    end
                end)

                Library:Connect(UserInputService.InputChanged, function(Input)
                    if Sliding and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                        local X = (Input.Position.X - Track.Instance.AbsolutePosition.X) / Track.Instance.AbsoluteSize.X
                        local NewValue = (Params.Min or 0) + ((Params.Max or 100) - (Params.Min or 0)) * math.clamp(X, 0, 1)
                        Element:Set(NewValue)
                    end
                end)

                Element:Set(Value)
                return Element
            end

            -- Метод для добавления Button
            function Tab:Button(Params)
                Params = Params or {}

                local Container = Library:Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 32),
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                })

                local Button = Library:Create("TextButton", {
                    Parent = Container.Instance,
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundColor3 = Theme.Element,
                    BorderSizePixel = 0,
                    Text = Params.Name or "Button",
                    TextColor3 = Theme.Text,
                    FontFace = Library.FontBold,
                    TextSize = 14,
                })

                Library:Create("UICorner", {
                    Parent = Button.Instance,
                    CornerRadius = UDim.new(0, 6),
                })

                Button.Instance.MouseEnter:Connect(function()
                    Button.Instance.BackgroundColor3 = Theme.ElementHover
                end)

                Button.Instance.MouseLeave:Connect(function()
                    Button.Instance.BackgroundColor3 = Theme.Element
                end)

                Button.Instance.MouseButton1Click:Connect(function()
                    Button.Instance.BackgroundColor3 = Theme.Accent2
                    task.wait(0.08)
                    Button.Instance.BackgroundColor3 = Theme.Element
                    Library.SafeCall(Params.Callback)
                end)

                return Container
            end

            -- Метод для добавления Label
            function Tab:Label(Params)
                Params = Params or {}

                local Container = Library:Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 22),
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                })

                local Label = Library:Create("TextLabel", {
                    Parent = Container.Instance,
                    Text = Params.Name or "",
                    FontFace = Params.Bold and Library.FontBold or Library.Font,
                    TextSize = Params.Size or 14,
                    TextColor3 = Params.Dim and Theme.TextDim or Theme.Text,
                    Position = UDim2.new(0, 0, 0.5, 0),
                    AnchorPoint = Vector2.new(0, 0.5),
                    BackgroundTransparency = 1,
                })

                return Container
            end

            if not Window.Tabs then Window.Tabs = {} end
            table.insert(Window.Tabs, Tab)

            if #Window.Tabs == 1 then
                Tab:Activate()
            end

            return Tab
        end

        Library:Connect(UserInputService.InputBegan, function(Input)
            if Input.KeyCode == Library.MenuKeybind and not UserInputService:GetFocusedTextBox() then
                Library:Toggle()
            end
        end)

        Library.Window = Window
        return Window
    end

    getgenv().PulseUI = Library
    return Library
end
