function Library:ApplyTheme(themeName)
    local theme = PresetThemes[themeName]
    if not theme then return end
    
    for key, value in pairs(theme) do
        self.Theme[key] = value
        self:RefreshTheme(key, value)
    end
    self.CurrentTheme = themeName
end

function Library:RefreshTheme(themeKey, color)
    for _, item in pairs(self.ThemeItems) do
        if item.Properties then
            for prop, val in pairs(item.Properties) do
                if val == themeKey then
                    item.Item[prop] = color
                end
            end
        end
    end
end

function Library:AddToTheme(item, properties)
    item = item.Instance or item
    local data = { Item = item, Properties = properties }
    for prop, val in pairs(properties) do
        if type(val) == "string" then
            item[prop] = self.Theme[val]
        else
            item[prop] = val()
        end
    end
    table.insert(self.ThemeItems, data)
    self.ThemeMap[item] = data
    return item
end

