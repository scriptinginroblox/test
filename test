--  СПИДХАК
-- ═══════════════════════════════════════════════════════════════════════════════

local SpeedHack = {
    Enabled = false,
    Speed = 50,
    OldSpeed = nil,
    Humanoid = nil,
}

local function GetCharacter()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        return char
    end
    return nil
end

function SpeedHack:Enable()
    if self.Enabled then return end
    
    local char = GetCharacter()
    if not char then return end
    
    self.Humanoid = char:FindFirstChild("Humanoid")
    if not self.Humanoid then return end
    
    self.OldSpeed = self.Humanoid.WalkSpeed
    self.Enabled = true
    self.Humanoid.WalkSpeed = self.Speed
    
    -- Уведомление
    local notif = Instance.new("TextLabel")
    notif.Size = UDim2.new(0, 250, 0, 35)
    notif.Position = UDim2.new(0.5, -125, 1, -50)
    notif.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
    notif.Text = "⚡ Спидхак включен! Скорость: " .. self.Speed
    notif.TextColor3 = Color3.fromRGB(100, 255, 150)
    notif.Font = Enum.Font.Gotham
    notif.TextSize = 14
    notif.Parent = gui
    Corner(notif, 8)
    
    task.delay(2, function() notif:Destroy() end)
end

function SpeedHack:Disable()
    if not self.Enabled then return end
    
    if self.Humanoid and self.OldSpeed then
        self.Humanoid.WalkSpeed = self.OldSpeed
    end
    
    self.Enabled = false
    self.OldSpeed = nil
    
    local notif = Instance.new("TextLabel")
    notif.Size = UDim2.new(0, 200, 0, 35)
    notif.Position = UDim2.new(0.5, -100, 1, -50)
    notif.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
    notif.Text = "⚡ Спидхак выключен"
    notif.TextColor3 = Color3.fromRGB(255, 150, 150)
    notif.Font = Enum.Font.Gotham
    notif.TextSize = 14
    notif.Parent = gui
    Corner(notif, 8)
    
    task.delay(2, function() notif:Destroy() end)
end

function SpeedHack:Toggle()
    if self.Enabled then
        self:Disable()
    else
        self:Enable()
    end
end

function SpeedHack:SetSpeed(newSpeed)
    self.Speed = newSpeed
    if self.Enabled and self.Humanoid then
        self.Humanoid.WalkSpeed = self.Speed
    end
end

-- Авто-восстановление
LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    if SpeedHack.Enabled then
        SpeedHack:Disable()
        task.wait(0.1)
        SpeedHack.Humanoid = char:FindFirstChild("Humanoid")
        SpeedHack:Enable()
    end
end)

