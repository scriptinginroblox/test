        frame.Size = UDim2.new(1, 0, 0, 36)
        frame.BackgroundTransparency = 1
        frame.ZIndex = 11
        frame.Parent = content

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, -120, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = config.name or "Keybind"
        label.TextColor3 = VoltageUI.Theme.Text
        label.TextSize = 15
        label.Font = Enum.Font.Gotham
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.ZIndex = 12
        label.Parent = frame

        local keyBtn = Instance.new("TextButton")
        keyBtn.Size = UDim2.new(0, 100, 0, 30)
        keyBtn.Position = UDim2.new(1, -100, 0.5, -15)
        keyBtn.AnchorPoint = Vector2.new(0, 0.5)
        keyBtn.BackgroundColor3 = VoltageUI.Theme.Element
        keyBtn.Text = tostring(default.Name)
        keyBtn.TextColor3 = VoltageUI.Theme.Text
        keyBtn.TextSize = 15
        keyBtn.Font = Enum.Font.GothamBold
        keyBtn.ZIndex = 12
        keyBtn.Parent = frame
        corner(keyBtn, 6)

        local listening = false
        local currentKey = default
        local function setKey(key)
            currentKey = key
            keyBtn.Text = key.Name
            VoltageUI.Flags[flag] = key
            callback(key)
        end

        keyBtn.MouseButton1Click:Connect(function()
            if listening then return end
            listening = true
            keyBtn.Text = "..."
            local conn
            conn = UserInputService.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.Keyboard then
                    setKey(input.KeyCode)
                    listening = false
                    conn:Disconnect()
                end
            end)
        end)

        local state = false
        UserInputService.InputBegan:Connect(function(input)
            if input.KeyCode == currentKey then
                if mode == "Toggle" then
                    state = not state
                    callback(state)
                elseif mode == "Hold" then
                    state = true
                    callback(true)
                end
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.KeyCode == currentKey and mode == "Hold" then
                state = false
                callback(false)
            end
        end)

        local obj = { Set = setKey, Get = function() return currentKey end }
        VoltageUI.Config[flag] = obj
        return obj
    end

    function sectionObj:Textbox(config)
        local flag = config.flag or "textbox_" .. tostring(math.random(1000, 9999))
        local default = config.default or ""
        local placeholder = config.placeholder or "Enter text..."
        local callback = config.callback or function() end

        local frame = Instance.new("Frame")
