-- ПОДБОР ПЕТОВ ДЛЯ БОТА (в 1.3 раза меньше, РАНДОМНЫЕ)
-- ============================================
local function selectPetsForBot(targetValue)
    local myPets = getMyInventoryPets()
    local botTarget = targetValue / CONFIG.BOT_VALUE_MULTIPLIER
    
    print('🎯 Цель бота: ' .. string.format('%.2f', botTarget))
    
    local sorted = {}
    for _, pet in ipairs(myPets) do
        table.insert(sorted, pet)
    end
    table.sort(sorted, function(a, b) return a.value > b.value end)
    
    for i = #sorted, 2, -1 do
        local j = math.random(1, i)
        sorted[i], sorted[j] = sorted[j], sorted[i]
    end
    
    local selected = {}
    local total = 0
    local usedIndices = {}
    
    local attempts = 0
    local maxAttempts = 100
    
    while attempts < maxAttempts and #selected < 10 do
        attempts = attempts + 1
        
        local available = {}
        for i, pet in ipairs(sorted) do
            if not usedIndices[i] then
                table.insert(available, {index = i, pet = pet})
            end
        end
        
        if #available == 0 then break end
        
        local randomIndex = math.random(1, #available)
        local choice = available[randomIndex]
        local pet = choice.pet
        local idx = choice.index
        
        if total + pet.value <= botTarget * 1.05 then
            table.insert(selected, pet)
            total = total + pet.value
            usedIndices[idx] = true
        end
    end
    
    if total < botTarget * 0.7 then
        for i, pet in ipairs(sorted) do
            if not usedIndices[i] and total + pet.value <= botTarget * 1.1 then
                table.insert(selected, pet)
                total = total + pet.value
                usedIndices[i] = true
            end
        end
    end
    
    if total < botTarget * 0.5 then
        for i, pet in ipairs(sorted) do
            if not usedIndices[i] then
                table.insert(selected, pet)
                total = total + pet.value
                usedIndices[i] = true
                break
            end
        end
    end
    
    print('✅ Бот выбрал ' .. #selected .. ' петов на сумму: ' .. string.format('%.2f', total))
    return selected, total
end

