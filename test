    -- ═══════════════════════════════════════════════════════════════
    -- БАЗОВЫЕ ФУНКЦИИ
    -- ═══════════════════════════════════════════════════════════════
    function Library:Create(Class, Props)
        local Inst = Instance.new(Class)

        if Class:match("Text") then
            local F = Library.Font
            if type(F) == "table" and F.ClassName == "Font" then
                pcall(function() Inst.FontFace = F end)
            end
            if not Inst.FontFace then
                pcall(function() Inst.Font = F end)
            end
            if not Inst.FontFace and not Inst.Font then
                pcall(function() Inst.Font = Enum.Font.SourceSans end)
            end
            Inst.TextSize = 14
            Inst.TextColor3 = Theme.Text
        end

        if Class == "TextButton" then
            Inst.AutoButtonColor = false
            Inst.Text = ""
        end

        if Class == "ImageButton" then
            Inst.AutoButtonColor = false
        end

        Inst.Name = "\0"

        for K, V in pairs(Props or {}) do
            Inst[K] = V
        end

        return setmetatable({Instance = Inst}, Library)
    end

    function Library:Connect(Signal, Callback)
        if not Signal then return nil end
        
        local Connection = nil
        pcall(function()
            if type(Signal) == "Instance" and Signal:IsA("RBXScriptSignal") then
                Connection = Signal:Connect(Callback)
            elseif type(Signal) == "table" and Signal.Instance then
                Connection = Signal.Instance:Connect(Callback)
            elseif type(Signal) == "RBXScriptSignal" then
                Connection = Signal:Connect(Callback)
            end
        end)
        
        if Connection and type(Connection) == "table" and Connection.Disconnect then
            table.insert(Library.Connections, Connection)
            return Connection
        end
        
        return nil
    end

    function Library:SafeCall(Func, ...)
        if not Func then return end
        local Args = {...}
        local S, R = pcall(Func, table.unpack(Args))
        if not S then warn("[PulseUI]", R) end
        return S, R
    end

    function Library:Tween(Obj, Props, Info)
        local Inst = Obj.Instance or Obj
        Info = Info or TweenInfo.new(Library.TweenSpeed, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
        local T = TweenService:Create(Inst, Info, Props)
        T:Play()
        return T
    end

    function Library:Round(Num, Dec)
        local M = 10 ^ (Dec or 0)
        return math.floor(Num * M + 0.5) / M
    end

    -- ═══════════════════════════════════════════════════════════════
    -- ПУЛЬСАЦИЯ
    -- ═══════════════════════════════════════════════════════════════
    function Library:AddPulse(Obj, Intensity)
        Intensity = Intensity or 0.12
        local Inst = Obj.Instance or Obj
        
        if Inst:IsA("UIStroke") then
            local Conn = Library:Connect(RunService.RenderStepped, function()
                if Inst and Inst.Parent then
                    local P = math.sin(tick() * 1.2) * 0.08 + 0.2
                    Inst.Transparency = math.clamp(P, 0, 0.5)
                end
            end)
            if Conn then table.insert(Library.PulseConnections, Conn) end
            return
        end
        
        if Inst:IsA("ImageLabel") or Inst:IsA("ImageButton") then
            table.insert(Library.PulseObjects, {
                Object = Inst,
                Intensity = Intensity,
                OriginalColor = Inst.ImageColor3,
                IsImage = true,
            })
            return
        end
        
        table.insert(Library.PulseObjects, {
            Object = Inst,
            Intensity = Intensity,
            OriginalColor = Inst.BackgroundColor3,
            IsImage = false,
        })
    end

    local PulseConnection = Library:Connect(RunService.RenderStepped, function()
        local Time = tick()
        for _, Data in pairs(Library.PulseObjects) do
            if Data.Object and Data.Object.Parent then
                local P = math.sin(Time * 1.2) * Data.Intensity
                if Data.IsImage then
                    local C = Data.OriginalColor
                    Data.Object.ImageColor3 = Color3.new(
                        math.clamp(C.R + P, 0, 1),
                        math.clamp(C.G + P * 0.7, 0, 1),
                        math.clamp(C.B + P * 0.3, 0, 1)
                    )
                else
                    local C = Data.OriginalColor
                    Data.Object.BackgroundColor3 = Color3.new(
                        math.clamp(C.R + P, 0, 1),
                        math.clamp(C.G + P * 0.7, 0, 1),
                        math.clamp(C.B + P * 0.3, 0, 1)
                    )
                end
            end
        end
    end)
    if PulseConnection then table.insert(Library.PulseConnections, PulseConnection) end

    -- ═══════════════════════════════════════════════════════════════
    -- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
    -- ═══════════════════════════════════════════════════════════════
    function Library:MakeDraggable(Obj)
        local Inst = Obj.Instance or Obj
        local Dragging = false
        local DragStart, StartPos

        Inst.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Dragging = true
                DragStart = Input.Position
                StartPos = Inst.Position
                local Changed = Input.Changed:Connect(function()
                    if Input.UserInputState == Enum.UserInputState.End then
                        Dragging = false
                        if Changed then Changed:Disconnect() end
                    end
                end)
            end
        end)

        Library:Connect(UserInputService.InputChanged, function(Input)
            if Dragging and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                local Delta = Input.Position - DragStart
                Inst.Position = UDim2.new(
                    StartPos.X.Scale, StartPos.X.Offset + Delta.X,
                    StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y
                )
            end
        end)
    end

    function Library:MakeResizable(Obj, MinSize)
        local Inst = Obj.Instance or Obj
        MinSize = MinSize or Vector2.new(500, 400)
        local Resizing = false
        local StartPos, StartSize

        local Handle = Library:Create("ImageButton", {
            Parent = Inst,
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, -4, 1, -4),
            Size = UDim2.new(0, 16, 0, 16),
            BackgroundTransparency = 1,
            Image = Icons.resize,
            ImageColor3 = Theme.TextDim,
            ZIndex = 999,
        })

        Handle.Instance.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Resizing = true
                StartPos = Input.Position
                StartSize = Inst.Size
            end
        end)

        Library:Connect(UserInputService.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Resizing = false
            end
        end)

        Library:Connect(UserInputService.InputChanged, function(Input)
            if Resizing and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                local Delta = Input.Position - StartPos
                Inst.Size = UDim2.new(
                    0, math.max(StartSize.X.Offset + Delta.X, MinSize.X),
                    0, math.max(StartSize.Y.Offset + Delta.Y, MinSize.Y)
                )
            end
        end)
    end

