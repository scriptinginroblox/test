            table.insert(spawnedPets, pet.displayName .. " (" .. variantName .. ") [" .. string.format("%.1f", pet.value) .. "]")
            logGUI:log("✅ " .. pet.displayName .. " (" .. variantName .. ") +" .. pet.value, Color3.fromRGB(0, 255, 0))
            
            pcall(function()
                game.StarterGui:SetCore('SendNotification', {
                    Title = '✅ Спавн!',
                    Text = pet.displayName .. ' (' .. variantName .. ')',
                    Duration = 2,
                })
            end)
        else
            logGUI:log("❌ Не спавн: " .. pet.displayName, Color3.fromRGB(255, 0, 0))
        end
        
        task.wait(0.1)
    end
    
    -- ═══════════════════════════════════════════════════════════════
    -- РЕЗУЛЬТАТ
    -- ═══════════════════════════════════════════════════════════════
    
    logGUI:log("═══════════════════", Color3.fromRGB(255, 255, 255))
    if #spawnedPets > 0 then
        logGUI:log("✅ Спавнено: " .. #spawnedPets .. " петов", Color3.fromRGB(0, 255, 0))
        logGUI:log("💰 Сумма: " .. string.format("%.2f", currentValue), Color3.fromRGB(255, 255, 0))
        for i, pet in ipairs(spawnedPets) do
            logGUI:log("  " .. i .. ". " .. pet, Color3.fromRGB(200, 200, 200))
        end
        
        pcall(function()
            game.StarterGui:SetCore('SendNotification', {
                Title = '✅ Готово!',
                Text = 'Спавнено ' .. #spawnedPets .. ' петов! Сумма: ' .. string.format("%.2f", currentValue),
                Duration = 5,
            })
        end)
    else
        logGUI:log("❌ Не спавнено ни одного пета!", Color3.fromRGB(255, 0, 0))
    end
    logGUI:log("═══════════════════", Color3.fromRGB(255, 255, 255))
end

-- Запускаем
local success, err = pcall(main)
if not success then
    logGUI:log("❌ ОШИБКА: " .. tostring(err), Color3.fromRGB(255, 0, 0))
    pcall(function()
        game.StarterGui:SetCore('SendNotification', {
            Title = '❌ Ошибка',
            Text = 'Ошибка: ' .. tostring(err),
            Duration = 10,
        })
    end)
end
