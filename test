function toggleMenu()
    mainFrame.Visible = not mainFrame.Visible
    if mainFrame.Visible then
        -- Позиционирование рядом с кнопкой
        local absPos = FAB.AbsolutePosition
        local absSize = FAB.AbsoluteSize
        local screenSize = Vector2.new(workspace.CurrentCamera.ViewportSize.X,
                                       workspace.CurrentCamera.ViewportSize.Y)
        local menuX = absPos.X + absSize.X + 12
        local menuY = absPos.Y
        if menuX + mainFrame.Size.X.Offset > screenSize.X then
            menuX = absPos.X - mainFrame.Size.X.Offset - 12
        end
        if menuY + mainFrame.Size.Y.Offset > screenSize.Y then
            menuY = screenSize.Y - mainFrame.Size.Y.Offset
        end
        if menuY < 0 then menuY = 0 end
        if menuX < 0 then menuX = 0 end
        mainFrame.Position = UDim2.new(0, menuX, 0, menuY)
        showChamsSettings()
        tween(mainFrame, { BackgroundTransparency = 0.05 }, 0.3)
    end
end

