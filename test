local KeyMap = {
    Backspace = "Bksp",
    Return = "Enter",
    LeftShift = "LShift",
    RightShift = "RShift",
    LeftControl = "LCtrl",
    RightControl = "RCtrl",
    LeftAlt = "LAlt",
    RightAlt = "RAlt",
    CapsLock = "Caps",
    Insert = "Ins",
    Delete = "Del",
    Home = "Home",
    End = "End",
    PageUp = "PgUp",
    PageDown = "PgDn",
    Escape = "Esc",
    Space = "Space",
    Tab = "Tab",
    Up = "↑",
    Down = "↓",
    Left = "←",
    Right = "→",
}

function Library:Keybind(data)
    data = data or {}
    local keybind = {
        Name = data.Name or "Keybind",
        Flag = data.Flag or data.Name or "Keybind",
        Default = data.Default or Enum.KeyCode.E,
        Mode = data.Mode or "Toggle",
        Callback = data.Callback or function() end,
        Key = "",
        Value = "None",
        Toggled = false,
        Picking = false,
    }
    
    local items = {}
    
    local frame = Library:Create("Frame", {
        Parent = data.Parent.Instance,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 20),
        BorderSizePixel = 0,
    })
    
    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1, -80, 1, 0)
    text.BackgroundTransparency = 1
    text.Text = keybind.Name
    text.TextColor3 = Library.Theme.TextDim
    text.Font = Enum.Font.Gotham
    text.TextSize = 13
    text.TextXAlignment = Enum.TextXAlignment.Left
    text.Parent = frame.Instance
    
    local keyBg = Instance.new("Frame")
    keyBg.AnchorPoint = Vector2.new(1, 0.5)
    keyBg.Position = UDim2.new(1, 0, 0.5, 0)
    keyBg.Size = UDim2.new(0, 60, 0, 18)
    keyBg.BackgroundColor3 = Library.Theme.Element
    keyBg.BorderSizePixel = 0
    keyBg.Parent = frame.Instance
    Library:Corner(keyBg, 4)
    
    local keyText = Instance.new("TextLabel")
    keyText.Size = UDim2.new(1, -8, 1, 0)
    keyText.Position = UDim2.new(0, 4, 0, 0)
    keyText.BackgroundTransparency = 1
    keyText.Text = "None"
    keyText.TextColor3 = Library.Theme.Text
    keyText.Font = Enum.Font.Gotham
    keyText.TextSize = 11
    keyText.TextXAlignment = Enum.TextXAlignment.Center
    keyText.Parent = keyBg
    
    local function getKeyName(key)
        if typeof(key) == "EnumItem" then
            return KeyMap[key.Name] or key.Name
        end
        return tostring(key)
    end
    
    function keybind:Set(key)
        if typeof(key) == "EnumItem" then
            self.Key = key
            self.Value = getKeyName(key)
            keyText.Text = self.Value
        elseif type(key) == "table" and key.Key then
            self.Key = key.Key
            self.Mode = key.Mode or self.Mode
            self.Value = getKeyName(key.Key)
            keyText.Text = self.Value
        elseif type(key) == "string" then
            self.Key = key
            self.Value = key
            keyText.Text = key
        end
        self.Picking = false
        Library.Flags[self.Flag] = { Key = self.Key, Mode = self.Mode, Toggled = self.Toggled }
        self.Callback(self.Toggled)
    end
    
    function keybind:Press(active)
        if self.Mode == "Toggle" then
            self.Toggled = not self.Toggled
        elseif self.Mode == "Hold" then
            self.Toggled = active
        elseif self.Mode == "Always" then
            self.Toggled = true
        end
        Library.Flags[self.Flag] = { Key = self.Key, Mode = self.Mode, Toggled = self.Toggled }
        self.Callback(self.Toggled)
    end
    
    function keybind:SetText(text)
        self.Name = text
        text.Text = text
    end
    
    function keybind:SetVisible(visible)
        frame.Instance.Visible = visible
    end
    
    keyBg.MouseButton1Click:Connect(function()
        if self.Picking then return end
        self.Picking = true
        keyText.Text = "..."
        local conn
        conn = UserInputService.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Keyboard then
                self:Set(input.KeyCode)
                conn:Disconnect()
            end
        end)
    end)
    
    UserInputService.InputBegan:Connect(function(input, gpe)
        if self.Value == "None" or self.Picking then return
        if input.KeyCode == self.Key then
            if self.Mode == "Toggle" then self:Press()
            elseif self.Mode == "Hold" then self:Press(true)
            elseif self.Mode == "Always" then self:Press(true) end
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if self.Value == "None" then return
        if input.KeyCode == self.Key and self.Mode == "Hold" then
            self:Press(false)
        end
    end)
    
    if keybind.Default then
        keybind:Set(keybind.Default)
    end
    
    Library.ConfigFlags[keybind.Flag] = keybind.Set
    
    if Library.KeybindList then
        local item = Library.KeybindList:Add(keybind.Name, keybind.Value, keybind.Mode)
        keybind._listItem = item
        local oldSet = keybind.Set
        keybind.Set = function(self, key)
            oldSet(self, key)
            if item then item:Update(self.Name, self.Value, self.Mode) end
        end
    end
    
    return keybind
end

