-- ═══════════════════════════════════════════════════════════════════════

function Library:CreateSettingsPage(window)
    local page = window:Page({ Name = "Settings", Icon = "Settings" })
    
    local configSection = page:Section({ Name = "Configs" })
    
    local configList = {}
    local configName = ""
    
    configSection:Label({ Name = "Save / Load Configurations" })
    
    local configDropdown = configSection:Dropdown({
        Name = "Configs",
        Items = Library:GetConfigList(),
        Callback = function(value)
            configName = value
        end
    })
    
    configSection:Button({
        Name = "Save Config",
        Callback = function()
            if configName and configName ~= "" then
                Library:SaveConfig(configName)
                configDropdown:Refresh(Library:GetConfigList())
            end
        end
    })
    
    configSection:Button({
        Name = "Load Config",
        Callback = function()
            if configName and configName ~= "" then
                Library:LoadConfigFile(configName)
            end
        end
    })
    
    configSection:Button({
        Name = "Delete Config",
        Callback = function()
            if configName and configName ~= "" then
                Library:DeleteConfig(configName)
