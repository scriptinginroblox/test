local themeElements = {}

local function registerTheme(obj, prop, key)
    table.insert(themeElements, {obj = obj, prop = prop, key = key})
    if Theme[key] then
        obj[prop] = Theme[key]
    end
end

-- ═══════════════════════════════════════════════════════════════════════
-- UTILITIES
-- ═══════════════════════════════════════════════════════════════════════

local function tween(obj, props, time, style, dir)
    time = time or 0.2
    style = style or Enum.EasingStyle.Quad
    dir = dir or Enum.EasingDirection.Out
    local tw = TweenService:Create(obj, TweenInfo.new(time, style, dir), props)
    tw:Play()
    return tw
end

local function corner(obj, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 6)
    c.Parent = obj
    return c
end

local function stroke(obj, col, thick, trans)
    local s = Instance.new("UIStroke")
    s.Color = col or Theme.Border
    s.Thickness = thick or 1
    s.Transparency = trans or 0
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = obj
    return s
end

local function pad(obj, t, r, b, l)
    local p = Instance.new("UIPadding")
    p.PaddingTop = UDim.new(0, t or 0)
    p.PaddingRight = UDim.new(0, r or 0)
    p.PaddingBottom = UDim.new(0, b or 0)
    p.PaddingLeft = UDim.new(0, l or 0)
    p.Parent = obj
    return p
end

local function makeIcon(parent, icon, size, color)
    local img = Instance.new("ImageLabel")
    img.Size = size or UDim2.fromOffset(18, 18)
    img.BackgroundTransparency = 1
    img.Image = icon
    if color then
        img.ImageColor3 = color
    else
        img.ImageColor3 = Theme.Text
    end
    img.Parent = parent
    return img
end

local function clamp(v, min, max)
    return math.max(min, math.min(max, v))
end

local function round(n, d)
    local m = 10 ^ (d or 0)
    return math.floor(n * m + 0.5) / m
end

