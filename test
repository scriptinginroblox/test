    local callback = config.Callback or function() end
    local listening = false
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 35)
    frame.BackgroundTransparency = 1
    frame.Parent = parent
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = config.Name or "Keybind"
    label.TextColor3 = self.Theme.Text
    label.FontFace = self.Font
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local keyBtn = Instance.new("TextButton")
    keyBtn.Size = UDim2.new(0, 80, 0, 22)
    keyBtn.Position = UDim2.new(0.85, 0, 0.5, -11)
    keyBtn.BackgroundColor3 = self.Theme.Surface
    keyBtn.BorderSizePixel = 0
    keyBtn.Text = key and key.Name or "None"
    keyBtn.TextColor3 = self.Theme.Text
    keyBtn.FontFace = self.Font
    keyBtn.TextSize = 12
    keyBtn.AutoButtonColor = false
    keyBtn.Parent = frame
    
    Utilities:Corner(keyBtn, 6)
    Utilities:Stroke(keyBtn, self.Theme.Border, 1, 0.5)
    
    keyBtn.MouseButton1Click:Connect(function()
        if listening then return end
        listening = true
        keyBtn.Text = "..."
        keyBtn.TextColor3 = self.Theme.Accent
        
        local conn
        conn = Services.UserInput.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Keyboard then
                key = input.KeyCode
                keyBtn.Text = key.Name
                keyBtn.TextColor3 = self.Theme.Text
                listening = false
                callback(key)
                conn:Disconnect()
            end
        end)
    end)
    
    return {
        Set = function(k)
            key = k
            keyBtn.Text = k and k.Name or "None"
        end,
        Get = function() return key end,
        UpdateTheme = function(theme)
            label.TextColor3 = theme.Text
            keyBtn.BackgroundColor3 = theme.Surface
            keyBtn.TextColor3 = theme.Text
        end
    }
end

