local function addItemToTrade(itemData)
    if not mockState.active or not mockState.trade then
        return false, "No active trade"
    end
    
    if mockState.trade.current_stage == "completed" then
        return false, "Trade already completed"
    end
    
    local item = {
        id = itemData.id or itemData.name or "FakeItem_" .. HttpService:GenerateGUID(false),
        name = itemData.name or "Unknown",
        type = itemData.type or "Weapons",
        amount = itemData.amount or 1,
        icon = itemData.icon or "2005276185",
        rarity = itemData.rarity or "Unknown",
    }
    
    table.insert(mockState.trade.sender_offer.items, item)
    mockState.trade.offer_version = mockState.trade.offer_version + 1
    updateTradeUI()
    
    return true, "Item added"
end

