function Library:Slider(data)
    data = data or {}
    local slider = {
        Name = data.Name or "Slider",
        Flag = data.Flag or data.Name or "Slider",
        Min = data.Min or 0,
        Max = data.Max or 100,
        Default = data.Default or 50,
        Decimals = data.Decimals or 0,
        Suffix = data.Suffix or "",
        Callback = data.Callback or function() end,
        Value = 0,
        Sliding = false,
    }
    
    local items = {}
    
    local frame = Library:Create("Frame", {
        Parent = data.Parent.Instance,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 35),
        BorderSizePixel = 0,
    })
    
    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1, -80, 0, 16)
    text.BackgroundTransparency = 1
    text.Text = slider.Name
    text.TextColor3 = Library.Theme.TextDim
    text.Font = Enum.Font.Gotham
    text.TextSize = 13
    text.TextXAlignment = Enum.TextXAlignment.Left
    text.Parent = frame.Instance
    
    local valueLbl = Instance.new("TextLabel")
    valueLbl.AnchorPoint = Vector2.new(1, 0)
    valueLbl.Position = UDim2.new(1, 0, 0, 0)
    valueLbl.Size = UDim2.new(0, 60, 0, 16)
    valueLbl.BackgroundTransparency = 1
    valueLbl.Text = tostring(slider.Default) .. slider.Suffix
    valueLbl.TextColor3 = Library.Theme.Accent
    valueLbl.Font = Enum.Font.GothamBold
    valueLbl.TextSize = 13
    valueLbl.TextXAlignment = Enum.TextXAlignment.Right
    valueLbl.Parent = frame.Instance
    
    local track = Instance.new("Frame")
    track.AnchorPoint = Vector2.new(0, 1)
    track.Position = UDim2.new(0, 0, 1, -2)
    track.Size = UDim2.new(1, 0, 0, 4)
    track.BackgroundColor3 = Library.Theme.Element
    track.BorderSizePixel = 0
    track.Parent = frame.Instance
    Library:Corner(track, 2)
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((slider.Default - slider.Min) / (slider.Max - slider.Min), 0, 1, 0)
    fill.BackgroundColor3 = Library.Theme.Accent
    fill.BorderSizePixel = 0
    fill.Parent = track
    Library:Corner(fill, 2)
    
    local knob = Instance.new("Frame")
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new((slider.Default - slider.Min) / (slider.Max - slider.Min), 0, 0.5, 0)
    knob.Size = UDim2.new(0, 10, 0, 10)
    knob.BackgroundColor3 = Library.Theme.Text
    knob.BorderSizePixel = 0
    knob.Parent = track
    Library:Corner(knob, 5)
    
    track.MouseEnter:Connect(function()
        Library:Tween(track, { BackgroundColor3 = Library.Theme.Hover })
    end)
    track.MouseLeave:Connect(function()
        Library:Tween(track, { BackgroundColor3 = Library.Theme.Element })
    end)
    
    function slider:Set(value)
        self.Value = Library:Clamp(value, self.Min, self.Max)
        local percent = (self.Value - self.Min) / (self.Max - self.Min)
        Library:Fade(fill, { Size = UDim2.new(percent, 0, 1, 0) })
        Library:Fade(knob, { Position = UDim2.new(percent, 0, 0.5, 0) })
        valueLbl.Text = tostring(Library:Round(self.Value, self.Decimals)) .. self.Suffix
        Library.Flags[self.Flag] = self.Value
        self.Callback(self.Value)
    end
    
    function slider:SetText(text)
        slider.Name = text
        text.Text = text
    end
    
    function slider:SetVisible(visible)
        frame.Instance.Visible = visible
    end
    
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            self.Sliding = true
            local percent = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
            local value = self.Min + (self.Max - self.Min) * Library:Clamp(percent, 0, 1)
            self:Set(value)
        end
    end)
    track.InputEnded:Connect(function()
        self.Sliding = false
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if self.Sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local percent = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
            local value = self.Min + (self.Max - self.Min) * Library:Clamp(percent, 0, 1)
            self:Set(value)
        end
    end)
    
    slider:Set(slider.Default)
    Library.ConfigFlags[slider.Flag] = slider.Set
    
    return slider
end

