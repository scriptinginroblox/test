function Library:GetConfig()
    local config = {}
    for flag, value in pairs(self.Flags) do
        if type(value) == "table" and value.Key then
            config[flag] = { Key = tostring(value.Key), Mode = value.Mode }
        elseif type(value) == "table" and value.Color then
            config[flag] = { Color = "#" .. value.HexValue, Alpha = value.Alpha }
        else
            config[flag] = value
        end
    end
    return HttpService:JSONEncode(config)
end

function Library:LoadConfig(json)
    local config = HttpService:JSONDecode(json)
    for flag, value in pairs(config) do
        local setter = self.ConfigFlags[flag]
        if setter then
            if type(value) == "table" and value.Key then
                setter(value)
            elseif type(value) == "table" and value.Color then
                setter(value.Color, value.Alpha)
            else
                setter(value)
            end
        end
    end
end

function Library:SaveConfig(name)
    if not name or name == "" then return end
    local path = self.Folders.Configs .. "/" .. name .. ".json"
    writefile(path, self:GetConfig())
    self:Notify({ Title = "Config", Description = "Saved: " .. name, Duration = 2, Type = "success" })
end

function Library:LoadConfigFile(name)
    if not name or name == "" then return end
    local path = self.Folders.Configs .. "/" .. name .. ".json"
    if isfile(path) then
        self:LoadConfig(readfile(path))
        self:Notify({ Title = "Config", Description = "Loaded: " .. name, Duration = 2, Type = "success" })
    end
end

function Library:DeleteConfig(name)
    if not name or name == "" then return end
    local path = self.Folders.Configs .. "/" .. name .. ".json"
    if isfile(path) then delfile(path) end
end

function Library:GetConfigList()
    local list = {}
    for _, file in ipairs(listfiles(self.Folders.Configs)) do
        local name = file:match("([^/\\]+)%.json$")
        if name then table.insert(list, name) end
    end
    return list
end

function Library:SetAutoLoad(name)
    local path = self.Folders.Configs .. "/" .. name .. ".json"
    if isfile(path) then
        writefile(self.Directory .. "/autoload.json", readfile(path))
    end
end

function Library:ClearAutoLoad()
    writefile(self.Directory .. "/autoload.json", "")
end

function Library:CheckAutoLoad()
    local path = self.Directory .. "/autoload.json"
    if isfile(path) then
        local content = readfile(path)
        if content and content ~= "" then
            self:LoadConfig(content)
        end
    end
end

