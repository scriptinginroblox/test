    local padding = Instance.new("UIPadding")
    padding.PaddingTop = UDim.new(0, 10)
    padding.PaddingBottom = UDim.new(0, 10)
    padding.PaddingLeft = UDim.new(0, 12)
    padding.PaddingRight = UDim.new(0, 12)
    padding.Parent = card
    
    local iconImg = Library:CreateIcon(icon, UDim2.fromOffset(18, 18), color.accent)
    iconImg.Position = UDim2.new(0, 0, 0.5, 0)
    iconImg.AnchorPoint = Vector2.new(0, 0.5)
    iconImg.Parent = card
    
    local titleLbl = Instance.new("TextLabel")
    titleLbl.BackgroundTransparency = 1
    titleLbl.Position = UDim2.new(0, 26, 0, 0)
    titleLbl.Size = UDim2.new(1, -26, 0, 18)
    titleLbl.Text = title
    titleLbl.TextColor3 = self.Theme.Text
    titleLbl.Font = Enum.Font.GothamBold
    titleLbl.TextSize = 14
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.Parent = card
    
    local descLbl = Instance.new("TextLabel")
    descLbl.BackgroundTransparency = 1
    descLbl.Position = UDim2.new(0, 26, 0, 20)
    descLbl.Size = UDim2.new(1, -26, 0, 0)
    descLbl.AutomaticSize = Enum.AutomaticSize.Y
    descLbl.Text = description
    descLbl.TextColor3 = self.Theme.TextDim
    descLbl.Font = Enum.Font.Gotham
    descLbl.TextSize = 12
    descLbl.TextXAlignment = Enum.TextXAlignment.Left
    descLbl.TextWrapped = true
    descLbl.Parent = card
    
    local progressBg = Instance.new("Frame")
    progressBg.Position = UDim2.new(0, 0, 1, -2)
    progressBg.Size = UDim2.new(1, 0, 0, 2)
    progressBg.BackgroundColor3 = self.Theme.Element
    progressBg.BorderSizePixel = 0
    progressBg.Parent = card
    
    local progress = Instance.new("Frame")
    progress.Size = UDim2.new(1, 0, 1, 0)
    progress.BackgroundColor3 = color.accent
    progress.BorderSizePixel = 0
    progress.Parent = progressBg
    
    tween(card, 0.2, { BackgroundTransparency = 0 })
    tween(progress, duration, { Size = UDim2.new(0, 0, 1, 0) })
    
    task.delay(duration, function()
        tween(card, 0.2, { BackgroundTransparency = 1 })
        task.wait(0.25)
        card:Destroy()
    end)
    
    return card
end

