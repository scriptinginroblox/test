-- ===== СИСТЕМА ТЕМ =====
function VoltageUI:SetTheme(theme)
    for k, v in pairs(theme) do
        self.Theme[k] = v
    end
    for _, listener in ipairs(self._themeListeners) do
        pcall(listener)
    end
end

function VoltageUI:OnThemeChange(callback)
    table.insert(self._themeListeners, callback)
end

