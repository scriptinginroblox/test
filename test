                    StarterGui:SetCore('SendNotification', {
                        Title = '✅ Спавн!',
                        Text = pet.name .. ' (' .. variantType .. ', ' .. ageName .. ')',
                        Duration = 2,
                    })
                end)
            end
            
            task.wait(0.08)
            
            if currentValue >= targetMin and #spawnedPets >= 10 then
                break
            end
        end
        
        print('━━━━━━━━━━━━━━━━━━━━━━━━')
