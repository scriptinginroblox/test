-- WATERMARK
-- ═══════════════════════════════════════════════════════════════════════

function Library:CreateWatermark(text)
    local frame = Library:Create("Frame", {
        Parent = Library.Holder.Instance,
        BackgroundColor3 = Library.Theme.Surface,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 20, 1, -20),
        AnchorPoint = Vector2.new(0, 1),
        Size = UDim2.new(0, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.XY,
        ZIndex = 999,
    })
    Library:Corner(frame, 6)
    Library:Stroke(frame, Library.Theme.Border)
    
    local content = Instance.new("Frame")
    content.Size = UDim2.new(1, 0, 1, 0)
    content.BackgroundTransparency = 1
    content.Parent = frame.Instance
    
    local layout = Instance.new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.Padding = UDim.new(0, 6)
    layout.VerticalAlignment = Enum.VerticalAlignment.Center
    layout.Parent = content
    
    local padding = Instance.new("UIPadding")
    padding.PaddingTop = UDim.new(0, 4)
    padding.PaddingBottom = UDim.new(0, 4)
    padding.PaddingLeft = UDim.new(0, 8)
    padding.PaddingRight = UDim.new(0, 8)
    padding.Parent = content
    
    local icon = Library:CreateIcon("Home", UDim2.fromOffset(14, 14), Library.Theme.Accent)
    icon.Parent = content
    
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Text = text or "Voltage Hub"
    label.TextColor3 = Library.Theme.TextDim
    label.Font = Enum.Font.Gotham
    label.TextSize = 11
    label.AutomaticSize = Enum.AutomaticSize.XY
    label.Parent = content
    
    local fps = Instance.new("TextLabel")
    fps.BackgroundTransparency = 1
    fps.Text = "FPS: 0"
    fps.TextColor3 = Library.Theme.TextDark
    fps.Font = Enum.Font.Gotham
    fps.TextSize = 10
    fps.AutomaticSize = Enum.AutomaticSize.XY
    fps.Parent = content
    
    local function updateWatermark()
        local ping = math.floor(Players.LocalPlayer and Players.LocalPlayer:GetNetworkPing() or 0)
        label.Text = text .. "  •  " .. ping .. "ms"
    end
    
    local counter = 0
    local lastTime = tick()
    local currentFps = 0
    
    RunService.Heartbeat:Connect(function()
        counter = counter + 1
        if tick() - lastTime >= 1 then
            currentFps = counter
            counter = 0
            lastTime = tick()
            fps.Text = "FPS: " .. currentFps
            updateWatermark()
        end
    end)
    
    local watermark = {
        _frame = frame,
        _label = label,
        SetVisible = function(self, visible)
            frame.Instance.Visible = visible
        end,
        SetText = function(self, text)
            label.Text = text
        end,
        Update = updateWatermark,
    }
    
    Library.Watermark = watermark
    return watermark
end

-- ═══════════════════════════════════════════════════════════════════════
-- UNLOAD
-- ═══════════════════════════════════════════════════════════════════════

function Library:Unload()
    for _, conn in pairs(self.Connections) do
        pcall(function() conn:Disconnect() end)
    end
    for _, thread in pairs(self.Threads) do
        pcall(function() coroutine.close(thread) end)
    end
    if self.Holder then
        pcall(function() self.Holder.Instance:Destroy() end)
    end
    if self.UnusedHolder then
        pcall(function() self.UnusedHolder.Instance:Destroy() end)
    end
    self = nil
    getgenv().Library = nil
end

