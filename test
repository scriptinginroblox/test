local function createColumn(xPos)
	local col = Instance.new("Frame")
	col.Size = UDim2.new(0, 85, 1, -10)
	col.Position = UDim2.new(0, xPos, 0, 0)
	col.BackgroundTransparency = 1
	col.Parent = bottom

	local layout = Instance.new("UIListLayout")
	layout.FillDirection = Enum.FillDirection.Vertical
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
	layout.Padding = UDim.new(0, 6)
	layout.Parent = col

	return col
end

local leftCol = createColumn(6)
local rightCol = createColumn(101)

local function createBtn(parent, emoji, name)
	local b = Instance.new("TextButton")
	b.Size = UDim2.new(1, 0, 0, 80)
	b.BackgroundColor3 = Color3.fromRGB(74, 81, 97)
	b.Text = ""
	b.Parent = parent

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = b

	local icon = Instance.new("TextLabel")
	icon.Size = UDim2.new(1, 0, 0, 42)
	icon.Position = UDim2.new(0, 0, 0, 4)
	icon.BackgroundTransparency = 1
	icon.Text = emoji
	icon.TextSize = 28
	icon.Font = Enum.Font.GothamBold
	icon.TextColor3 = Color3.fromRGB(255,255,255)
	icon.Parent = b

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 0, 20)
	label.Position = UDim2.new(0, 0, 0, 48)
	label.BackgroundTransparency = 1
	label.Text = name
	label.TextSize = 13
	label.Font = Enum.Font.GothamBold
	label.TextColor3 = Color3.fromRGB(255,255,255)
	label.Parent = b

	b.MouseEnter:Connect(function()
		b.BackgroundColor3 = Color3.fromRGB(60, 66, 80)
	end)

	b.MouseLeave:Connect(function()
		b.BackgroundColor3 = Color3.fromRGB(74, 81, 97)
	end)

	return b
end

-- левая колонка
createBtn(leftCol, "🧩", "Misc")
