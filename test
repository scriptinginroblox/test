    selectBg.Position = UDim2.new(1, 0, 0, 0)
    selectBg.Size = UDim2.new(0, 140, 1, 0)
    selectBg.BackgroundColor3 = Library.Theme.Element
    selectBg.BorderSizePixel = 0
    selectBg.Parent = frame.Instance
    Library:Corner(selectBg, 4)
    
    local selectText = Instance.new("TextLabel")
    selectText.Size = UDim2.new(1, -20, 1, 0)
    selectText.Position = UDim2.new(0, 6, 0, 0)
