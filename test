-- позиционирование меню (справа/слева от кнопки)
local function updateMenuPos()
	local vp = workspace.CurrentCamera.ViewportSize
	local btnPos = openBtn.AbsolutePosition

	local rightX = btnPos.X + 60
	local leftX = btnPos.X - 520 - 10
	local y = btnPos.Y

	if rightX + 520 < vp.X then
		menu.Position = UDim2.new(0, rightX, 0, y)
	else
		menu.Position = UDim2.new(0, math.max(10, leftX), 0, y)
	end
end

