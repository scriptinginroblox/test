                ValueLabel.TextColor3 = Theme.TextDim
                ValueLabel.TextSize = 13
                ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
                ValueLabel.Parent = Btn
                
                local Arrow = makeIcon(Btn, Icons.chevron_down, UDim2.fromOffset(12, 12), Theme.TextDim)
                Arrow.Position = UDim2.new(1, -14, 0.5, -6)
                
                local List = Instance.new("ScrollingFrame")
                List.Size = UDim2.new(1, -4, 0, 0)
                List.Position = UDim2.new(0, 2, 0, 4)
                List.BackgroundColor3 = Theme.Surface
                List.BorderSizePixel = 0
                List.ScrollBarThickness = 2
                List.AutomaticCanvasSize = Enum.AutomaticSize.Y
                List.CanvasSize = UDim2.new(0, 0, 0, 0)
                List.Visible = false
                List.ClipsDescendants = true
                List.Parent = Btn
                corner(List, 6)
                stroke(List, Theme.Border, 1)
                
                local ListLayout = Instance.new("UIListLayout")
                ListLayout.Padding = UDim.new(0, 2)
                ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
                ListLayout.Parent = List
                
                local isOpen = false
                local selected = default
                
                local function closeList()
                    isOpen = false
                    tween(Arrow, {Rotation = 0}, 0.15)
                    tween(Btn, {Size = UDim2.new(1, 0, 0, 30)}, 0.15)
                    task.wait(0.15)
                    List.Visible = false
                    List.Size = UDim2.new(1, -4, 0, 0)
                end
                
                local function openList()
                    isOpen = true
                    List.Visible = true
                    tween(Arrow, {Rotation = 180}, 0.15)
                    local height = clamp(#items * 26 + 8, 0, 120)
                    List.Size = UDim2.new(1, -4, 0, height)
                    tween(Btn, {Size = UDim2.new(1, 0, 0, 30 + height + 4)}, 0.15)
                end
                
                local function selectItem(item, fire)
                    selected = item
                    ValueLabel.Text = tostring(item)
                    Flags[flag] = item
                    if fire then pcall(callback, item) end
                    closeList()
                end
                
                for _, item in ipairs(items) do
                    local ItemBtn = Instance.new("TextButton")
                    ItemBtn.Size = UDim2.new(1, -4, 0, 24)
                    ItemBtn.Position = UDim2.new(0, 2, 0, 0)
                    ItemBtn.BackgroundTransparency = 1
                    ItemBtn.Text = ""
                    ItemBtn.AutoButtonColor = false
                    ItemBtn.Parent = List
                    
                    local ItemLabel = Instance.new("TextLabel")
                    ItemLabel.Size = UDim2.new(1, -16, 1, 0)
                    ItemLabel.Position = UDim2.new(0, 10, 0, 0)
                    ItemLabel.BackgroundTransparency = 1
                    ItemLabel.Font = Enum.Font.Gotham
                    ItemLabel.Text = tostring(item)
                    ItemLabel.TextColor3 = Theme.TextDim
                    ItemLabel.TextSize = 13
                    ItemLabel.TextXAlignment = Enum.TextXAlignment.Left
                    ItemLabel.Parent = ItemBtn
                    
                    ItemBtn.MouseEnter:Connect(function()
                        tween(ItemBtn, {BackgroundTransparency = 0.85})
                        tween(ItemLabel, {TextColor3 = Theme.Text})
                    end)
                    ItemBtn.MouseLeave:Connect(function()
                        tween(ItemBtn, {BackgroundTransparency = 1})
                        tween(ItemLabel, {TextColor3 = Theme.TextDim})
                    end)
                    ItemBtn.MouseButton1Click:Connect(function()
                        selectItem(item, true)
                    end)
                end
                
                Btn.MouseButton1Click:Connect(function()
                    if isOpen then closeList() else openList() end
                end)
                
                UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        if isOpen then
                            local pos = input.Position
                            local abs = Btn.AbsolutePosition
                            local size = Btn.AbsoluteSize
                            if pos.X < abs.X or pos.X > abs.X + size.X or pos.Y < abs.Y or pos.Y > abs.Y + size.Y then
                                closeList()
                            end
                        end
                    end
                end)
                
                FlagSetters[flag] = function(v) selectItem(v, true) end
                
                return {
                    Set = function(v) selectItem(v, true) end,
                    Get = function() return selected end,
                    Refresh = function(newItems)
                        for _, child in ipairs(List:GetChildren()) do
                            if child:IsA("TextButton") then child:Destroy() end
                        end
                        items = newItems or {}
                        for _, item in ipairs(items) do
                            local ItemBtn = Instance.new("TextButton")
                            ItemBtn.Size = UDim2.new(1, -4, 0, 24)
                            ItemBtn.Position = UDim2.new(0, 2, 0, 0)
                            ItemBtn.BackgroundTransparency = 1
                            ItemBtn.Text = ""
                            ItemBtn.AutoButtonColor = false
                            ItemBtn.Parent = List
                            
                            local ItemLabel = Instance.new("TextLabel")
                            ItemLabel.Size = UDim2.new(1, -16, 1, 0)
                            ItemLabel.Position = UDim2.new(0, 10, 0, 0)
                            ItemLabel.BackgroundTransparency = 1
                            ItemLabel.Font = Enum.Font.Gotham
                            ItemLabel.Text = tostring(item)
                            ItemLabel.TextColor3 = Theme.TextDim
                            ItemLabel.TextSize = 13
                            ItemLabel.TextXAlignment = Enum.TextXAlignment.Left
                            ItemLabel.Parent = ItemBtn
                            
                            ItemBtn.MouseEnter:Connect(function()
                                tween(ItemBtn, {BackgroundTransparency = 0.85})
                                tween(ItemLabel, {TextColor3 = Theme.Text})
                            end)
                            ItemBtn.MouseLeave:Connect(function()
                                tween(ItemBtn, {BackgroundTransparency = 1})
                                tween(ItemLabel, {TextColor3 = Theme.TextDim})
                            end)
                            ItemBtn.MouseButton1Click:Connect(function()
                                selectItem(item, true)
                            end)
                        end
                    end,
                }
            end
            
            -- KEYBIND
            function API:Keybind(config)
                config = config or {}
                local name = config.Name or "Keybind"
                local flag = config.Flag or name
                local default = config.Default or Enum.KeyCode.E
                local mode = config.Mode or "Toggle"
                local callback = config.Callback or function() end
                
                local Frame = Instance.new("Frame")
                Frame.Size = UDim2.new(1, 0, 0, 30)
                Frame.BackgroundTransparency = 1
                Frame.Parent = SectionContent
                
                local Btn = Instance.new("TextButton")
                Btn.Size = UDim2.new(1, 0, 1, 0)
                Btn.BackgroundColor3 = Theme.Element
                Btn.Text = ""
                Btn.AutoButtonColor = false
                Btn.Parent = Frame
                corner(Btn, 6)
                
                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -100, 1, 0)
                Label.Position = UDim2.new(0, 10, 0, 0)
                Label.BackgroundTransparency = 1
                Label.Font = Enum.Font.Gotham
                Label.Text = name
                Label.TextColor3 = Theme.Text
                Label.TextSize = 13
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = Btn
                
                local KeyDisplay = Instance.new("TextLabel")
                KeyDisplay.Size = UDim2.new(0, 70, 1, 0)
                KeyDisplay.Position = UDim2.new(1, -80, 0, 0)
                KeyDisplay.BackgroundTransparency = 1
                KeyDisplay.Font = Enum.Font.GothamBold
                KeyDisplay.Text = tostring(default):gsub("Enum.KeyCode.", "")
                KeyDisplay.TextColor3 = Theme.Accent
                KeyDisplay.TextSize = 12
                KeyDisplay.TextXAlignment = Enum.TextXAlignment.Right
                KeyDisplay.Parent = Btn
                
                local currentKey = default
                local isListening = false
                local keyState = false
                
                local function setKey(key, fire)
                    currentKey = key
                    KeyDisplay.Text = tostring(key):gsub("Enum.KeyCode.", "")
                    Flags[flag] = {Key = currentKey, Mode = mode, State = keyState}
                    if fire then pcall(callback, keyState) end
                end
                
                Btn.MouseButton1Click:Connect(function()
                    if isListening then return end
                    isListening = true
                    KeyDisplay.Text = "..."
                    
                    local conn
                    conn = UserInputService.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            if input.KeyCode ~= Enum.KeyCode.Unknown then
                                setKey(input.KeyCode, true)
                                isListening = false
                                conn:Disconnect()
                            end
                        end
                    end)
                end)
                
                UserInputService.InputBegan:Connect(function(input)
                    if isListening then return end
                    if input.KeyCode == currentKey then
                        if mode == "Toggle" then
                            keyState = not keyState
                            pcall(callback, keyState)
                        elseif mode == "Hold" then
                            keyState = true
                            pcall(callback, true)
                        end
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if isListening then return end
                    if mode == "Hold" and input.KeyCode == currentKey then
                        keyState = false
                        pcall(callback, false)
                    end
                end)
                
                FlagSetters[flag] = function(v)
                    if type(v) == "table" then
                        if v.Key then setKey(v.Key, false) end
                        if v.Mode then mode = v.Mode end
                        if v.State ~= nil then keyState = v.State end
                    else
                        setKey(v, false)
                    end
                end
                
                return {
                    Set = function(k) setKey(k, true) end,
                    Get = function() return currentKey, keyState end,
                }
            end
            
