-- Полное удаление старого GUI
if game.CoreGui:FindFirstChild('PSX_LoadingScreen') then
    game.CoreGui:FindFirstChild('PSX_LoadingScreen'):Destroy()
end

-- Основной код для спавна питомца
task.spawn(function()
    local success, err = pcall(function()
        -- Загрузка необходимых модулей
        local Fsys = require(game.ReplicatedStorage:WaitForChild('Fsys'))
        local load = Fsys.load
        local ClientData = load('ClientData')
        local KindDB = load('KindDB')
        local RouterClient = load('RouterClient')
        local DownloadClient = load('DownloadClient')
        local AnimationManager = load('AnimationManager')
        local newPetRigs = load('new:PetRigs')
        
        local HttpService = game:GetService('HttpService')
        local Players = game:GetService('Players')
        local LocalPlayer = Players.LocalPlayer
        
        -- Переменные для хранения данных
        local petCache = {}
        local spawnedPets = {}
        local currentPet = nil
        local ridingPet = nil
        
        -- Функции для работы с питомцами (адаптировано из вашего скрипта)
        local function generateGUID()
            return HttpService:GenerateGUID(false)
        end
        
        local function getPetData(petId)
            if petCache[petId] then
                return petCache[petId]
            end
            local data = DownloadClient.promise_download_copy('Pets', petId):expect()
            petCache[petId] = data
            return data
        end
        
        local function updateClientData(path, callback)
            ClientData.predict(path, callback)
        end
        
        local function spawnPet(petId, properties)
            local uniqueId = generateGUID()
            local petData = nil
            
            updateClientData('inventory', function(inventory)
                local newInventory = table.clone(inventory)
                petData = {
                    unique = uniqueId,
                    category = 'pets',
                    id = petId,
                    kind = KindDB[petId].kind,
                    newness_order = 0,
                    properties = properties
                }
                newInventory.pets[uniqueId] = petData
                return newInventory
            end)
            
            spawnedPets[uniqueId] = {
                data = petData,
                model = nil
            }
            
            return petData
        end
        
        local function applyNeonEffects(petModel, petKind)
            local neonParts = KindDB[petKind].neon_parts
            if not neonParts then return end
            
            for _, partName in pairs(neonParts) do
                local part = newPetRigs.get(petModel).get_geo_part(petModel, partName)
                if part then
                    part.Material = neonParts[partName].Material
                    part.Color = neonParts[partName].Color
                end
            end
        end
        
        local function addPetCharWrapper(petUnique, model, properties)
            updateClientData('pet_char_wrappers', function(wrappers)
                local newWrappers = table.clone(wrappers)
                table.insert(newWrappers, {
                    char = model,
                    mega_neon = properties.mega_neon or false,
                    neon = properties.neon or false,
                    player = LocalPlayer,
                    entity_controller = LocalPlayer,
                    controller = LocalPlayer,
                    rp_name = properties.rp_name or '',
                    pet_trick_level = properties.pet_trick_level or 0,
                    pet_unique = petUnique,
                    pet_id = properties.id,
                    location = {
                        full_destination_id = 'housing',
                        destination_id = 'housing',
                        house_owner = LocalPlayer
                    },
                    pet_progression = {
                        friendship_level = properties.friendship_level or 0,
                        age = properties.age or 1,
                        percentage = 0
                    },
                    are_colors_sealed = false,
                    is_pet = true
                })
                return newWrappers
            end)
        end
        
        local function addPetStateManager(petUnique, model)
            updateClientData('pet_state_managers', function(managers)
                local newManagers = table.clone(managers)
                table.insert(newManagers, {
                    char = model,
                    player = LocalPlayer,
                    store_key = 'pet_state_managers',
                    is_sitting = false,
                    chars_connected_to_me = {},
                    states = {}
                })
                return newManagers
            end)
        end
        
        -- Функция для полного спавна питомца
        local function fullySpawnPet(petId, properties)
            local petData = spawnPet(petId, properties)
            local petModel = getPetData(petId):Clone()
            petModel.Parent = workspace
            
            spawnedPets[petData.unique].model = petModel
            
            if properties.neon or properties.mega_neon then
                applyNeonEffects(petModel, petId)
            end
            
            addPetCharWrapper(petData.unique, petModel, properties)
            addPetStateManager(petData.unique, petModel)
            
            return petData
        end
        
        -- Поиск ID питомца по имени
        local InventoryDB = require(game.ReplicatedStorage.Fsys).load('InventoryDB')
        
        local function getPetIdByName(petName)
            for _, pet in pairs(InventoryDB.pets) do
                if type(pet.name) == 'string' and pet.name:lower() == petName:lower() then
                    return pet.id
                end
            end
            return false
        end
        
        -- Параметры для MFR Crow
        local petName = 'Crow'
        local petId = getPetIdByName(petName)
        
        if petId then
            -- Создаём MFR Crow
            local properties = {
                pet_trick_level = 0,
                rideable = true,
                flyable = true,
                friendship_level = 0,
                age = 1,
                ailments_completed = 0,
                rp_name = '',
                mega_neon = true,  -- MFR
                neon = false
            }
            
            fullySpawnPet(petId, properties)
            
            -- Уведомление об успехе
            pcall(function()
                game.StarterGui:SetCore('SendNotification', {
                    Title = '✅ Успех!',
                    Text = 'MFR Crow добавлен в инвентарь!',
                    Duration = 3
                })
            end)
        else
            -- Если питомец не найден
            pcall(function()
                game.StarterGui:SetCore('SendNotification', {
                    Title = '❌ Ошибка',
                    Text = 'Питомец "Crow" не найден',
                    Duration = 3
                })
            end)
        end
    end)
    
    if not success then
        pcall(function()
            game.StarterGui:SetCore('SendNotification', {
                Title = '❌ Ошибка',
                Text = 'Не удалось спавнить питомца: ' .. tostring(err),
                Duration = 5
            })
        end)
    end
end)
