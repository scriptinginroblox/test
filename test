-- ═══════════════════════════════════════════════════════════════════════

function Library:Window(data)
    data = data or {}
    local window = {
        Name = data.Name or "Voltage Hub",
        Subtitle = data.Subtitle or "Premium UI Library",
        Size = data.Size or UDim2.new(0, 780, 0, 520),
