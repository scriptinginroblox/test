print("🔴 СКРИПТ ЗАПУЩЕН!")

game:GetService('StarterGui'):SetCore('SendNotification', {
    Title = '🔴 ТЕСТ',
    Text = 'Скрипт работает!',
    Duration = 5
})

task.wait(2)

local Players = game:GetService('Players')
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService('ReplicatedStorage')

game:GetService('StarterGui'):SetCore('SendNotification', {
    Title = '📦 ШАГ 1',
    Text = 'Игрок: ' .. LocalPlayer.Name,
    Duration = 3
})

task.wait(2)

game:GetService('StarterGui'):SetCore('SendNotification', {
    Title = '📦 ШАГ 2',
    Text = 'Проверяю Fsys...',
    Duration = 3
})

local Fsys = nil
local success, err = pcall(function()
    Fsys = require(ReplicatedStorage:WaitForChild('Fsys'))
end)

if not success then
    game:GetService('StarterGui'):SetCore('SendNotification', {
        Title = '❌ ОШИБКА',
        Text = 'Fsys не найден: ' .. tostring(err),
        Duration = 10
    })
    print("❌ Ошибка Fsys: " .. tostring(err))
    return
end

game:GetService('StarterGui'):SetCore('SendNotification', {
    Title = '✅ ШАГ 3',
    Text = 'Fsys загружен!',
    Duration = 3
})

print("✅ Fsys загружен!")

task.wait(2)

game:GetService('StarterGui'):SetCore('SendNotification', {
    Title = '✅ ГОТОВО',
    Text = 'Скрипт работает, можно использовать!',
    Duration = 5
})

print("✅ Скрипт готов к работе!")
