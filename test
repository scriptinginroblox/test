    -- Фабрики элементов (копируем из ранее определённых функций)
    Window._addToggle = function(self, config, content)
        local flag = config.flag or "toggle_" .. tostring(math.random(1000, 9999))
        local default = config.default or false
        local callback = config.callback or function() end

        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 32)
        frame.BackgroundTransparency = 1
        frame.ZIndex = 11
        frame.Parent = content

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, -60, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = config.name or "Toggle"
        label.TextColor3 = VoltageUI.Theme.Text
        label.TextSize = 15
        label.Font = Enum.Font.Gotham
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.ZIndex = 12
        label.Parent = frame

        local pill = Instance.new("Frame")
        pill.Size = UDim2.new(0, 40, 0, 22)
        pill.Position = UDim2.new(1, -40, 0.5, -11)
        pill.AnchorPoint = Vector2.new(0, 0.5)
        pill.BackgroundColor3 = default and VoltageUI.Theme.Accent or Color3.fromRGB(60, 70, 85)
        pill.BorderSizePixel = 0
        pill.ZIndex = 12
        pill.Parent = frame
        corner(pill, 11)

        local knob = Instance.new("Frame")
        knob.Size = UDim2.new(0, 18, 0, 18)
        knob.Position = default and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)
        knob.AnchorPoint = Vector2.new(0, 0.5)
        knob.BackgroundColor3 = Color3.new(1, 1, 1)
        knob.BorderSizePixel = 0
        knob.ZIndex = 13
        knob.Parent = pill
        corner(knob, 9)

        local state = default
        local function setState(v)
            state = v
            tween(pill, { BackgroundColor3 = state and VoltageUI.Theme.Accent or Color3.fromRGB(60, 70, 85) }, 0.15)
            tween(knob, { Position = state and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9) }, 0.15)
            VoltageUI.Flags[flag] = state
            callback(state)
        end

        frame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                setState(not state)
            end
        end)

        setState(default)
        local obj = { Set = setState, Get = function() return state end }
        VoltageUI.Config[flag] = obj
        return obj
    end

    Window._addSlider = function(self, config, content)
        -- аналогично предыдущей реализации
        local flag = config.flag or "slider_" .. tostring(math.random(1000, 9999))
        local min = config.min or 0
        local max = config.max or 100
        local default = config.default or 50
        local suffix = config.suffix or ""
        local decimals = config.decimals or 0
        local callback = config.callback or function() end

        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 50)
        frame.BackgroundTransparency = 1
        frame.ZIndex = 11
        frame.Parent = content

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, -80, 0, 20)
        label.BackgroundTransparency = 1
        label.Text = config.name or "Slider"
        label.TextColor3 = VoltageUI.Theme.Text
        label.TextSize = 15
        label.Font = Enum.Font.Gotham
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.ZIndex = 12
        label.Parent = frame

        local valLbl = Instance.new("TextLabel")
        valLbl.Size = UDim2.new(0, 70, 0, 20)
        valLbl.Position = UDim2.new(1, -70, 0, 0)
        valLbl.AnchorPoint = Vector2.new(1, 0)
        valLbl.BackgroundTransparency = 1
        valLbl.Text = tostring(default) .. suffix
        valLbl.TextColor3 = VoltageUI.Theme.Accent
        valLbl.TextSize = 15
        valLbl.Font = Enum.Font.GothamBold
        valLbl.TextXAlignment = Enum.TextXAlignment.Right
        valLbl.ZIndex = 12
        valLbl.Parent = frame

        local track = Instance.new("Frame")
        track.Size = UDim2.new(1, 0, 0, 6)
        track.Position = UDim2.new(0, 0, 1, -6)
        track.BackgroundColor3 = Color3.fromRGB(40, 48, 58)
        track.BorderSizePixel = 0
        track.ZIndex = 12
        track.Parent = frame
        corner(track, 3)

        local fill = Instance.new("Frame")
        fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
        fill.BackgroundColor3 = VoltageUI.Theme.Accent
        fill.BorderSizePixel = 0
        fill.ZIndex = 13
        fill.Parent = track
        corner(fill, 3)

        local knob = Instance.new("TextButton")
        knob.Size = UDim2.new(0, 16, 0, 16)
        knob.Position = UDim2.new((default - min) / (max - min), -8, 0.5, -8)
        knob.AnchorPoint = Vector2.new(0, 0.5)
        knob.BackgroundColor3 = Color3.new(1, 1, 1)
        knob.BorderSizePixel = 0
        knob.ZIndex = 14
        knob.Text = ""
        knob.Parent = track
        corner(knob, 8)

        local dragging = false
        local function setValue(val)
            val = math.clamp(val, min, max)
            local alpha = (val - min) / (max - min)
            fill.Size = UDim2.new(alpha, 0, 1, 0)
            knob.Position = UDim2.new(alpha, -8, 0.5, -8)
            valLbl.Text = tostring(math.round(val * (10^decimals)) / (10^decimals)) .. suffix
            VoltageUI.Flags[flag] = val
            callback(val)
        end

        track.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                local pos = input.Position.X - track.AbsolutePosition.X
                local alpha = math.clamp(pos / track.AbsoluteSize.X, 0, 1)
                setValue(min + alpha * (max - min))
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local pos = input.Position.X - track.AbsolutePosition.X
                local alpha = math.clamp(pos / track.AbsoluteSize.X, 0, 1)
                setValue(min + alpha * (max - min))
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)

        setValue(default)
        local obj = { Set = setValue, Get = function() return VoltageUI.Flags[flag] end }
        VoltageUI.Config[flag] = obj
        return obj
    end

    Window._addDropdown = function(self, config, content)
        -- аналогично
