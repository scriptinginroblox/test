-- Добавляем тень под кнопкой (эффект глубины)
local fabShadow = Instance.new("ImageLabel")
fabShadow.Size = UDim2.new(1, 20, 1, 20)
fabShadow.Position = UDim2.new(0.5, 0, 0.5, 0)
fabShadow.AnchorPoint = Vector2.new(0.5, 0.5)
fabShadow.BackgroundTransparency = 1
fabShadow.Image = "rbxassetid://18245826428"  -- Спрайт тени
fabShadow.ScaleType = Enum.ScaleType.Slice
fabShadow.SliceCenter = Rect.new(21, 21, 79, 79)
fabShadow.ImageTransparency = 0.6
fabShadow.ZIndex = -1
