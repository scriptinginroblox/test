    dropdownList.ScrollBarImageColor3 = self.Theme.Accent
    dropdownList.Parent = frame
    
    Utilities:Corner(dropdownList, 8)
    Utilities:Stroke(dropdownList, self.Theme.Border, 1, 0.5)
    
    local listLayout = Utilities:ListLayout(dropdownList, 2)
    
    local function buildDropdown()
        for _, child in pairs(dropdownList:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        
        for _, option in ipairs(options) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 28)
            btn.BackgroundColor3 = self.Theme.Surface
            btn.BackgroundTransparency = 0.5
            btn.BorderSizePixel = 0
            btn.Text = option
            btn.TextColor3 = self.Theme.TextDim
            btn.FontFace = self.Font
            btn.TextSize = 12
            btn.AutoButtonColor = false
            btn.Parent = dropdownList
            
            btn.MouseEnter:Connect(function()
                Utilities:Tween(btn, {BackgroundTransparency = 0.2, TextColor3 = self.Theme.Text}, 0.1)
            end)
            
            btn.MouseLeave:Connect(function()
                Utilities:Tween(btn, {BackgroundTransparency = 0.5, TextColor3 = self.Theme.TextDim}, 0.1)
            end)
            
            btn.MouseButton1Click:Connect(function()
                selected = option
                dropdownBtn.Text = option
                callback(option)
                toggleDropdown(false)
            end)
        end
    end
    
    local function toggleDropdown(state)
        open = (state ~= nil) and state or not open
        dropdownList.Visible = open
        
        if open then
            dropdownList.Size = UDim2.new(0.5, 0, 0, math.min(#options * 30 + 10, 150))
            local img = arrow:FindFirstChildWhichIsA("ImageLabel")
            if img then Utilities:Tween(img, {Rotation = 180}, 0.2) end
        else
            dropdownList.Size = UDim2.new(0.5, 0, 0, 0)
            local img = arrow:FindFirstChildWhichIsA("ImageLabel")
            if img then Utilities:Tween(img, {Rotation = 0}, 0.2) end
        end
    end
    
    dropdownBtn.MouseButton1Click:Connect(function()
        toggleDropdown()
    end)
    
    buildDropdown()
    
    return {
        Set = function(value)
            selected = value
            dropdownBtn.Text = value
            callback(value)
        end,
        Get = function() return selected end,
        Refresh = function(newOptions)
            options = newOptions or {}
            buildDropdown()
        end,
        UpdateTheme = function(theme)
            label.TextColor3 = theme.Text
            dropdownBtn.BackgroundColor3 = theme.Surface
            dropdownBtn.TextColor3 = theme.Text
        end
    }
end

