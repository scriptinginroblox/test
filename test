-- ================================================================
-- Плавающая круглая кнопка, которая всегда видна на экране.
-- При клике открывает/закрывает меню. Можно перетаскивать.
-- Вдохновлено дизайном из Material Design и Ventura UI.
-- ================================================================

-- Создаём кнопку
local FAB = Instance.new("TextButton")
FAB.Size = UDim2.new(0, 56, 0, 56)
FAB.Position = UDim2.new(0, 20, 0, 120)
