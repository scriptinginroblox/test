local function createCategoryButton(icon, text, bgColor)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 82)
    btn.BackgroundColor3 = bgColor
    btn.Text = ""
    btn.ZIndex = 10
    btn.AutoButtonColor = false
    corner(btn, 10)
    stroke(btn, Theme.Stroke, 1)

    -- Градиентный фон при наведении
    local hoverGrad = gradient(btn, Theme.Hover, Theme.Hover, 0)
    hoverGrad.Transparency = NumberSequence.new{
        NumberSequenceKeypoint.new(0, 1),
        NumberSequenceKeypoint.new(1, 1)
    }

    -- Иконка
    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(1, 0, 0, 40)
    iconLabel.Position = UDim2.new(0, 0, 0, 6)
    iconLabel.BackgroundTransparency = 1
    iconLabel.Text = icon
    iconLabel.TextColor3 = Color3.new(1, 1, 1)
    iconLabel.TextSize = 30
    iconLabel.Font = Enum.Font.Gotham
    iconLabel.TextXAlignment = Enum.TextXAlignment.Center
    iconLabel.ZIndex = 11
    iconLabel.Parent = btn

    -- Текст
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 0, 20)
    textLabel.Position = UDim2.new(0, 0, 0, 50)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = text
    textLabel.TextColor3 = Color3.new(1, 1, 1)
    textLabel.TextSize = 13
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextXAlignment = Enum.TextXAlignment.Center
    textLabel.ZIndex = 11
    textLabel.Parent = btn

    -- Акцентная линия снизу
    local accentLine = Instance.new("Frame")
    accentLine.Size = UDim2.new(0, 0, 0, 2)
    accentLine.Position = UDim2.new(0.5, 0, 1, -4)
    accentLine.AnchorPoint = Vector2.new(0.5, 0)
    accentLine.BackgroundColor3 = Theme.Accent1
    accentLine.BorderSizePixel = 0
    accentLine.ZIndex = 12
    accentLine.Parent = btn
    gradient(accentLine, Theme.Accent1, Theme.Accent2, 0)

    -- Анимации при наведении
    btn.MouseEnter:Connect(function()
        tween(btn, { BackgroundColor3 = Theme.Hover }, 0.15)
        tween(btn, { Size = UDim2.new(1, 4, 0, 84) }, 0.15, Enum.EasingStyle.Back)
        tween(accentLine, { Size = UDim2.new(0.6, 0, 0, 2) }, 0.2)
        tween(textLabel, { TextColor3 = Theme.Accent1 }, 0.15)
    end)

    btn.MouseLeave:Connect(function()
        tween(btn, { BackgroundColor3 = bgColor }, 0.15)
        tween(btn, { Size = UDim2.new(1, 0, 0, 82) }, 0.15)
        tween(accentLine, { Size = UDim2.new(0, 0, 0, 2) }, 0.2)
        tween(textLabel, { TextColor3 = Color3.new(1, 1, 1) }, 0.15)
    end)

    btn.MouseButton1Click:Connect(function()
        -- Эффект нажатия
        tween(btn, { Size = UDim2.new(0.95, 0, 0, 78) }, 0.08)
        task.wait(0.08)
        tween(btn, { Size = UDim2.new(1, 0, 0, 82) }, 0.12, Enum.EasingStyle.Back)
    end)

    return btn
end

