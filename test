    local randomPlayer = filtered[math.random(1, #filtered)]
    
    return {
        Name = randomPlayer.Name,
        DisplayName = randomPlayer.DisplayName,
        UserId = randomPlayer.UserId,
        Character = randomPlayer.Character,
    }
end

