-- ================================================================
-- 2. ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ (Helpers)
-- ================================================================
-- Эти функции упрощают создание GUI-элементов и анимаций.
-- Они взяты из Ventura UI и адаптированы под наш стиль.
-- ================================================================

-- Создаёт скруглённый угол у объекта
local function corner(obj, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = obj
    return c
end

-- Создаёт обводку у объекта (UIStroke)
local function stroke(obj, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Color = color or Color3.fromRGB(50, 50, 60)
    s.Thickness = thickness or 1
    s.Transparency = transparency or 0
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = obj
    return s
end

-- Плавная анимация (Tween) с настраиваемыми параметрами
local function tween(obj, props, time, style, dir)
    time = time or 0.2
    style = style or Enum.EasingStyle.Quad
    dir = dir or Enum.EasingDirection.Out
    local tw = TweenService:Create(obj, TweenInfo.new(time, style, dir), props)
    tw:Play()
    return tw
end

-- Создаёт отступы (UIPadding) у объекта
local function pad(obj, top, right, bottom, left)
    local p = Instance.new("UIPadding")
    p.PaddingTop = UDim.new(0, top or 0)
    p.PaddingRight = UDim.new(0, right or 0)
    p.PaddingBottom = UDim.new(0, bottom or 0)
    p.PaddingLeft = UDim.new(0, left or 0)
    p.Parent = obj
    return p
end

