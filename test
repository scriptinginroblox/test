                local function ActivateSub()
                    if Tab.ActiveSubTab then Tab.ActiveSubTab.DeactivateSub() end
                    SubTab.Active = true
                    Tab.ActiveSubTab = SubTab
                    SubButton.Instance.BackgroundTransparency = 0
                    SubButton.Instance.BackgroundColor3 = Theme.ElementHover
                    SubIcon.ImageColor3 = Theme.Accent1
                    SubText.TextColor3 = Theme.Text
                    SubContainer.Instance.Visible = true
                end

                local function DeactivateSub()
                    SubTab.Active = false
                    SubButton.Instance.BackgroundTransparency = 1
                    SubIcon.ImageColor3 = Theme.TextDim
                    SubText.TextColor3 = Theme.TextDim
                    SubContainer.Instance.Visible = false
                end

                SubTab.ActivateSub = ActivateSub
                SubTab.DeactivateSub = DeactivateSub

                SubButton.Instance.MouseButton1Click:Connect(ActivateSub)

                table.insert(Tab.SubTabs, SubTab)

                -- ═══════════════════════════════════════════════════
                -- СЕКЦИЯ
                -- ═══════════════════════════════════════════════════
                function SubTab:Section(Params)
                    Params = Params or {}

                    local Section = Library:Create("Frame", {
                        Parent = SubContainer.Instance,
                        Size = UDim2.new(1, 0, 0, 0),
                        BackgroundColor3 = Theme.Background2,
                        BorderSizePixel = 0,
                        AutomaticSize = Enum.AutomaticSize.Y,
                        ClipsDescendants = true,
                    })
                    Library:Create("UICorner", {Parent = Section.Instance, CornerRadius = UDim.new(0, 8)})
                    Library:Create("UIStroke", {Parent = Section.Instance, Color = Theme.Outline, Thickness = 1})

                    local Header = Library:Create("Frame", {
                        Parent = Section.Instance,
                        Size = UDim2.new(1, 0, 0, 36),
                        BackgroundTransparency = 1,
                        BorderSizePixel = 0,
                    })
                    local HeaderText = Library:Create("TextLabel", {
                        Parent = Header.Instance,
                        Text = Params.Name or "Section",
                        Font = FontBoldEnum,
                        TextSize = 14,
                        TextColor3 = Theme.Text,
                        Position = UDim2.new(0, 14, 0.5, 0),
                        AnchorPoint = Vector2.new(0, 0.5),
                        BackgroundTransparency = 1,
                    })
                    local PulseDot = Library:Create("Frame", {
                        Parent = Header.Instance,
                        Size = UDim2.new(0, 8, 0, 8),
                        Position = UDim2.new(1, -16, 0.5, 0),
                        AnchorPoint = Vector2.new(0.5, 0.5),
                        BackgroundColor3 = Theme.Accent1,
                        BorderSizePixel = 0,
                    })
                    Library:Create("UICorner", {Parent = PulseDot.Instance, CornerRadius = UDim.new(1, 0)})
                    Library:AddPulse(PulseDot, 0.3)

                    local Content = Library:Create("Frame", {
                        Parent = Section.Instance,
                        Position = UDim2.new(0, 0, 0, 36),
                        Size = UDim2.new(1, 0, 0, 0),
                        BackgroundTransparency = 1,
                        BorderSizePixel = 0,
                        AutomaticSize = Enum.AutomaticSize.Y,
                    })
                    Library:Create("UIListLayout", {Parent = Content.Instance, Padding = UDim.new(0, 4), SortOrder = Enum.SortOrder.LayoutOrder})
                    Library:Create("UIPadding", {Parent = Content.Instance, PaddingBottom = UDim.new(0, 10), PaddingTop = UDim.new(0, 4), PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12)})

                    return {
                        Instance = Section,
                        Content = Content,
                        Add = function(self, Element)
                            if Element and Element.Instance then
                                Element.Instance.Parent = Content.Instance
                            end
                            return Element
                        end
                    }
                end

                -- ═══════════════════════════════════════════════════
                -- TOGGLE
                -- ═══════════════════════════════════════════════════
                function SubTab:Toggle(Params)
                    Params = Params or {}

                    local Element = {
                        Name = Params.Name or "Toggle",
                        Flag = Params.Flag or "Toggle_" .. tostring(#Library.Elements + 1),
                        Default = Params.Default or false,
                        Callback = Params.Callback or function() end,
                        Value = false,
                    }

                    local Container = Library:Create("Frame", {
                        Size = UDim2.new(1, 0, 0, 28),
                        BackgroundTransparency = 1,
                        BorderSizePixel = 0,
                    })
                    local Label = Library:Create("TextLabel", {
                        Parent = Container.Instance,
                        Text = Element.Name,
                        Font = FontEnum,
                        TextSize = 14,
                        TextColor3 = Theme.Text,
                        Position = UDim2.new(0, 0, 0.5, 0),
                        AnchorPoint = Vector2.new(0, 0.5),
                        BackgroundTransparency = 1,
                    })
                    local Track = Library:Create("TextButton", {
                        Parent = Container.Instance,
                        AnchorPoint = Vector2.new(1, 0.5),
                        Position = UDim2.new(1, 0, 0.5, 0),
                        Size = UDim2.new(0, 40, 0, 22),
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                    })
                    Library:Create("UICorner", {Parent = Track.Instance, CornerRadius = UDim.new(1, 0)})
                    local Knob = Library:Create("Frame", {
                        Parent = Track.Instance,
                        Size = UDim2.new(0, 16, 0, 16),
                        Position = UDim2.new(0, 3, 0.5, -8),
                        BackgroundColor3 = Theme.TextDim,
                        BorderSizePixel = 0,
                    })
                    Library:Create("UICorner", {Parent = Knob.Instance, CornerRadius = UDim.new(1, 0)})

                    function Element:Set(Value)
                        Element.Value = Value
                        if Value then
                            Track.Instance.BackgroundColor3 = Theme.Accent1
                            Knob.Instance.Position = UDim2.new(1, -19, 0.5, -8)
                            Knob.Instance.BackgroundColor3 = Theme.Text
                        else
                            Track.Instance.BackgroundColor3 = Theme.Element
                            Knob.Instance.Position = UDim2.new(0, 3, 0.5, -8)
                            Knob.Instance.BackgroundColor3 = Theme.TextDim
                        end
                        Library.Flags[Element.Flag] = Value
                        Library.SafeCall(Element.Callback, Value)
                    end

                    Track.Instance.MouseButton1Click:Connect(function()
                        Element:Set(not Element.Value)
                    end)

                    Element.Instance = Container.Instance
                    Library.Elements[Element.Flag] = Element
                    Library.ConfigFlags[Element.Flag] = function(Value) Element:Set(Value) end
                    Element:Set(Element.Default)
                    return Element
                end

                -- ═══════════════════════════════════════════════════
                -- BUTTON
                -- ═══════════════════════════════════════════════════
                function SubTab:Button(Params)
                    Params = Params or {}

                    local Element = {
                        Name = Params.Name or "Button",
                        Callback = Params.Callback or function() end,
                    }

                    local Container = Library:Create("Frame", {
                        Size = UDim2.new(1, 0, 0, 32),
                        BackgroundTransparency = 1,
                        BorderSizePixel = 0,
                    })
                    local Button = Library:Create("TextButton", {
                        Parent = Container.Instance,
                        Size = UDim2.new(1, 0, 1, 0),
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Text = Element.Name,
                        TextColor3 = Theme.Text,
                        Font = FontBoldEnum,
                        TextSize = 14,
                    })
                    Library:Create("UICorner", {Parent = Button.Instance, CornerRadius = UDim.new(0, 6)})

                    Button.Instance.MouseEnter:Connect(function()
                        Button.Instance.BackgroundColor3 = Theme.ElementHover
                    end)
                    Button.Instance.MouseLeave:Connect(function()
                        Button.Instance.BackgroundColor3 = Theme.Element
                    end)
                    Button.Instance.MouseButton1Click:Connect(function()
                        Button.Instance.BackgroundColor3 = Theme.Accent2
                        task.wait(0.08)
                        Button.Instance.BackgroundColor3 = Theme.Element
                        Library.SafeCall(Element.Callback)
                    end)

                    Element.Instance = Container.Instance
                    return Element
                end

                -- ═══════════════════════════════════════════════════
                -- SLIDER
                -- ═══════════════════════════════════════════════════
                function SubTab:Slider(Params)
                    Params = Params or {}

                    local Element = {
                        Name = Params.Name or "Slider",
                        Flag = Params.Flag or "Slider_" .. tostring(#Library.Elements + 1),
                        Min = Params.Min or 0,
                        Max = Params.Max or 100,
                        Default = Params.Default or 50,
                        Suffix = Params.Suffix or "",
                        Callback = Params.Callback or function() end,
                        Value = 0,
                        Sliding = false,
                    }

                    local Container = Library:Create("Frame", {
                        Size = UDim2.new(1, 0, 0, 44),
                        BackgroundTransparency = 1,
                        BorderSizePixel = 0,
                    })
                    local Label = Library:Create("TextLabel", {
                        Parent = Container.Instance,
                        Text = Element.Name,
                        Font = FontEnum,
                        TextSize = 14,
                        TextColor3 = Theme.Text,
                        Position = UDim2.new(0, 0, 0, 0),
                        BackgroundTransparency = 1,
                    })
                    local ValueLabel = Library:Create("TextLabel", {
                        Parent = Container.Instance,
                        Text = tostring(Element.Default) .. Element.Suffix,
                        Font = FontBoldEnum,
                        TextSize = 14,
                        TextColor3 = Theme.Accent1,
                        AnchorPoint = Vector2.new(1, 0),
                        Position = UDim2.new(1, 0, 0, 0),
                        BackgroundTransparency = 1,
                    })
                    local Track = Library:Create("TextButton", {
                        Parent = Container.Instance,
                        AnchorPoint = Vector2.new(0, 1),
                        Position = UDim2.new(0, 0, 1, -4),
                        Size = UDim2.new(1, 0, 0, 4),
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                    })
                    Library:Create("UICorner", {Parent = Track.Instance, CornerRadius = UDim.new(1, 0)})
                    local Fill = Library:Create("Frame", {
                        Parent = Track.Instance,
                        Size = UDim2.new(0.5, 0, 1, 0),
                        BackgroundColor3 = Theme.Accent1,
                        BorderSizePixel = 0,
                    })
                    Library:Create("UICorner", {Parent = Fill.Instance, CornerRadius = UDim.new(1, 0)})
                    Library:AddPulse(Fill, 0.06)
                    local Knob = Library:Create("Frame", {
                        Parent = Track.Instance,
                        Size = UDim2.new(0, 12, 0, 12),
                        Position = UDim2.new(0.5, -6, 0.5, -6),
                        BackgroundColor3 = Theme.Accent1,
                        BorderSizePixel = 0,
                    })
                    Library:Create("UICorner", {Parent = Knob.Instance, CornerRadius = UDim.new(1, 0)})

                    function Element:Set(Value)
                        Element.Value = math.clamp(Value, Element.Min, Element.Max)
                        local Percent = (Element.Value - Element.Min) / (Element.Max - Element.Min)
                        Fill.Instance.Size = UDim2.new(Percent, 0, 1, 0)
                        Knob.Instance.Position = UDim2.new(Percent, -6, 0.5, -6)
                        ValueLabel.Text = tostring(Element.Value) .. Element.Suffix
                        Library.Flags[Element.Flag] = Element.Value
                        Library.SafeCall(Element.Callback, Element.Value)
                    end

                    Track.Instance.InputBegan:Connect(function(Input)
                        if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                            Element.Sliding = true
                            local X = (Input.Position.X - Track.Instance.AbsolutePosition.X) / Track.Instance.AbsoluteSize.X
                            local Value = Element.Min + (Element.Max - Element.Min) * math.clamp(X, 0, 1)
                            Element:Set(Value)
                        end
                    end)
                    Library:Connect(UserInputService.InputEnded, function(Input)
                        if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                            Element.Sliding = false
                        end
                    end)
                    Library:Connect(UserInputService.InputChanged, function(Input)
                        if Element.Sliding and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                            local X = (Input.Position.X - Track.Instance.AbsolutePosition.X) / Track.Instance.AbsoluteSize.X
                            local Value = Element.Min + (Element.Max - Element.Min) * math.clamp(X, 0, 1)
                            Element:Set(Value)
                        end
                    end)

                    Element.Instance = Container.Instance
                    Library.Elements[Element.Flag] = Element
                    Library.ConfigFlags[Element.Flag] = function(Value) Element:Set(Value) end
                    Element:Set(Element.Default)
                    return Element
                end

                -- ═══════════════════════════════════════════════════
                -- LABEL
                -- ═══════════════════════════════════════════════════
                function SubTab:Label(Params)
                    Params = Params or {}

                    local Element = {
                        Name = Params.Name or "",
                    }

                    local Container = Library:Create("Frame", {
                        Size = UDim2.new(1, 0, 0, 22),
                        BackgroundTransparency = 1,
                        BorderSizePixel = 0,
                    })
                    local Label = Library:Create("TextLabel", {
                        Parent = Container.Instance,
                        Text = Element.Name,
                        Font = Params.Bold and FontBoldEnum or FontEnum,
                        TextSize = Params.Size or 14,
                        TextColor3 = Params.Dim and Theme.TextDim or Theme.Text,
                        Position = UDim2.new(0, 0, 0.5, 0),
                        AnchorPoint = Vector2.new(0, 0.5),
                        BackgroundTransparency = 1,
                    })

                    Element.Instance = Container.Instance
                    Element.SetText = function(Text) Label.Text = Text end
                    return Element
                end

                if not Tab.ActiveSubTab then
                    ActivateSub()
                end

                return SubTab
            end

            table.insert(Window.Tabs, Tab)
            if #Window.Tabs == 1 then Activate() end

            return Tab
        end

        Library.Window = Window
        return Window
    end

    getgenv().PulseUI = Library
    return Library
end
