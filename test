        availablePets[i], availablePets[j] = availablePets[j], availablePets[i]
    end
    
    while #spawnedPets < petCount and attempts < maxAttempts do
        attempts = attempts + 1
        local randomIndex = math.random(1, #availablePets)
        local pet = availablePets[randomIndex]
        
        -- Выбираем тип: если MFR цена < 100, то используем MFR
        -- Иначе рандомно FR/NFR/MFR
        local variantType
        local price
        
        if pet.mfr < 100 then
            -- Если MFR меньше 100, используем MFR
            variantType = "MFR"
            price = pet.mfr
        else
            -- Иначе рандомно выбираем
            local variants = {
                {name = "FR", price = pet.fr},
                {name = "NFR", price = pet.nfr},
                {name = "MFR", price = pet.mfr},
            }
            local chosen = variants[math.random(1, 3)]
            variantType = chosen.name
            price = chosen.price
        end
        
        -- Пропускаем если цена 0
        if price <= 0 then
            price = pet.fr
            if price <= 0 then price = pet.nfr end
            if price <= 0 then price = pet.mfr end
            if price <= 0 then
                logGUI:log("⚠️ " .. pet.name .. " - нет цены", Color3.fromRGB(255, 255, 0))
                task.wait(0.05)
                continue
            end
        end
        
        local petData = {
            pet_trick_level = 0,
            rideable = true,
            flyable = true,
            friendship_level = 0,
            age = 1,
            ailments_completed = 0,
            rp_name = '',
        }
        
        if variantType == "MFR" then
            petData.mega_neon = true
        elseif variantType == "NFR" then
            petData.neon = true
        end
        -- FR - ничего не добавляем, просто rideable + flyable
        
        logGUI:log("🔄 " .. pet.name .. " (" .. variantType .. ")", Color3.fromRGB(255, 255, 0))
        
        local success, result = pcall(function()
            return u63(pet.id, petData)
        end)
        
        if success and result then
            currentValue = currentValue + price
            table.insert(spawnedPets, pet.name .. " (" .. variantType .. ") [" .. string.format("%.1f", price) .. "]")
            logGUI:log("✅ " .. pet.name .. " (" .. variantType .. ") +" .. price, Color3.fromRGB(0, 255, 0))
            
            pcall(function()
                game.StarterGui:SetCore('SendNotification', {
                    Title = '✅ Спавн!',
                    Text = pet.name .. ' (' .. variantType .. ')',
                    Duration = 2,
                })
            end)
        else
            logGUI:log("❌ Ошибка: " .. pet.name, Color3.fromRGB(255, 0, 0))
        end
        
        task.wait(0.08)
        
        -- Если набрали нужную сумму и достаточно петов - выходим
        if currentValue >= targetMin and #spawnedPets >= 10 then
            break
        end
    end
    
    -- ═══════════════════════════════════════════════════════════════
    -- РЕЗУЛЬТАТ
    -- ═══════════════════════════════════════════════════════════════
    
    logGUI:log("━━━━━━━━━━━━━━━━━━━━━━━━", Color3.fromRGB(255, 255, 255))
    if #spawnedPets > 0 then
        logGUI:log("✅ Спавнено: " .. #spawnedPets, Color3.fromRGB(0, 255, 0))
        logGUI:log("💰 Сумма: " .. string.format("%.2f", currentValue), Color3.fromRGB(255, 255, 0))
        for i, pet in ipairs(spawnedPets) do
            logGUI:log("  " .. i .. ". " .. pet, Color3.fromRGB(200, 200, 200))
        end
        
        local statusText = "Спавнено " .. #spawnedPets .. " петов! Сумма: " .. string.format("%.2f", currentValue)
        if currentValue < targetMin then
            statusText = statusText .. " (маловато 😅)"
        elseif currentValue > targetMax then
            statusText = statusText .. " (многовато 😅)"
        else
            statusText = statusText .. " ✅"
        end
        
        pcall(function()
            game.StarterGui:SetCore('SendNotification', {
                Title = '✅ Готово!',
                Text = statusText,
                Duration = 5,
            })
        end)
    else
