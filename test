                            selectedMulti = {}
                            if type(v) == "table" then
                                for _, item in ipairs(v) do
                                    selectedMulti[item] = true
                                end
                            end
                            local list = {}
                            for k, v2 in pairs(selectedMulti) do
                                if v2 then table.insert(list, k) end
                            end
                            ValueLabel.Text = #list > 0 and table.concat(list, ", ") or "None"
                            Flags[flag] = list
                            pcall(callback, list)
                        else
                            selectItem(v, true)
                        end
                    end,
                    Get = function()
                        if multi then
                            local list = {}
                            for k, v in pairs(selectedMulti) do
                                if v then table.insert(list, k) end
                            end
                            return list
                        end
                        return selected
                    end,
                    Refresh = function(newItems)
                        for _, child in ipairs(List:GetChildren()) do
                            if child:IsA("TextButton") then child:Destroy() end
                        end
                        items = newItems or {}
                        for _, item in ipairs(items) do
                            local itemFrame = Instance.new("TextButton")
                            itemFrame.Size = UDim2.new(1, -8, 0, 28)
                            itemFrame.Position = UDim2.new(0, 4, 0, 0)
                            itemFrame.BackgroundTransparency = 1
                            itemFrame.Text = ""
                            itemFrame.AutoButtonColor = false
                            itemFrame.Parent = List
                            
                            local itemLabel = Instance.new("TextLabel")
