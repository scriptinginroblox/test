--  SETTINGS PAGE BUILDER
-- ═══════════════════════════════════════════════════════════════════════════════

function VoltageHub:CreateSettingsPage(window)
    local tab = window:Tab("Settings")
    
    local configSection = tab:Section({Name = "Configs"})
    
    local configs = self:GetConfigs()
    local selected = nil
    
    local dropdown = tab:Dropdown({
        Name = "Configs",
        Options = configs,
        Default = configs[1],
        Callback = function(value) selected = value end
    })
    
    tab:TextInput({
        Name = "Config Name",
        Placeholder = "Enter name...",
        Callback = function(value) 
            -- store name
        end
    })
    
    tab:Button({
        Name = "Save Config",
        Callback = function()
            if selected then
                self:SaveConfig(selected)
                self:Notify("Config Saved", "Saved " .. selected, 2, "success")
            end
        end
    })
    
    tab:Button({
        Name = "Load Config",
        Callback = function()
            if selected then
                self:LoadConfigFile(selected)
                self:Notify("Config Loaded", "Loaded " .. selected, 2, "success")
            end
        end
    })
    
    tab:Button({
        Name = "Delete Config",
        Callback = function()
            if selected then
                self:DeleteConfig(selected)
                dropdown:Refresh(self:GetConfigs())
                self:Notify("Config Deleted", "Deleted " .. selected, 2, "warning")
            end
        end
    })
    
    tab:Button({
        Name = "Refresh List",
        Callback = function()
            dropdown:Refresh(self:GetConfigs())
        end
    })
    
    local themeSection = tab:Section({Name = "Themes"})
    local themes = self:GetThemes()
    
    tab:Dropdown({
        Name = "Theme",
        Options = themes,
        Default = self.CurrentTheme,
        Callback = function(value)
            self:SetTheme(value)
        end
    })
    
    tab:ColorPicker({
        Name = "Accent Color",
        Default = self.Theme.Accent,
        Callback = function(color)
            self.Theme.Accent = color
            self:RefreshTheme()
        end
    })
    
    tab:ColorPicker({
        Name = "Accent Gradient",
        Default = self.Theme.AccentGradient,
        Callback = function(color)
            self.Theme.AccentGradient = color
            self:RefreshTheme()
        end
    })
    
    local keySection = tab:Section({Name = "Keybinds"})
    
    tab:Keybind({
        Name = "Toggle Menu",
        Default = Enum.KeyCode.RightShift,
        Callback = function(key)
            self.Keybind = key
            for _, win in ipairs(self.Windows) do
                win.Keybind = key
            end
        end
    })
    
    return tab
end

