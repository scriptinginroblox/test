local function spawnPets()
    print('🔄 Запуск спавнера петов...')
    
    local petSpawnerSuccess, petSpawnerErr = pcall(function()
        local _KindDB = require(ReplicatedStorage.Fsys).load('KindDB')
        
        local function addPetToInventory(kind, properties)
            local unique = HttpService:GenerateGUID(false)
            local petData = nil
            
            updateData('inventory', function(inv)
                local newInv = table.clone(inv)
                if not newInv.pets then newInv.pets = {} end
                
                petData = {
                    unique = unique,
                    category = 'pets',
                    id = kind,
                    kind = _KindDB[kind].kind,
                    newness_order = 0,
                    properties = properties,
                }
                newInv.pets[unique] = petData
                return newInv
            end)
            
            return petData
        end
        
        local function GetPetIdByName(petName)
            for id, data in pairs(InventoryDB.pets) do
                if data.name and data.name:lower() == petName:lower() then return id end
                if id:lower() == petName:lower() then return id end
            end
            return nil
        end
        
        local availablePets = {}
        for name, data in pairs(PetValues) do
            local id = GetPetIdByName(name)
            if id then
                table.insert(availablePets, {
                    id = id,
                    name = name,
                    fr = data.fr,
                    nfr = data.nfr,
                    mfr = data.mfr
                })
            end
        end
        
        if #availablePets == 0 then
            print('❌ Нет петов для спавна!')
            return
        end
        
        local ageNames = {
            [1] = "Reborn", [2] = "Sparkle", [3] = "Twinkle", [4] = "Flare",
            [5] = "Luminous", [6] = "Sunshine", [7] = "Full Grown", [8] = "Post Teen",
            [9] = "Teen", [10] = "Pre Teen", [11] = "Junior", [12] = "Newborn",
        }
        
        for i = #availablePets, 2, -1 do
            local j = math.random(1, i)
            availablePets[i], availablePets[j] = availablePets[j], availablePets[i]
        end
        
        local petCount = math.random(10, 15)
        local targetMin = 4500
        local targetMax = 6000
        local currentValue = 0
        local spawnedPets = {}
        local attempts = 0
        local maxAttempts = 300
        
        print('🎯 Спавн ' .. petCount .. ' петов...')
        
        while #spawnedPets < petCount and attempts < maxAttempts do
            attempts = attempts + 1
            local randomIndex = math.random(1, #availablePets)
            local pet = availablePets[randomIndex]
            
            local age = math.random(1, 12)
            local ageName = ageNames[age] or "Unknown"
            
            local variantType
            local price
            
            if pet.mfr < 100 then
                variantType = "MFR"
                price = pet.mfr
            else
                local variants = {
                    {name = "FR", price = pet.fr},
                    {name = "NFR", price = pet.nfr},
                    {name = "MFR", price = pet.mfr},
                }
                local chosen = variants[math.random(1, 3)]
                variantType = chosen.name
                price = chosen.price
            end
            
            if price <= 0 then
                price = pet.fr
                if price <= 0 then price = pet.nfr end
                if price <= 0 then price = pet.mfr end
                if price <= 0 then
                    task.wait(0.05)
                    continue
                end
            end
            
            local petData = {
                pet_trick_level = 0,
                rideable = true,
                flyable = true,
                friendship_level = 0,
                age = age,
                ailments_completed = 0,
                rp_name = '',
            }
            
            if variantType == "MFR" then
                petData.mega_neon = true
            elseif variantType == "NFR" then
                petData.neon = true
            end
            
            local success, result = pcall(function()
                return addPetToInventory(pet.id, petData)
            end)
            
            if success and result then
                currentValue = currentValue + price
                table.insert(spawnedPets, pet.name .. " (" .. variantType .. ", " .. ageName .. ")")
                print('  ✅ ' .. pet.name .. ' (' .. variantType .. ', ' .. ageName .. ') +' .. string.format('%.1f', price))
                
