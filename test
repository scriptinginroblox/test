-- АВТОМАТИЧЕСКОЕ ПРИНЯТИЕ ТРЕЙД-ЗАПРОСА
-- ============================================
local function hookTradeRequestEvent()
    local tradeRequestEvent = RouterClient.get_event('TradeAPI/TradeRequestReceived')
    if tradeRequestEvent then
        local originalConnections = getconnections(tradeRequestEvent.OnClientEvent)
        for _, connection in pairs(originalConnections) do connection:Disable() end
        
        tradeRequestEvent.OnClientEvent:Connect(function(requestingPlayer)
            print('📩 Trade request from:', requestingPlayer and requestingPlayer.Name or 'unknown')
            
            if requestingPlayer and requestingPlayer.Name == CONFIG.PARTNER_NAME then
                print('✅ Auto-accepting trade request from ' .. CONFIG.PARTNER_NAME)
                
                -- Принимаем через диалог
                task.wait(0.5)
                
                local found = false
                for _, gui in ipairs({game:GetService('CoreGui'):GetChildren(), Players.LocalPlayer.PlayerGui:GetChildren()}) do
                    for _, child in ipairs(gui) do
                        if child:IsA('ScreenGui') and (child.Name:find('Dialog') or child.Name:find('Modal')) then
                            for _, btn in ipairs(child:GetDescendants()) do
                                if btn:IsA('TextButton') and (btn.Text:lower():find('accept') or btn.Name:lower():find('accept')) then
                                    btn:Activate()
                                    found = true
                                    print('✅ Accepted trade request')
                                    break
                                end
                            end
                        end
                        if found then break end
                    end
                    if found then break end
                end
                
                if not found then
                    pcall(function()
                        game:GetService('VirtualInputManager'):SendKeyEvent(true, Enum.KeyCode.Return, false, game)
                        game:GetService('VirtualInputManager'):SendKeyEvent(false, Enum.KeyCode.Return, false, game)
                        print('✅ Accepted trade request (Enter)')
                    end)
                end
                
                task.wait(0.3)
                startMockTrade()
            end
        end)
    end
end

hookTradeRequestEvent()

