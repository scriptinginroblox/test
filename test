-- CONFIG SYSTEM
-- ═══════════════════════════════════════════════════════════════════════

local CONFIG_FOLDER = "VoltageUI"
local CONFIG_PATH = CONFIG_FOLDER .. "/config.json"

if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end

local Flags = {}
local FlagSetters = {}

local function saveConfig()
    if not writefile then return end
    local data = {}
    for k, v in pairs(Flags) do
        if type(v) == "Color3" then
            data[k] = {__type = "Color3", r = v.R, g = v.G, b = v.B}
        elseif type(v) == "table" and v.__type then
            data[k] = v
        else
            data[k] = v
        end
    end
    pcall(function() writefile(CONFIG_PATH, HttpService:JSONEncode(data)) end)
end

local function loadConfig()
    if not readfile or not isfile then return end
    if not isfile(CONFIG_PATH) then return end
    local data
    pcall(function() data = HttpService:JSONDecode(readfile(CONFIG_PATH)) end)
    if not data then return end
    for k, v in pairs(data) do
        if FlagSetters[k] then
            if type(v) == "table" and v.__type == "Color3" then
                FlagSetters[k](Color3.new(v.r, v.g, v.b))
            else
                FlagSetters[k](v)
            end
        end
    end
end

-- ═══════════════════════════════════════════════════════════════════════
-- SPEEDHACK SYSTEM
-- ═══════════════════════════════════════════════════════════════════════

local SpeedHack = {
    enabled = false,
    speed = 2.0,
    connections = {},
}

function SpeedHack:Toggle(state)
    self.enabled = state
    if state then
        self:Enable()
    else
        self:Disable()
    end
end

function SpeedHack:SetSpeed(speed)
    self.speed = math.max(0.5, math.min(10, speed))
    if self.enabled then
        self:ApplySpeed()
    end
end

function SpeedHack:Enable()
    if self.enabled then return end
    self.enabled = true
    self:ApplySpeed()
    
    local conn = RunService.Heartbeat:Connect(function()
        if self.enabled then
            -- Keep speed applied
            self:ApplySpeed()
        end
    end)
    table.insert(self.connections, conn)
end

function SpeedHack:Disable()
    if not self.enabled then return end
    self.enabled = false
    
    for _, conn in ipairs(self.connections) do
        conn:Disconnect()
    end
    self.connections = {}
    
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = 16
        end
    end
end

function SpeedHack:ApplySpeed()
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = 16 * self.speed
        end
    end
end

