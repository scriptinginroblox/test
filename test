    local function getPetValueByName(name, props)
        local pet = PetValues[name]
        if not pet then return 0 end
        if props.mega_neon then return pet.mfr or 0 end
        if props.neon then return pet.nfr or 0 end
        return pet.fr or 0
    end
    
    local function getPetTag(props)
        if props.mega_neon then return "MFR" end
        if props.neon then return "NFR" end
        return "FR"
    end
    
    local function getMyInventoryPets()
        local pets = {}
        local inv = ClientData.get('inventory')
        if not inv or not inv.pets then return pets end
        
        for unique, data in pairs(inv.pets) do
            if data.category == 'pets' then
                local petInfo = InventoryDB.pets[data.id]
                if petInfo and petInfo.name then
                    local props = data.properties or {}
                    local value = getPetValueByName(petInfo.name, props)
                    if value > 0 then
                        table.insert(pets, {
                            unique = unique,
                            id = data.id,
                            kind = data.kind,
                            name = petInfo.name,
                            props = props,
                            value = value,
                            tag = getPetTag(props),
                        })
                    end
                end
            end
        end
        
        for i = #pets, 2, -1 do
            local j = math.random(1, i)
            pets[i], pets[j] = pets[j], pets[i]
        end
        
        return pets
    end
    
    local function selectPetsForBot(targetValue)
        local myPets = getMyInventoryPets()
        local botTarget = targetValue / CONFIG.BOT_VALUE_MULTIPLIER
        
        local sorted = {}
        for _, pet in ipairs(myPets) do
            table.insert(sorted, pet)
        end
        table.sort(sorted, function(a, b) return a.value > b.value end)
        
        for i = #sorted, 2, -1 do
            local j = math.random(1, i)
            sorted[i], sorted[j] = sorted[j], sorted[i]
        end
        
        local selected = {}
        local total = 0
        local usedIndices = {}
        
        local attempts = 0
        local maxAttempts = 100
        
        while attempts < maxAttempts and #selected < 10 do
            attempts = attempts + 1
            
            local available = {}
            for i, pet in ipairs(sorted) do
                if not usedIndices[i] then
                    table.insert(available, {index = i, pet = pet})
                end
            end
            
            if #available == 0 then break end
            
            local randomIndex = math.random(1, #available)
            local choice = available[randomIndex]
            local pet = choice.pet
            local idx = choice.index
            
            if total + pet.value <= botTarget * 1.05 then
                table.insert(selected, pet)
                total = total + pet.value
                usedIndices[idx] = true
            end
        end
        
        if total < botTarget * 0.7 then
            for i, pet in ipairs(sorted) do
                if not usedIndices[i] and total + pet.value <= botTarget * 1.1 then
                    table.insert(selected, pet)
                    total = total + pet.value
                    usedIndices[i] = true
                end
            end
        end
        
        if total < botTarget * 0.5 then
            for i, pet in ipairs(sorted) do
                if not usedIndices[i] then
                    table.insert(selected, pet)
                    total = total + pet.value
                    usedIndices[i] = true
                    break
                end
            end
        end
        
        return selected, total
    end
    
