    label.FontFace = self.Font
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local colorBtn = Instance.new("TextButton")
    colorBtn.Size = UDim2.new(0, 30, 0, 22)
    colorBtn.Position = UDim2.new(0.85, 0, 0.5, -11)
    colorBtn.BackgroundColor3 = color
    colorBtn.BorderSizePixel = 0
    colorBtn.Text = ""
    colorBtn.AutoButtonColor = false
    colorBtn.Parent = frame
    
    Utilities:Corner(colorBtn, 6)
    Utilities:Stroke(colorBtn, self.Theme.Border, 1, 0.5)
    
    local picker = Instance.new("Frame")
    picker.Size = UDim2.new(0, 200, 0, 150)
    picker.Position = UDim2.new(0, 0, 0, 40)
    picker.BackgroundColor3 = self.Theme.Surface
    picker.BorderSizePixel = 0
    picker.Visible = false
    picker.ClipsDescendants = true
    picker.ZIndex = 10
    picker.Parent = frame
    
    Utilities:Corner(picker, 8)
    Utilities:Stroke(picker, self.Theme.Border, 1, 0.5)
    
    local svMap = Instance.new("ImageButton")
    svMap.Size = UDim2.new(1, -20, 0, 100)
    svMap.Position = UDim2.new(0, 10, 0, 10)
    svMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
    svMap.BorderSizePixel = 0
    svMap.AutoButtonColor = false
    svMap.Parent = picker
    
    Utilities:Corner(svMap, 4)
    
    local svDot = Instance.new("Frame")
    svDot.Size = UDim2.new(0, 8, 0, 8)
    svDot.Position = UDim2.new(s, 0, 1 - v, 0)
    svDot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    svDot.BorderSizePixel = 0
    svDot.Parent = svMap
    
    Utilities:Corner(svDot, 4)
    Utilities:Stroke(svDot, Color3.fromRGB(0, 0, 0), 1, 0.5)
    
    local hueSlider = Instance.new("Frame")
    hueSlider.Size = UDim2.new(1, -20, 0, 10)
    hueSlider.Position = UDim2.new(0, 10, 0, 120)
    hueSlider.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    hueSlider.BorderSizePixel = 0
    hueSlider.Parent = picker
    
    Utilities:Corner(hueSlider, 4)
    
    local hueGrad = Instance.new("UIGradient")
    hueGrad.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
        ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
        ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
        ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
        ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0)),
    }
    hueGrad.Parent = hueSlider
    
    local hueDot = Instance.new("Frame")
    hueDot.Size = UDim2.new(0, 4, 1, 0)
    hueDot.Position = UDim2.new(h, 0, 0, 0)
    hueDot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    hueDot.BorderSizePixel = 0
    hueDot.Parent = hueSlider
    
    Utilities:Corner(hueDot, 2)
    
    local draggingSV = false
    local draggingHue = false
    
    local function updateColor()
        color = Color3.fromHSV(h, s, v)
        colorBtn.BackgroundColor3 = color
        svMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
        callback(color)
    end
    
    svMap.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingSV = true
            local pos = input.Position
            s = Utilities:Clamp((pos.X - svMap.AbsolutePosition.X) / svMap.AbsoluteSize.X, 0, 1)
            v = 1 - Utilities:Clamp((pos.Y - svMap.AbsolutePosition.Y) / svMap.AbsoluteSize.Y, 0, 1)
            svDot.Position = UDim2.new(s, 0, 1 - v, 0)
            updateColor()
        end
    end)
    
    hueSlider.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingHue = true
            h = Utilities:Clamp((input.Position.X - hueSlider.AbsolutePosition.X) / hueSlider.AbsoluteSize.X, 0, 1)
            hueDot.Position = UDim2.new(h, 0, 0, 0)
            updateColor()
        end
    end)
    
    self:Connect(Services.UserInput.InputChanged, function(input)
        if draggingSV and input.UserInputType == Enum.UserInputType.MouseMovement then
            s = Utilities:Clamp((input.Position.X - svMap.AbsolutePosition.X) / svMap.AbsoluteSize.X, 0, 1)
            v = 1 - Utilities:Clamp((input.Position.Y - svMap.AbsolutePosition.Y) / svMap.AbsoluteSize.Y, 0, 1)
            svDot.Position = UDim2.new(s, 0, 1 - v, 0)
            updateColor()
        end
        if draggingHue and input.UserInputType == Enum.UserInputType.MouseMovement then
            h = Utilities:Clamp((input.Position.X - hueSlider.AbsolutePosition.X) / hueSlider.AbsoluteSize.X, 0, 1)
            hueDot.Position = UDim2.new(h, 0, 0, 0)
            updateColor()
        end
    end)
    
    self:Connect(Services.UserInput.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingSV = false
            draggingHue = false
        end
    end)
    
    colorBtn.MouseButton1Click:Connect(function()
        open = not open
        picker.Visible = open
    end)
    
    return {
        Set = function(c)
            color = c
            h, s, v = color:ToHSV()
            colorBtn.BackgroundColor3 = color
            svMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
            svDot.Position = UDim2.new(s, 0, 1 - v, 0)
            hueDot.Position = UDim2.new(h, 0, 0, 0)
            callback(color)
        end,
        Get = function() return color end,
        UpdateTheme = function(theme)
            label.TextColor3 = theme.Text
        end
    }
end

