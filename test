-- Обработчик открытия/закрытия меню
local menuOpen = false

callButton.MouseButton1Click:Connect(function()
    menuOpen = not menuOpen
    menu.Visible = menuOpen
    
    if menuOpen then
        -- Позиционирование меню справа от кнопки
        local buttonPos = callButton.AbsolutePosition
        local buttonSize = callButton.AbsoluteSize
        
        local x = buttonPos.X + buttonSize.X + 5
        local y = buttonPos.Y - menuHeight / 2 + buttonSize.Y / 2
        
        -- Проверка, помещается ли справа
        local screenSize = gui.AbsoluteSize
        if x + menuWidth > screenSize.X then
            -- Не помещается справа - ставим слева
            x = buttonPos.X - menuWidth - 5
        end
        
        -- Проверка по вертикали
        if y < 0 then
            y = 0
        elseif y + menuHeight > screenSize.Y then
            y = screenSize.Y - menuHeight
        end
        
        menu.Position = UDim2.new(0, x, 0, y)
    end
end)

-- Обновление позиции при изменении размера экрана
gui.Changed:Connect(function()
    if menuOpen then
        local buttonPos = callButton.AbsolutePosition
        local buttonSize = callButton.AbsoluteSize
        
        local x = buttonPos.X + buttonSize.X + 5
        local y = buttonPos.Y - menuHeight / 2 + buttonSize.Y / 2
        
        local screenSize = gui.AbsoluteSize
        if x + menuWidth > screenSize.X then
            x = buttonPos.X - menuWidth - 5
        end
        
        if y < 0 then
            y = 0
        elseif y + menuHeight > screenSize.Y then
            y = screenSize.Y - menuHeight
        end
        
        menu.Position = UDim2.new(0, x, 0, y)
    end
end)
