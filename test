    local PulseObjects = {}

    function Library:AddPulse(Object, Intensity)
        Intensity = Intensity or 0.15
        local Instance = Object.Instance or Object
        table.insert(PulseObjects, {
            Object = Instance,
            Intensity = Intensity,
            OriginalColor = Instance.BackgroundColor3,
        })
    end

    Library:Connect(RunService.RenderStepped, function()
        local Time = tick()
        for _, Data in pairs(PulseObjects) do
            if Data.Object and Data.Object.Parent then
                local Pulse = math.sin(Time * Library.PulseSpeed) * Data.Intensity
                local Color = Data.OriginalColor
                local R = math.clamp(Color.R + Pulse, 0, 1)
                local G = math.clamp(Color.G + Pulse * 0.7, 0, 1)
                local B = math.clamp(Color.B + Pulse * 0.3, 0, 1)
                Data.Object.BackgroundColor3 = Color3.new(R, G, B)
            end
        end
    end)

