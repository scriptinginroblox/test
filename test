        -- SLIDER
        function Window:Slider(Params)
            Params = Params or {}

            local Element = {
                Name = Params.Name or "Slider",
                Flag = Params.Flag or "Slider_" .. tostring(#Library.Elements + 1),
                Min = Params.Min or 0,
                Max = Params.Max or 100,
                Default = Params.Default or 50,
                Decimals = Params.Decimals or 0,
                Suffix = Params.Suffix or "",
                Callback = Params.Callback or function() end,
                Value = 0,
                Sliding = false,
            }

            local Container = Library:Create("Frame", {
                Size = UDim2.new(1, 0, 0, 44),
                BackgroundTransparency = 1,
                BorderSizePixel = 0,
            })

            local Label = Library:Create("TextLabel", {
                Parent = Container.Instance,
                Text = Element.Name,
                FontFace = Library.Font,
                TextSize = 14,
                TextColor3 = Theme.Text,
                Position = UDim2.new(0, 0, 0, 0),
                BackgroundTransparency = 1,
            })

            local ValueLabel = Library:Create("TextLabel", {
                Parent = Container.Instance,
                Text = tostring(Element.Default) .. Element.Suffix,
                FontFace = Library.FontBold,
                TextSize = 14,
                TextColor3 = Theme.Accent1,
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, 0, 0, 0),
                BackgroundTransparency = 1,
            })

            local Track = Library:Create("TextButton", {
                Parent = Container.Instance,
                AnchorPoint = Vector2.new(0, 1),
                Position = UDim2.new(0, 0, 1, -4),
                Size = UDim2.new(1, 0, 0, 4),
                BackgroundColor3 = Theme.Element,
                BorderSizePixel = 0,
            })

            Library:Create("UICorner", {
                Parent = Track.Instance,
                CornerRadius = UDim.new(1, 0),
            })

            local Fill = Library:Create("Frame", {
                Parent = Track.Instance,
                Size = UDim2.new(0.5, 0, 1, 0),
                BackgroundColor3 = Theme.Accent1,
                BorderSizePixel = 0,
            })
            Library:Create("UICorner", {
                Parent = Fill.Instance,
                CornerRadius = UDim.new(1, 0),
            })

            local Knob = Library:Create("Frame", {
                Parent = Track.Instance,
                Size = UDim2.new(0, 12, 0, 12),
                Position = UDim2.new(0.5, -6, 0.5, -6),
                BackgroundColor3 = Theme.Accent1,
                BorderSizePixel = 0,
            })
            Library:Create("UICorner", {
                Parent = Knob.Instance,
                CornerRadius = UDim.new(1, 0),
            })

            function Element:Set(Value)
                Element.Value = math.clamp(Value, Element.Min, Element.Max)
                Element.Value = Library:Round(Element.Value, Element.Decimals)
                local Percent = (Element.Value - Element.Min) / (Element.Max - Element.Min)
                Fill.Instance.Size = UDim2.new(Percent, 0, 1, 0)
                Knob.Instance.Position = UDim2.new(Percent, -6, 0.5, -6)
                ValueLabel.Text = tostring(Element.Value) .. Element.Suffix
                Library.Flags[Element.Flag] = Element.Value
                Library.SafeCall(Element.Callback, Element.Value)
            end

            Track.Instance.InputBegan:Connect(function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                    Element.Sliding = true
                    local X = (Input.Position.X - Track.Instance.AbsolutePosition.X) / Track.Instance.AbsoluteSize.X
                    local Value = Element.Min + (Element.Max - Element.Min) * math.clamp(X, 0, 1)
                    Element:Set(Value)
                end
            end)

            Library:Connect(UserInputService.InputEnded, function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                    Element.Sliding = false
                end
            end)

            Library:Connect(UserInputService.InputChanged, function(Input)
                if Element.Sliding and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                    local X = (Input.Position.X - Track.Instance.AbsolutePosition.X) / Track.Instance.AbsoluteSize.X
                    local Value = Element.Min + (Element.Max - Element.Min) * math.clamp(X, 0, 1)
                    Element:Set(Value)
                end
            end)

            Element.Instance = Container.Instance
            Library.Elements[Element.Flag] = Element
            Library.ConfigFlags[Element.Flag] = function(Value) Element:Set(Value) end
            Element:Set(Element.Default)
            return Element
        end

